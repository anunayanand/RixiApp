<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Support Center | Rixi Lab</title>
  
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  
   <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon">
  
  <link rel="stylesheet" href="/css/supportCenter.css">
  <script>
    const savedTheme = localStorage.getItem('theme') || 'dark'; // Default to dark mode as requested
    document.documentElement.setAttribute('data-theme', savedTheme);
  </script>
</head>
<body>

<div class="support-container" id="supportContainer">
  <!-- Sidebar -->
  <div class="chat-sidebar">
    <div class="chat-sidebar-header">
      <div class="d-flex align-items-center">
        <a href="/admin" class="btn btn-sm me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; border-radius: 50%; background: var(--hover-bg); color: var(--icon-color); border: none;"><i class="bi bi-arrow-left"></i></a>
        <h4>Support Center</h4>
      </div>
      <div class="d-flex align-items-center">
        <button id="themeToggleBtn" class="btn btn-sm rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: var(--hover-bg); color: var(--icon-color); border: none;">
          <i class="bi bi-moon-fill" id="themeIcon"></i>
        </button>
        <div class="dropdown">
          <img src="<%= admin.img_url %>" alt="Profile" class="rounded-circle shadow-sm cursor-pointer" width="40" height="40" style="object-fit: cover; cursor: pointer;" data-bs-toggle="dropdown" role="button">
          <ul class="dropdown-menu dropdown-menu-end shadow border-0">
            <li><a class="dropdown-item" href="/admin">Dashboard</a></li>
            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="chat-ticket-list" id="adminTicketList">
      <div class="text-center text-muted p-4 small">Loading tickets...</div>
    </div>
  </div>

  <!-- Main Chat Area -->
  <div class="chat-main-area">
    <!-- Empty State -->
    <div id="adminChatEmpty" class="chat-main-empty">
      <div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px; overflow: hidden; background: #fff;">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo" style="width: 70%; object-fit: contain;">
      </div>
      <h4 style="color: var(--text-primary); font-weight: 300;">Rixi Support Center</h4>
      <p style="color: var(--text-secondary);">Select a ticket to start messaging</p>
    </div>

    <!-- Active Chat -->
    <div id="adminChatActive" class="d-none h-100 d-flex flex-column">
      <div class="chat-header">
        <div class="d-flex align-items-center gap-3">
          <button class="mobile-back-btn" onclick="closeMobileChat()"><i class="bi bi-arrow-left"></i></button>
          <div class="position-relative">
            <img id="adminChatInternImg" src="" alt="Intern" width="45" height="45" class="rounded-circle" style="object-fit: cover; border: 2px solid var(--border-color);">
            <span id="adminChatInternStatus" class="position-absolute bottom-0 end-0 border border-2 rounded-circle bg-secondary" style="width: 12px; height: 12px; border-color: var(--header-bg) !important;"></span>
          </div>
          <div>
            <h6 class="mb-0 fw-bold" id="adminChatInternName" style="color: var(--text-primary);">...</h6>
            <div style="font-size: 0.75rem; color: var(--text-secondary);">
              <span id="adminChatInternStatusText">Offline</span> • <span id="adminChatSubject">...</span>
            </div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <div id="adminChatActions"></div>
        </div>
      </div>

      <div class="chat-messages" id="adminChatMessagesBox">
        <!-- Messages appended here -->
      </div>

      <div class="chat-input-bar">
        <div id="adminEmojiPanel" class="emoji-panel"></div>
        <button type="button" class="chat-emoji-btn" id="adminToggleEmojiBtn" title="Emojis"><i class="bi bi-emoji-smile"></i></button>
        <textarea class="chat-input" id="adminChatInputMessage" placeholder="Type a message" rows="1"></textarea>
        <button type="button" class="chat-send-btn" id="adminChatSendBtn" title="Send"><i class="bi bi-send-fill"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- Custom Confirm Modal -->
<div class="modal fade" id="customConfirmModal" tabindex="-1" aria-labelledby="customConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content shadow border-0" style="border-radius: 12px; background: var(--sidebar-bg); color: var(--text-primary);">
      <div class="modal-body text-center py-4">
        <i class="bi bi-exclamation-circle text-warning mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold mb-2">Close Ticket?</h5>
        <p class="mb-4 px-2" style="color: var(--text-secondary);">Are you sure you want to close this ticket? It will be removed from your list.</p>
        <div class="d-flex justify-content-center gap-2">
          <button type="button" class="btn rounded-pill px-4" style="background: var(--hover-bg); color: var(--text-primary); border: none;" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger rounded-pill px-4" onclick="confirmCloseTicket()">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

<!-- Chat Logic Script -->
<script src="/js/supportCenter.js"></script>
</body>
</html>
