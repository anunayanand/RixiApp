<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>Employee Profile — Rixi Lab</title>
  <meta name="robots" content="noindex, nofollow, noarchive">

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Raleway:wght@400;600;700;800;900&display=swap" rel="stylesheet">

  <!-- Vendor CSS -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/js/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/js/vendor/aos/aos.css" rel="stylesheet">

  <!-- Main CSS -->
  <link href="/css/main.css" rel="stylesheet">

  <style>
    /* ─── Page Shell ─── */
    .profile-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 120px 16px 80px;
      position: relative;
      overflow: hidden;
    }

    /* Background ambient glow blobs */
    .profile-page::before {
      content: '';
      position: fixed;
      width: 520px;
      height: 520px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,102,0,0.12) 0%, transparent 70%);
      top: -120px;
      right: -100px;
      pointer-events: none;
      animation: blobFloat 8s ease-in-out infinite;
    }
    .profile-page::after {
      content: '';
      position: fixed;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,102,0,0.08) 0%, transparent 70%);
      bottom: -80px;
      left: -80px;
      pointer-events: none;
      animation: blobFloat 6s ease-in-out infinite reverse;
    }
    @keyframes blobFloat {
      0%, 100% { transform: translateY(0px); }
      50%       { transform: translateY(-30px); }
    }

    /* ─── Main Card ─── */
    .profile-card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 520px;
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 102, 0, 0.18);
      border-radius: 24px;
      padding: 52px 48px 44px;
      box-shadow: 0 8px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.04) inset;
    }
    @media (max-width: 768px) {
      .profile-card { padding: 36px 24px 32px; border-radius: 18px; }
    }
    @media (max-width: 480px) {
      .profile-card { padding: 28px 18px 24px; border-radius: 14px; }
    }

    /* ─── Verification Badge ─── */
    .verified-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255, 102, 0, 0.12);
      border: 1px solid rgba(255, 102, 0, 0.35);
      border-radius: 50px;
      padding: 5px 16px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #ff6600;
      margin-bottom: 28px;
      position: relative;
      overflow: hidden;
    }
    .verified-badge.not-found {
      background: rgba(255, 193, 7, 0.12);
      border-color: rgba(255, 193, 7, 0.35);
      color: #ffc107;
    }
    .verified-badge::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 60%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      animation: shimmer 2.5s infinite;
    }
    @keyframes shimmer {
      0%   { left: -100%; }
      100% { left: 200%; }
    }

    /* ─── Avatar ─── */
    .avatar-wrap {
      position: relative;
      width: 100px;
      height: 100px;
      margin: 0 auto 24px;
    }
    .avatar-img {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #ff6600;
      position: relative;
      z-index: 2;
      background: #000;
    }
    .pulse-ring {
      position: absolute;
      inset: -10px;
      border-radius: 50%;
      border: 2px solid rgba(255, 102, 0, 0.35);
      animation: pulseRing 2s ease-out infinite;
      z-index: 1;
    }
    @keyframes pulseRing {
      0%   { transform: scale(0.85); opacity: 0.8; }
      100% { transform: scale(1.15); opacity: 0; }
    }
    
    .avatar-icon-placeholder {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(255, 193, 7, 0.1);
        border: 2px solid #ffc107;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: #ffc107;
        margin: 0 auto 24px;
    }

    /* ─── Name and Role ─── */
    .emp-name {
      font-family: 'Raleway', sans-serif;
      font-size: clamp(24px, 5vw, 32px);
      font-weight: 900;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #ff6600 0%, #ff9a44 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.2;
      margin-bottom: 8px;
    }
    .role-chip {
      display: inline-block;
      font-family: 'Raleway', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: rgba(248, 248, 248, 0.7);
      margin-bottom: 32px;
    }
    
    .not-found-msg {
      font-size: 16px;
      color: rgba(248, 248, 248, 0.8);
      margin-bottom: 32px;
      line-height: 1.5;
    }

    /* ─── Details Grid ─── */
    .details-grid {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 14px;
      padding: 24px 28px;
      margin-bottom: 32px;
    }
    @media (max-width: 480px) {
      .details-grid { padding: 18px 16px; }
    }
    .detail-row {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .detail-row:last-child { border-bottom: none; padding-bottom: 0; }
    .detail-row:first-child { padding-top: 0; }
    .detail-icon {
      width: 32px;
      height: 32px;
      min-width: 32px;
      border-radius: 8px;
      background: rgba(255, 102, 0, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #ff6600;
      font-size: 14px;
    }
    .detail-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: rgba(248, 248, 248, 0.35);
      line-height: 1;
      margin-bottom: 4px;
    }
    .detail-value {
      font-size: 15px;
      font-weight: 600;
      color: rgba(248, 248, 248, 0.9);
      line-height: 1.3;
    }

    /* ─── Status Banner ─── */
    .status-banner {
      background: rgba(34, 197, 94, 0.1);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #22c55e;
      border-radius: 8px;
      padding: 12px;
      font-size: 13px;
      font-weight: 700;
      text-align: center;
      letter-spacing: 0.5px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    /* ─── Trust Footer ─── */
    .trust-footer {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      margin-top: 28px;
      font-size: 11px;
      color: rgba(248, 248, 248, 0.28);
      letter-spacing: 0.3px;
    }
    .trust-footer i {
      color: rgba(255, 102, 0, 0.55);
      font-size: 12px;
    }

    /* ─── Divider ─── */
    /* ─── Premium CEO Card ─── */
    .profile-card.ceo-mode {
      background: rgba(15, 15, 15, 0.6);
      border: 1px solid rgba(255, 215, 0, 0.4);
      box-shadow: 0 10px 80px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255,215,0,0.1) inset;
    }
    .ceo-verified-badge {
      display: inline-block;
      background: linear-gradient(90deg, #b8860b, #ffd700, #b8860b);
      color: #000;
      font-weight: 800;
      font-size: 11px;
      letter-spacing: 2px;
      padding: 6px 20px;
      border-radius: 4px;
      text-transform: uppercase;
      box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
      position: relative;
      z-index: 2;
    }
    .ceo-avatar-wrap {
      position: relative;
      width: 130px;
      height: 130px;
      margin: 0 auto 20px;
    }
    .ceo-avatar-img {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid #ffd700;
      position: relative;
      z-index: 2;
    }
    .ceo-glow {
      position: absolute;
      top: 50%; left: 50%;
      width: 140%; height: 140%;
      background: radial-gradient(circle, rgba(255,215,0,0.3) 0%, transparent 60%);
      transform: translate(-50%, -50%);
      z-index: 1;
      animation: ceoPulse 3s infinite alternate;
    }
    @keyframes ceoPulse {
      0% { opacity: 0.5; transform: translate(-50%, -50%) scale(0.9); }
      100% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
    }
    .ceo-name {
      font-family: 'Raleway', sans-serif;
      font-size: clamp(28px, 6vw, 36px);
      font-weight: 900;
      color: #fff;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
      margin-bottom: 5px;
      position: relative;
      z-index: 2;
    }
    .ceo-designation {
      color: #ffd700;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 30px;
      position: relative;
      z-index: 2;
    }
    .ceo-details-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      background: rgba(255,215,0,0.05);
      border: 1px solid rgba(255,215,0,0.15);
      border-radius: 12px;
      padding: 24px;
      position: relative;
      z-index: 2;
    }
    .ceo-detail-item {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .ceo-detail-label {
      font-size: 11px;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .ceo-detail-value {
      font-size: 16px;
      color: #fff;
      font-weight: 600;
      line-height: 1.3;
    }
    .ceo-watermark {
      position: absolute;
      top: 20px; right: 20px;
      font-size: 80px;
      color: rgba(255,215,0,0.04);
      z-index: 0;
      pointer-events: none;
    }
  </style>
</head>

<body class="index-page">
  <%- include('partials/loader') %>

  <!-- Header -->
  <header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container position-relative d-flex align-items-center justify-content-between">
      <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
        <h1 class="sitename">Rixi Lab</h1>
      </a>
      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#services">Services</a></li>
          <li><a href="/certificate.html">Certificate</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>
      <a class="btn-getstarted" href="/login">Login</a>
    </div>
  </header>

  <main>
    <section class="profile-page">
      <div class="profile-card <%= (employee && role === 'Super Admin') ? 'ceo-mode' : '' %>" data-aos="fade-up" data-aos-duration="700">

        <% if (employee) { %>
          <% if (role === 'Super Admin') { %>
            <!-- Premium CEO Profile -->
            <i class="bi bi-award-fill ceo-watermark"></i>
            
            <div class="text-center mb-4">
              <span class="ceo-verified-badge"><i class="bi bi-star-fill me-1"></i> RIXI LAB EXECUTIVE</span>
            </div>
            
            <div class="text-center">
              <div class="ceo-avatar-wrap">
                <div class="ceo-glow"></div>
                <img src="<%= employee.img_url || '/img/chat-admin-profile.jpg' %>" alt="CEO Profile" class="ceo-avatar-img">
              </div>
              <h2 class="ceo-name"><%= employee.name %></h2>
              <div class="ceo-designation"><%= employee.designation || 'Chief Executive Officer' %></div>
            </div>
            
            <div class="ceo-details-grid text-start">
              <div class="ceo-detail-item">
                <div class="ceo-detail-label">Executive ID</div>
                <div class="ceo-detail-value text-warning"><%= employee.emp_id %></div>
              </div>
              <div class="ceo-detail-item">
                <div class="ceo-detail-label">Status</div>
                <div class="ceo-detail-value text-success"><i class="bi bi-shield-fill-check me-1"></i> Active</div>
              </div>
              <div class="ceo-detail-item" style="grid-column: span 2; margin-top: 8px; border-top: 1px solid rgba(255,215,0,0.1); padding-top: 15px;">
                <div class="ceo-detail-label">Authority</div>
                <div class="ceo-detail-value" style="font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.8);">
                  Verified by the Rixi Lab Executive Board. Grants full administrative clearance.
                </div>
              </div>
            </div>

          <% } else { %>
            <!-- Normal Staff Profile -->
            
            <!-- Badge -->
            <div class="text-center">
              <span class="verified-badge">
                <i class="bi bi-shield-check"></i> RIXI LAB · STAFF
              </span>
            </div>

            <!-- Avatar -->
            <div class="text-center">
              <div class="avatar-wrap">
                <div class="pulse-ring"></div>
                <img src="<%= employee.img_url || 'https://i.pinimg.com/736x/e6/31/f1/e631f170b5dfc882ed2845b521653ecb.jpg' %>" alt="Profile" class="avatar-img">
              </div>
            </div>

            <!-- Name & Role -->
            <div class="text-center">
              <h2 class="emp-name"><%= employee.name %></h2>
              <div class="role-chip">
                <%= role %> <% if (employee.designation) { %>&middot; <%= employee.designation %><% } %>
              </div>
            </div>

            <!-- Details Grid -->
            <div class="details-grid">
              <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-person-badge"></i></div>
                <div>
                  <div class="detail-label">Employee ID</div>
                  <div class="detail-value" style="color: #ff6600;"><%= employee.emp_id %></div>
                </div>
              </div>

              <% if (employee.domain) { %>
              <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-diagram-3"></i></div>
                <div>
                  <div class="detail-label">Domain</div>
                  <div class="detail-value"><%= employee.domain %></div>
                </div>
              </div>
              <% } %>

              <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-calendar-check"></i></div>
                <div>
                  <div class="detail-label">Joined Date</div>
                  <div class="detail-value">
                    <%= employee.joining_date ? new Date(employee.joining_date).toDateString().slice(4) : 'N/A' %>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Status Banner -->
            <div class="status-banner">
              <i class="bi bi-check-circle-fill"></i> ACTIVE EMPLOYEE
            </div>
          <% } %>

        <% } else { %>
          <!-- Invalid / Not Found State -->
          
          <div class="text-center">
            <span class="verified-badge not-found">
              <i class="bi bi-exclamation-triangle-fill"></i> Unverified
            </span>
          </div>
          
          <div class="text-center">
            <div class="avatar-icon-placeholder">
              <i class="bi bi-person-x"></i>
            </div>
          </div>
          
          <div class="text-center">
            <h2 class="emp-name" style="background: #ffc107; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Record Not Found</h2>
            <p class="not-found-msg">
              No matching employee record could be found for this QR code.
            </p>
          </div>
          
          <div class="status-banner" style="background: rgba(255, 193, 7, 0.1); border-color: rgba(255, 193, 7, 0.3); color: #ffc107;">
            <i class="bi bi-info-circle-fill"></i> Please contact HR for assistance
          </div>
          
        <% } %>

        <div class="profile-divider"></div>

        <!-- Trust Footer -->
        <div class="trust-footer">
          <i class="bi bi-shield-fill-check"></i>
          Officially verified by Rixi Lab Security
        </div>

      </div>
    </section>
  </main>

  <%- include('partials/userFooter') %>

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
    <i class="bi bi-arrow-up-short"></i>
  </a>

  <!-- Vendor JS -->
  <script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/vendor/aos/aos.js"></script>
  <script src="/js/vendor/glightbox/js/glightbox.min.js"></script>
  <script src="/js/vendor/purecounter/purecounter_vanilla.js"></script>
  <script src="/js/vendor/typed.js/typed.umd.js"></script>
  <script src="/js/vendor/swiper/swiper-bundle.min.js"></script>
  <script src="/js/main.js"></script>

</body>
</html>
