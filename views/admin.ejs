             }
          });
       }

       // Submission Rate Chart
       const ctx2 = document.getElementById('submissionRateChart');
       if(ctx2) {
          new Chart(ctx2, {
             type: 'pie',
             data: {
                labels: ['Approved', 'Rejected', 'Pending'],
