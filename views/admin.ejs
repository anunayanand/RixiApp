    // 7. PDF Download Logic
    async function downloadRegistrationPDF(regId, regName) {
      try {
        const { jsPDF } = window.jspdf;
        const templateId = 'pdfTemplate' + regId;
        const templateElement = document.getElementById(templateId);

        if (!templateElement) {
          alert('Template not found for registration!');
          return;
        }

        // We temporarily display it block to render it, then hide it again.
        // It's vital that it renders outside of the scrollable modal container boundary to avoid cutoff.
        const originalParent = templateElement.parentElement;
        const originalDisplay = templateElement.style.display;
        
        // Move to body specifically so it can render fully without hidden overflows
        document.body.appendChild(templateElement);
        templateElement.style.display = 'block';

        // Add a small loading indicator or button disable logic here if desired

        const canvas = await html2canvas(templateElement, {
          scale: 2, 
          useCORS: true, 
          allowTaint: true,
          logging: false
        });

        // Restore original position and hidden state immediately after capturing
        originalParent.appendChild(templateElement);
        templateElement.style.display = originalDisplay;

        const imgData = canvas.toDataURL('image/png');
        
        // A4 Paper Dimensions (in mm)
        const pdf = new jsPDF('p', 'mm', 'a4');
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = (canvas.height * pdfWidth) / canvas.width;

        pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
        
        const fileName = `RixiLab_Registration_${regName.replace(/[^a-zA-Z0-9]/g, '_')}.pdf`;
        pdf.save(fileName);
        
      } catch (error) {
        console.error('Error generating PDF:', error);
        alert('An error occurred while generating the document. Please try again.');
      }
    }

    // 8. Global Modal Fix: Append all modals to body to prevent them from being trapped inside overflow containers
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.modal').forEach(modal => {
        document.body.appendChild(modal);
      });
    });
    // 9. Approve Registration
    async function approveRegistration(regId) {
      const intern_id = document.getElementById(`intern_id_${regId}`).value;
      const batch_no = document.getElementById(`batch_no_${regId}`).value;
      const btn = document.getElementById(`approveBtn_${regId}`);
      const btnText = btn.querySelector('.btn-text');
      const spinner = btn.querySelector('.spinner-border');

      if (!intern_id || !batch_no) {
        showToast("Please provide both Intern ID and Batch No", "error");
        return;
      }
      
      // Disable button and show spinner
      btn.disabled = true;
      btnText.classList.add('d-none');
      spinner.classList.remove('d-none');

      try {
        const response = await fetch(`/admin/accept-registration/${regId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ intern_id, batch_no })
        });
        const data = await response.json();
        
        if (data.success) {
          showToast("Registration approved successfully!", "success");
          setTimeout(() => window.location.reload(), 1500);
        } else {
          showToast(data.message || "Failed to approve registration", "error");
          btn.disabled = false;
          btnText.classList.remove('d-none');
          spinner.classList.add('d-none');
        }
      } catch (err) {
        console.error(err);
        showToast("Server error while approving registration", "error");
        btn.disabled = false;
        btnText.classList.remove('d-none');
        spinner.classList.add('d-none');
      }
    }

    // ==========================================
    // ADMIN DASHBOARD & CHAT LOGIC
    // ==========================================
    let activeTicketId = null;
    let lastAdminMessageId = null;
    let adminChatPollInterval = null;
    let currentInternObjectId = null;
    let isAdminChatOpen = false;

    // Check initial badge & start ticket polling
    window.addEventListener("DOMContentLoaded", () => {
       fetchAdminUnreadCount();
       setInterval(fetchAdminUnreadCount, 5000);
       fetchTicketList();
       ticketListPollInterval = setInterval(fetchTicketList, 10000); // Check for new tickets every 10s
    });

    const origShowSection = showSection;
    showSection = function(sectionId) {
       origShowSection(sectionId);
       isAdminChatOpen = (sectionId === 'supportChat');
       if (isAdminChatOpen) {
          fetchTicketList();
          if (activeTicketId) markAdminMessagesAsRead(activeTicketId);
       }
    };

    function fetchTicketList() {
       fetch('/chat/tickets')
         .then(res => res.json())
         .then(data => {
            if (!data.success) return;
            renderTicketList(data.tickets);
         }).catch(console.error);
    }

    function renderTicketList(tickets) {
       const listEl = document.getElementById('adminTicketList');
       if (!tickets || tickets.length === 0) {
          listEl.innerHTML = '<div class="text-center text-muted p-4 small">No active support tickets.</div>';
          return;
       }

       let html = '';
       tickets.forEach(ticket => {
          let internName = ticket.internId ? ticket.internId.name : 'Unknown Intern';
          let time = new Date(ticket.createdAt).toLocaleDateString() + ' ' + new Date(ticket.createdAt).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
          let statusClass = ticket.status === 'pending' ? 'ticket-status-pending' : 'ticket-status-accepted';
          let statusText = ticket.status.charAt(0).toUpperCase() + ticket.status.slice(1);
          let isActive = ticket._id === activeTicketId ? 'active' : '';

          let unreadDot = '';
          if (ticket.status === 'accepted' && ticket.internId) { /* Add unread visual check if possible, currently rely on global unread badge */ }

          html += `
             <div class="chat-ticket-item ${isActive}" onclick="openChatTicket('${ticket._id}', '${ticket.status}', '${escapeHtml(ticket.subject)}', '${escapeHtml(internName)}', '${ticket.internId ? ticket.internId.intern_id : ''}', '${ticket.internId ? ticket.internId.img_url : ''}', '${ticket.internId ? ticket.internId._id : ''}')">
                <div class="ticket-item-top">
                   <div class="ticket-name">${escapeHtml(internName)}</div>
                   <div class="ticket-time">${time}</div>
                </div>
                <div class="ticket-subject">${escapeHtml(ticket.subject)}</div>
                <div class="ticket-status ${statusClass}">${statusText}</div>
             </div>
          `;
       });
       listEl.innerHTML = html;
    }


    function openChatTicket(ticketId, status, subject, internName, internIdStr, internImg, internObjId) {
       activeTicketId = ticketId;
       lastAdminMessageId = null;
       currentInternObjectId = internObjId;
       
       document.getElementById('adminChatEmpty').classList.add('d-none');
       document.getElementById('adminChatActive').classList.remove('d-none');
       
       document.getElementById('adminChatInternName').innerText = internName;
       document.getElementById('adminChatInternId').innerText = internIdStr;
       document.getElementById('adminChatSubject').innerText = subject;
       if (internImg) document.getElementById('adminChatInternImg').src = internImg;

       document.getElementById('adminChatMessagesBox').innerHTML = ''; // clear messages
       
       const dot = document.getElementById('pingStatusDotAdmin');
       const txt = document.getElementById('pingStatusTextAdmin');
       if(dot && txt) {
           dot.className = 'spinner-grow spinner-grow-sm text-secondary me-2';
           txt.className = 'text-secondary';
           txt.innerText = 'Checking...';
       }

       // Setup Buttons
       const actionsDiv = document.getElementById('adminChatActions');
       if (status === 'pending') {
           actionsDiv.innerHTML = `<button class="btn btn-sm btn-success" onclick="acceptTicket('${ticketId}')"><i class="bi bi-check-circle me-1"></i>Accept</button>`;
           document.getElementById('adminChatInputMessage').disabled = true;
           document.getElementById('adminChatSendBtn').disabled = true;
       } else {
           actionsDiv.innerHTML = `<button class="btn btn-sm btn-outline-danger" onclick="closeTicket('${ticketId}')"><i class="bi bi-x-circle me-1"></i></button>`;
           document.getElementById('adminChatInputMessage').disabled = false;
           document.getElementById('adminChatSendBtn').disabled = false;
           
           if (adminChatPollInterval) clearInterval(adminChatPollInterval);
           pollAdminMessages();
           adminChatPollInterval = setInterval(pollAdminMessages, 3000);
           
           if (isAdminChatOpen) markAdminMessagesAsRead(ticketId);
       }
       
       // Update visual active state
       document.querySelectorAll('.chat-ticket-item').forEach(el => el.classList.remove('active'));
       event.currentTarget.classList.add('active');
       
       pingInternOnlineStatus();
    }
    
    function pingInternOnlineStatus() {
       if(!currentInternObjectId || !activeTicketId) return;
       fetch('/chat/ping-intern/' + currentInternObjectId, { cache: 'no-store' })
         .then(res => res.json())
         .then(data => {
            const dot = document.getElementById('pingStatusDotAdmin');
            const txt = document.getElementById('pingStatusTextAdmin');
            if(dot && txt) {
               dot.classList.remove('spinner-grow', 'spinner-grow-sm', 'bg-success', 'bg-secondary');
               dot.classList.add('rounded-circle');
               dot.style.width = '10px';
               dot.style.height = '10px';
               if(data.success && data.isOnline) {
                  dot.classList.add('bg-success');
                  txt.innerText = 'Online';
                  txt.classList.remove('text-secondary');
                  txt.classList.add('text-success');
               } else {
                  dot.classList.add('bg-secondary');
                  txt.innerText = 'Offline';
                  txt.classList.remove('text-success');
                  txt.classList.add('text-secondary');
               }
            }
         }).catch(console.error);
    }
    
    setInterval(() => {
        if(isAdminChatOpen) pingInternOnlineStatus();
    }, 10000);

    function acceptTicket(ticketId) {
        fetch(`/chat/ticket/${ticketId}/accept`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
             if(data.success) {
                 fetchTicketList();
                 // Immediately simulate reopening this ticket
                 const name = document.getElementById('adminChatInternName').innerText;
                 const subject = document.getElementById('adminChatSubject').innerText;
                 const iId = document.getElementById('adminChatInternId').innerText;
                 const img = document.getElementById('adminChatInternImg').src;
                 openChatTicket(ticketId, 'accepted', subject, name, iId, img, currentInternObjectId);
             }
        }).catch(console.error);
    }

    let ticketToClose = null;

    function closeTicket(ticketId) {
        ticketToClose = ticketId;
        const modal = new bootstrap.Modal(document.getElementById('closeTicketModal'));
        modal.show();
    }

    document.getElementById('confirmCloseTicketBtn')?.addEventListener('click', () => {
        if(!ticketToClose) return;
        const btn = document.getElementById('confirmCloseTicketBtn');
        const originalText = btn.innerText;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
        btn.disabled = true;

        fetch(`/chat/ticket/${ticketToClose}/close`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
             btn.innerText = originalText;
             btn.disabled = false;
             bootstrap.Modal.getInstance(document.getElementById('closeTicketModal')).hide();

             if(data.success) {
                 activeTicketId = null;
                 isAdminChatOpen = false;
                 if (adminChatPollInterval) clearInterval(adminChatPollInterval);
                 document.getElementById('adminChatEmpty').classList.remove('d-none');
                 document.getElementById('adminChatActive').classList.add('d-none');
                 fetchTicketList();
                 if (typeof showToast !== 'undefined') showToast('Ticket closed successfully', 'success');
             }
        }).catch(err => {
             console.error(err);
             btn.innerText = originalText;
             btn.disabled = false;
             if (typeof showToast !== 'undefined') showToast('Error closing ticket', 'error');
        });
    });

    function pollAdminMessages() {
       if (!activeTicketId) return;

       let url = `/chat/messages/${activeTicketId}`;
       if (lastAdminMessageId) url += `?lastMessageId=${lastAdminMessageId}`;

       fetch(url, { cache: 'no-store' })
         .then(res => res.json())
         .then(data => {
            if (!data.success) return;

            // Check if ticket status changed on the backend
            if (data.status === 'closed') {
                closeTicket(activeTicketId); // clean close
                return;
            }

            // Update intern online status
            const statusDot = document.getElementById('adminChatInternStatus');
            const statusText = document.getElementById('adminChatInternStatusText');
            const pingDot = document.getElementById('pingStatusDotAdmin');
            const pingTxt = document.getElementById('pingStatusTextAdmin');

            if (data.opponentIsOnline) {
               if(statusDot) { statusDot.classList.remove('bg-secondary'); statusDot.classList.add('bg-success'); }
               if(statusText) { statusText.innerText = 'Online'; statusText.classList.remove('text-secondary'); statusText.classList.add('text-success'); }
               if(pingDot) { pingDot.classList.remove('bg-secondary', 'spinner-grow', 'spinner-grow-sm'); pingDot.classList.add('rounded-circle', 'bg-success'); }
               if(pingTxt) { pingTxt.innerText = 'Online'; pingTxt.classList.remove('text-secondary'); pingTxt.classList.add('text-success'); }
            } else {
               if(statusDot) { statusDot.classList.remove('bg-success'); statusDot.classList.add('bg-secondary'); }
               if(statusText) { statusText.innerText = 'Offline'; statusText.classList.remove('text-success'); statusText.classList.add('text-secondary'); }
               if(pingDot) { pingDot.classList.remove('bg-success', 'spinner-grow', 'spinner-grow-sm'); pingDot.classList.add('rounded-circle', 'bg-secondary'); }
               if(pingTxt) { pingTxt.innerText = 'Offline'; pingTxt.classList.remove('text-success'); pingTxt.classList.add('text-secondary'); }
            }

            // Render new messages
            if (data.messages && data.messages.length > 0 && data.status === 'accepted') {
               const box = document.getElementById('adminChatMessagesBox');
               data.messages.forEach(msg => {
                  renderAdminMessage(msg, box);
                  lastAdminMessageId = msg._id;
               });
               box.scrollTop = box.scrollHeight;
               
               if (isAdminChatOpen) markAdminMessagesAsRead(activeTicketId);
            }
         }).catch(console.error);
    }

    function renderAdminMessage(msg, box) {
        const isAdmin = msg.senderRole === 'admin';
        const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        
        const bubbleWrap = document.createElement('div');
        // Admin's own messages are bubble-admin (which aligns to right in this context since THEY are the user), interns are bubble-intern (align left)
        bubbleWrap.className = `chat-bubble ${isAdmin ? 'chat-bubble-admin' : 'chat-bubble-intern'}`;
        
        bubbleWrap.innerHTML = `
           <div>${escapeHtml(msg.text)}</div>
           <span class="chat-time">${time}</span>
        `;
        box.appendChild(bubbleWrap);
    }

    // Send Message
    document.getElementById('adminChatSendBtn')?.addEventListener('click', sendAdminMessage);
    document.getElementById('adminChatInputMessage')?.addEventListener('keypress', (e) => {
       if (e.key === 'Enter' && !e.shiftKey) {
           e.preventDefault();
           sendAdminMessage();
       }
    });

    function sendAdminMessage() {
       const input = document.getElementById('adminChatInputMessage');
       const text = input.value.trim();
       if (!text || !activeTicketId) return;

       input.value = '';
       document.getElementById('adminEmojiPanel').classList.remove('show');

       fetch('/chat/message', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticketId: activeTicketId, text })
       })
       .then(res => res.json())
       .then(data => {
          if (data.success) {
             renderAdminMessage(data.message, document.getElementById('adminChatMessagesBox'));
             lastAdminMessageId = data.message._id;
             document.getElementById('adminChatMessagesBox').scrollTop = document.getElementById('adminChatMessagesBox').scrollHeight;
          }
       }).catch(console.error);
    }

    function markAdminMessagesAsRead(ticketId) {
        fetch(`/chat/mark-read/${ticketId}`, { method: 'POST' });
        const badge = document.getElementById('adminChatBadge');
        if (badge && badge.innerText !== '0') {
           setTimeout(fetchAdminUnreadCount, 1000); // re-fetch badge right after
        }
    }

    function fetchAdminUnreadCount() {
        if (isAdminChatOpen && activeTicketId) {
           // don't completely ignore, just rely on the read update
        }
        fetch('/chat/unread-badge')
           .then(res => res.json())
           .then(data => {
               const badge = document.getElementById('adminChatBadge');
               if (data.success && data.count > 0) {
                   badge.innerText = data.count > 99 ? '99+' : data.count;
                   badge.classList.remove('d-none');
               } else {
                   badge.classList.add('d-none');
               }
           }).catch(console.error);
    }

    // EMOJI PANEL
    const ADMIN_EMOJIS = ["👍","👎","😊","😂","🙌","👏","✅","❌","❓","👀","💡","🚀","💻","😅","😎","🔥","💼","⭐","🎉","👍🏻"];
    const aEmojiPanel = document.getElementById('adminEmojiPanel');
    const aToggleEmojiBtn = document.getElementById('adminToggleEmojiBtn');
    
    if (aEmojiPanel && aToggleEmojiBtn) {
        ADMIN_EMOJIS.forEach(emoji => {
           const btn = document.createElement('button');
           btn.type = 'button';
           btn.className = 'emoji-btn';
           btn.innerText = emoji;
           btn.onclick = () => {
              const input = document.getElementById('adminChatInputMessage');
              input.value += emoji;
              input.focus();
           };
           aEmojiPanel.appendChild(btn);
        });

        aToggleEmojiBtn.addEventListener('click', (e) => {
           e.stopPropagation();
           aEmojiPanel.classList.toggle('show');
        });

        document.addEventListener('click', (e) => {
           if (!aEmojiPanel.contains(e.target) && e.target !== aToggleEmojiBtn) {
              aEmojiPanel.classList.remove('show');
           }
        });
    }

    function escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe.toString()
             .replace(/&/g, "&amp;")
             .replace(/</g, "&lt;")
             .replace(/>/g, "&gt;")
             .replace(/"/g, "&quot;")
             .replace(/'/g, "&#039;");
    }

    async function toggleVisibility(projectId, isVisible) {
      try {
        const res = await fetch(`/project/toggle-visibility/${projectId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isHidden: !isVisible })
        });
        const data = await res.json().catch(() => ({}));
      } catch(err) {
        console.error('Toggle error:', err);
      }
    }
    async function updateProjectStatus(userId, projectId, status, btn) {
      const icon = btn.querySelector('.btn-icon');
      const spinner = btn.querySelector('.spinner-border');
      
      // Disable all action buttons in the same row
      const actionContainer = btn.closest('.project-review-actions');
      const buttons = actionContainer.querySelectorAll('button');
      buttons.forEach(b => b.disabled = true);
      
      if (icon) icon.classList.add('d-none');
      if (spinner) spinner.classList.remove('d-none');

      try {
        const response = await fetch('/admin/projects/update-status', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ userId, projectId, status })
        });
        
        const data = await response.json();
        
        if (data.success) {
          if (typeof showToast !== 'undefined') showToast(data.message || "Project " + status + " successfully!", "success");
          
          // Update the status badge
          const row = btn.closest('tr');
          const badge = row.querySelector('.badge');
          if (badge) {
             badge.className = 'badge badge-sub-' + status;
             badge.textContent = status;
          }
          
          // Re-enable and reset buttons
          buttons.forEach(b => b.disabled = false);
          if (icon) icon.classList.remove('d-none');
          if (spinner) spinner.classList.add('d-none');
          
          // Hide the clicked button and show the other one
          buttons.forEach(b => {
             const titleLabel = b.getAttribute('title').toLowerCase();
             if (titleLabel === 'approve') {
                if (status === 'accepted') {
                   b.classList.remove('d-flex');
                   b.classList.add('d-none');
                } else {
                   b.classList.remove('d-none');
                   b.classList.add('d-flex');
                }
             } else if (titleLabel === 'reject') {
                if (status === 'rejected') {
                   b.classList.remove('d-flex');
                   b.classList.add('d-none');
                } else {
                   b.classList.remove('d-none');
                   b.classList.add('d-flex');
                }
             }
          });
          
        } else {
          if (typeof showToast !== 'undefined') showToast(data.message || "Failed to update project", "error");
          buttons.forEach(b => b.disabled = false);
          if (icon) icon.classList.remove('d-none');
          if (spinner) spinner.classList.add('d-none');
        }
      } catch (err) {
        console.error(err);
        if (typeof showToast !== 'undefined') showToast("Server error while updating project", "error");
        buttons.forEach(b => b.disabled = false);
        if (icon) icon.classList.remove('d-none');
        if (spinner) spinner.classList.add('d-none');
      }
    }
  </script>
</body>
</html>
