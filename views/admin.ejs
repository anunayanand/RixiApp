          <div class="mb-3">
             <i class="bi bi-x-circle text-danger" style="font-size: 3rem;"></i>
          </div>
          <h5 class="fw-bold text-white mb-2">Close Ticket?</h5>
          <p class="text-secondary small mb-4">Are you sure you want to close this ticket? It will be removed from the active list.</p>
          <div class="d-flex gap-2 justify-content-center">
             <button type="button" class="btn btn-outline-secondary w-50" data-bs-dismiss="modal" style="border-color: var(--border); color: var(--text-secondary);">Cancel</button>
             <button type="button" class="btn btn-danger w-50 fw-bold" id="confirmCloseTicketBtn">Close</button>
          </div>
        </div>
      </div>
    </div>
  </div>

