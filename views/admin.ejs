                          <div style="display: flex; gap: 40px; flex-wrap: wrap;">
                            <div>
                              <p style="margin: 0; font-size: 13px; color: #6b7280; text-transform: uppercase; font-weight: 700;">Email</p>
                              <p style="margin: 4px 0 0 0; font-size: 16px; font-weight: 500;"><%= reg.email %></p>
                            </div>
                            <div>
                              <p style="margin: 0; font-size: 13px; color: #6b7280; text-transform: uppercase; font-weight: 700;">Phone</p>
                              <p style="margin: 4px 0 0 0; font-size: 16px; font-weight: 500;"><%= reg.phone %></p>
                            </div>
                            <div>
                              <p style="margin: 0; font-size: 13px; color: #6b7280; text-transform: uppercase; font-weight: 700;">Date Applied</p>
                              <p style="margin: 4px 0 0 0; font-size: 16px; font-weight: 500;"><%= new Date(reg.createdAt).toLocaleDateString('en-GB') %></p>
                            </div>
                          </div>
                        </div>
                        <div style="flex-shrink: 0; text-align: right; display: flex; flex-direction: column; justify-content: center;">
                          <div style="background: <%= reg.status === 'approved' ? '#dcfce7' : (reg.status === 'rejected' ? '#fee2e2' : '#fef9c3') %>; color: <%= reg.status === 'approved' ? '#166534' : (reg.status === 'rejected' ? '#991b1b' : '#854d0e') %>; padding: 10px 20px; border-radius: 30px; font-weight: 700; font-size: 14px; display: inline-block; text-transform: uppercase; border: 1px solid <%= reg.status === 'approved' ? '#bbf7d0' : (reg.status === 'rejected' ? '#fecaca' : '#fef08a') %>;">
                            Status: <%= reg.status || 'Pending' %>
                          </div>
                        </div>
                      </div>

                      <!-- Details Sections Grid -->
                      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        
                        <!-- Academic Information -->
                        <div style="background: #f8fafc; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0;">
                          <h3 style="margin: 0 0 20px 0; font-size: 18px; color: #ff6600; text-transform: uppercase; font-weight: 800; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px;">Academic Details</h3>
                          
                          <div style="margin-bottom: 15px;">
                            <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">University</p>
                            <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.university %></p>
                          </div>
                          
                          <div style="margin-bottom: 15px;">
                            <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">College</p>
                            <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.college %></p>
                          </div>
                          
                          <div style="display: flex; gap: 20px;">
                            <div style="flex: 1;">
                              <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Course</p>
                              <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.course %></p>
                            </div>
                            <div style="flex: 1;">
                              <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Branch</p>
                              <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.branch %></p>
                            </div>
                          </div>
                          
                          <div style="margin-top: 15px;">
                            <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Current Year / Semester</p>
                            <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.year_sem %></p>
                          </div>
                        </div>

                        <!-- Internship Details -->
                        <div style="background: #f8fafc; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0;">
                          <h3 style="margin: 0 0 20px 0; font-size: 18px; color: #ff6600; text-transform: uppercase; font-weight: 800; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px;">Internship Particulars</h3>
                          
                          <div style="margin-bottom: 15px;">
                            <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Selected Domain</p>
                            <p style="margin: 4px 0 0 0; font-size: 16px; font-weight: 700; color: #0f172a;"><%= reg.domain %></p>
                          </div>
                          
                          <div style="display: flex; gap: 20px; margin-bottom: 15px;">
                            <div style="flex: 1;">
                              <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Duration</p>
                              <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.duration %> Weeks</p>
                            </div>
                            <div style="flex: 1;">
                              <p style="margin: 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Referral Code</p>
                              <p style="margin: 4px 0 0 0; font-size: 15px; font-weight: 500; color: #334155;"><%= reg.referral_code || 'None' %></p>
                            </div>
                          </div>
                          
                          <div style="margin-top: 25px;">
                            <p style="margin: 0 0 8px 0; font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase;">Payment Status Information</p>
                            <div style="background: white; border: 1px solid #e2e8f0; padding: 12px 15px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
                              <div>
                                <span style="font-size: 13px; color: #64748b;">Order ID:</span>
                                <strong style="margin-left: 5px; font-size: 13px; font-family: monospace;"><%= reg.order_id || 'N/A' %></strong>
                              </div>
                              <div style="font-weight: 700; font-size: 13px; color: <%= reg.payment_status === 'SUCCESS' ? '#166534' : '#991b1b' %>;">
                                <%= reg.payment_status || 'PENDING' %>
                              </div>
                            </div>
                            <div style="margin-top: 8px; font-size: 12px; color: #64748b;">
                              Transaction Ref: <span style="font-family: monospace; color: #334155;"><%= reg.payID || 'N/A' %></span>
                            </div>
                          </div>
                        </div>

                      </div>

                      <!-- Footer -->
                      <div style="margin-top: 50px; padding-top: 20px; border-top: 1px solid #e2e8f0; text-align: center; color: #94a3b8; font-size: 12px;">
                        <p style="margin: 0 0 5px 0;">This document is electronically generated and requires no physical signature.</p>
                        <p style="margin: 0;">© <%= new Date().getFullYear() %> Rixi Lab. All rights reserved.</p>
                      </div>

                    </div>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">No approved registrations found.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

    </div> <!-- End Content Body -->

    <!-- SETTINGS SECTION -->
    <section id="settings" class="content-section" style="display:none;">
      <div class="page-header mb-3">
        <h4>Account Settings</h4>
        <p>Manage your admin profile details and system preferences.</p>
      </div>

      <div class="row">
        <div class="col-12 col-lg-8">
          <div class="stat-card" style="box-shadow: var(--shadow-sm) !important; border: 1px solid var(--border) !important; background: var(--surface);">
            <div class="d-flex align-items-center mb-4 pb-4 border-bottom border-light">
              <div class="position-relative me-4">
                <img src="<%= admin.img_url %>" alt="Profile" class="rounded-circle border border-3 border-white shadow" width="90" height="90" style="object-fit:cover;">
                <button class="btn btn-sm btn-primary rounded-circle position-absolute shadow-sm" data-bs-toggle="modal" data-bs-target="#updateProfileModal" style="bottom: 0px; right: 0px; width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center; border: 2px solid #fff;">
                  <i class="bi bi-camera-fill" style="font-size: 0.85rem;"></i>
                </button>
              </div>
              <div>
                <h4 class="mb-1 text-dark fw-bold"><%= admin.name %></h4>
                <div class="text-muted small mb-0 d-flex align-items-center"><i class="bi bi-envelope me-2 text-primary"></i><%= admin.email %></div>
              </div>
            </div>

            <form action="/update-admin-profile" method="POST">
              <h6 class="text-muted fw-bold mb-4 small text-uppercase" style="letter-spacing: 0.8px;">Personal Information</h6>
              
              <div class="row g-4">
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small text-muted fw-semibold mb-1">Full Name</label>
                    <input type="text" class="form-control form-control-lg bg-light border-0 px-3 shadow-none custom-input" id="settingsName" name="name" value="<%= admin.name %>" placeholder="Enter Full Name" required style="border-radius: 10px; font-size: 0.95rem;">
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small text-muted fw-semibold mb-1">Phone Number</label>
                    <input type="tel" class="form-control form-control-lg bg-light border-0 px-3 shadow-none custom-input" id="settingsPhone" name="phone" value="<%= admin.phone || '' %>" placeholder="Enter Phone Number" style="border-radius: 10px; font-size: 0.95rem;">
                  </div>
                </div>
                <div class="col-md-12">
                  <div class="form-group">
                    <label class="form-label small text-muted fw-semibold mb-1">Email Address <span class="fw-normal opacity-75">(Cannot edit)</span></label>
                    <input type="email" class="form-control form-control-lg border-0 px-3 shadow-none text-muted" id="settingsEmail" value="<%= admin.email %>" disabled readonly style="background-color: #e9ecef; border-radius: 10px; font-size: 0.95rem; cursor: not-allowed;">
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small text-muted fw-semibold mb-1">Designation <span class="fw-normal opacity-75">(Cannot edit)</span></label>
                    <input type="text" class="form-control form-control-lg border-0 px-3 shadow-none text-muted" id="settingsDesignation" value="<%= admin.designation %>" disabled readonly style="background-color: #e9ecef; border-radius: 10px; font-size: 0.95rem; cursor: not-allowed;">
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-label small text-muted fw-semibold mb-1">Domain / Stack <span class="fw-normal opacity-75">(Cannot edit)</span></label>
                    <input type="text" class="form-control form-control-lg border-0 px-3 shadow-none text-muted" id="settingsDomain" value="<%= admin.domain %>" disabled readonly style="background-color: #e9ecef; border-radius: 10px; font-size: 0.95rem; cursor: not-allowed;">
                  </div>
                </div>
              </div>

              <div class="d-flex flex-column flex-sm-row justify-content-end mt-5 pt-4 border-top border-light gap-3 align-items-center">
                <button type="button" class="btn btn-light rounded-pill px-4 py-2 text-dark border fw-medium" data-bs-toggle="modal" data-bs-target="#passwordModal" style="font-size: 0.9rem;">
                  Change Password
                </button>
                <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-semibold shadow-sm" style="font-size: 0.9rem;">
                  <i class="bi bi-arrow-down-square me-2"></i>Save Changes
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

  </div> <!-- End Main Content -->

  <!-- GLOBAL MODALS -->

  <!-- Logout Modal -->
  <div class="modal fade" id="logoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-body text-center p-4">
          <i class="bi bi-box-arrow-right text-danger fs-1 mb-3"></i>
          <h5>Logging Out?</h5>
          <p class="text-muted small mb-4">You will be returned to the login screen.</p>
          <div class="d-flex gap-2 justify-content-center">
