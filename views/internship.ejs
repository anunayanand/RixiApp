                  <%
                    const dateObj = new Date();
                    const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "June", "July", "Aug", "Sept", "Oct", "Nov", "Dec"];
                    const lastDay = new Date(dateObj.getFullYear(), dateObj.getMonth() + 1, 0);
                    const lastDayStr = `${lastDay.getDate()} ${monthNames[lastDay.getMonth()]} ${lastDay.getFullYear()}`;
                    const firstDayNext = new Date(dateObj.getFullYear(), dateObj.getMonth() + 1, 1);
                    const nextDayStr = `1 ${monthNames[firstDayNext.getMonth()]} ${firstDayNext.getFullYear()}`;
                  %>
