      <!-- Multi-step Form Script -->
      <script>
        function validateStep(stepIndex) {
          const stepContainer = document.getElementById(`step-${stepIndex}`);
          const inputs = stepContainer.querySelectorAll('input[required], select[required]');
          
          for (let input of inputs) {
            if (!input.checkValidity()) {
              input.reportValidity();
              return false;
            }
          }
          
          if (stepIndex === 1 && !uploadedImageUrl) {
            const fileInput = document.getElementById("profileImage");
            if (fileInput && fileInput.files.length > 0) {
                showToast("Please wait for the image to finish uploading", "warning");
                return false;
            } else {
                showToast("Please select a profile picture to upload", "error");
                return false;
            }
          }
          
          return true;
        }

        function nextStep(currentStep) {
          if (!validateStep(currentStep)) return;
          
          document.getElementById(`step-${currentStep}`).classList.remove('active');
          document.getElementById(`indicator-${currentStep}`).classList.remove('active');
          document.getElementById(`indicator-${currentStep}`).classList.add('completed');
          
          const nextStep = currentStep + 1;
          document.getElementById(`step-${nextStep}`).classList.add('active');
          document.getElementById(`indicator-${nextStep}`).classList.add('active');
          window.scrollTo({top: document.querySelector('.contact-form-wrapper').offsetTop - 100, behavior: 'smooth'});
        }

        function prevStep(currentStep) {
          document.getElementById(`step-${currentStep}`).classList.remove('active');
          document.getElementById(`indicator-${currentStep}`).classList.remove('active');
          
          const prevStep = currentStep - 1;
          document.getElementById(`step-${prevStep}`).classList.add('active');
          document.getElementById(`indicator-${prevStep}`).classList.add('active');
          document.getElementById(`indicator-${prevStep}`).classList.remove('completed');
          window.scrollTo({top: document.querySelector('.contact-form-wrapper').offsetTop - 100, behavior: 'smooth'});
        }
      </script>

      <!-- Image Preview Script -->
      <script>
        let uploadedImageUrl = null;
        let uploadedImagePublicId = null;

        function handleImageUpload(event) {
          const file = event.target.files[0];
          if (!file) return;

          // Validate file type
          if (!file.type.startsWith("image/")) {
            showToast("Please select an image file", "error");
            event.target.value = "";
            return;
          }

          // Validate file size (max 1MB)
          if (file.size > 1 * 1024 * 1024) {
            showToast("Image size should be less than 1MB", "error");
            event.target.value = "";
            return;
          }

          // Create image to check dimensions
          const img = new Image();
          const reader = new FileReader();

          reader.onload = function (e) {
            img.src = e.target.result;
          };

          img.onload = function () {
            // Cloudinary will crop the image to a square automatically
            uploadImage(file);
          };

          img.onerror = function () {
            showToast("Invalid image file", "error");
            event.target.value = "";
          };

          reader.readAsDataURL(file);
        }

        async function uploadImage(file) {
          try {
            const formData = new FormData();
            formData.append("profileImage", file);

            document.getElementById("imagePreviewContainer").style.setProperty("display", "flex", "important");
            document.getElementById("imgUploadSpinner").style.display = "block";
            document.getElementById("imagePreviewThumb").style.display = "none";

            const response = await fetch("/internship/upload-profile-image", {
              method: "POST",
              body: formData,
            });

            const data = await response.json();
            document.getElementById("imgUploadSpinner").style.display = "none";

            if (data.success) {
              uploadedImageUrl = data.imageUrl;
              uploadedImagePublicId = data.publicId;

              // Show preview thumbnail
              document.getElementById("imagePreviewThumb").src = uploadedImageUrl;
              document.getElementById("imagePreviewThumb").style.display = "block";

              showToast("Profile picture uploaded successfully", "success");
            } else {
              showToast(data.message || "Failed to upload image", "error");
              event.target.value = "";
              document.getElementById("imagePreviewContainer").style.setProperty("display", "none", "important");
            }
          } catch (error) {
            document.getElementById("imgUploadSpinner").style.display = "none";
            document.getElementById("imagePreviewContainer").style.setProperty("display", "none", "important");
            console.error("Error uploading image:", error);
            showToast("Error uploading image", "error");
            event.target.value = "";
          }
        }

        function openImagePreviewModal() {
          if (uploadedImageUrl) {
            document.getElementById("imagePreviewFull").src = uploadedImageUrl;
            const modal = new bootstrap.Modal(
              document.getElementById("imagePreviewModal"),
            );
            modal.show();
          }
        }

        function deleteImage() {
          // Clear the image
          uploadedImageUrl = null;
          uploadedImagePublicId = null;

          // Clear file input
          document.getElementById("profileImage").value = "";

          // Hide preview
          document.getElementById("imagePreviewContainer").style.setProperty("display", "none", "important");
          document.getElementById("imagePreviewThumb").style.display = "none";

          // Close modal
          const modalEl = document.getElementById("imagePreviewModal");
          const modal = bootstrap.Modal.getInstance(modalEl);
          if (modal) {
            modal.hide();
          }

          showToast("Profile picture removed", "success");
        }
      </script>

      <script>
        // Cashfree will be initialized dynamically before checkout

        // Domain-wise prices (must match backend DOMAIN_PRICES)
        const domainPrices = {
          "Web Development": 100,
          "Data Analytics": 150,
          "DSA": 124,
          "Graphics Design": 100,
          "Python Programming": 149,
          "Java Programming": 174,
          "Full Stack Development": 124,
          "Machine Learning": 200,
          "Artificial Intelligence": 200
        };

        let currentDomainPrice = 100;
        let currentReferralDiscountPercent = 0;

        function updateBillingTable() {
          let baseAmount = currentDomainPrice;

          let referralDiscountAmount = 0;
          if (currentReferralDiscountPercent > 0) {
            referralDiscountAmount = (baseAmount * currentReferralDiscountPercent) / 100;
            document.getElementById("referralPercentDisplay").textContent = currentReferralDiscountPercent;
            if (document.getElementById("referralDiscountAmount")) {
              document.getElementById("referralDiscountAmount").textContent = referralDiscountAmount.toFixed(2);
            }
            document.getElementById("referralDiscountRow").style.display = "table-row";
          } else {
            document.getElementById("referralDiscountRow").style.display = "none";
          }

          let discountedBase = baseAmount - referralDiscountAmount;
          let serviceCharge = discountedBase * 0.0195;
          let gst = discountedBase * 0.0045; // Exact 0.45%
          let totalFee = discountedBase + serviceCharge + gst;

          let baseRegFee = 499;
          let baseDiscount = baseRegFee - baseAmount;
          let discountPercentValue = Math.round((baseDiscount / baseRegFee) * 100);

          document.getElementById("baseRegFee").textContent = baseRegFee.toFixed(2);
          document.getElementById("baseDiscount").textContent = baseDiscount.toFixed(2);
          if (document.getElementById("baseDiscountPercent")) {
            document.getElementById("baseDiscountPercent").textContent = discountPercentValue;
          }
          document.getElementById("baseAmount").textContent = baseAmount.toFixed(2);

          if (document.getElementById("serviceChargeAmount")) {
            document.getElementById("serviceChargeAmount").textContent = serviceCharge.toFixed(2);
          }
          document.getElementById("serviceTaxDisplay").textContent = gst.toFixed(2);

          if (totalFee < 1) totalFee = 1; // Cashfree minimum
          document.getElementById("totalFeeDisplay").textContent = totalFee.toFixed(2);
        }

        // Update price when domain changes
        document.getElementById("contactDomain").addEventListener("change", function () {
          const selectedDomain = this.value;
          currentDomainPrice = domainPrices[selectedDomain] || 100;
          document.getElementById("billingPlaceholder").style.display = "none";
          document.getElementById("billingTable").style.display = "table";
          updateBillingTable();
        });

        // Handle referral verification automatically via AJAX
        let referralDebounceTimer;
        async function verifyReferralCode(code) {
          const msgEl = document.getElementById("referralMessage");
          if (!code) {
            currentReferralDiscountPercent = 0;
            msgEl.textContent = "";
            updateBillingTable();
            return;
          }

          msgEl.textContent = "Verifying...";
          msgEl.style.color = "white";

          try {
            const response = await fetch("/internship/validate-referral", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ referralCode: code })
            });
            const data = await response.json();
            if (data.valid) {
              currentReferralDiscountPercent = data.discountPercent || 0;
              if (data.internName) {
                msgEl.textContent = `Valid! Referred by ${data.internName}.`;
              } else {
                msgEl.textContent = `Valid! ${currentReferralDiscountPercent}% discount applied.`;
              }
              msgEl.style.color = "#4ade80"; // green
              updateBillingTable();
            } else {
              currentReferralDiscountPercent = 0;
              msgEl.textContent = data.message || "Invalid referral code.";
              msgEl.style.color = "#ef4444"; // red
              updateBillingTable();
            }
          } catch (e) {
            currentReferralDiscountPercent = 0;
            msgEl.textContent = "Error verifying code.";
            msgEl.style.color = "#ef4444";
            updateBillingTable();
          }
        }

        document.getElementById("contactReferral").addEventListener("input", function () {
          clearTimeout(referralDebounceTimer);
          const code = this.value.trim();
          referralDebounceTimer = setTimeout(() => {
            verifyReferralCode(code);
          }, 600); // 600ms debounce
        });





        function showLoader() {
          const loaderWrapper = document.getElementById("rixiLoaderOverlay");
          if (loaderWrapper) {
            loaderWrapper.style.display = "flex";
            void loaderWrapper.offsetWidth; // force reflow
            loaderWrapper.classList.remove("hidden");
          }
        }

        function hideLoader() {
          const loaderWrapper = document.getElementById("rixiLoaderOverlay");
          if (loaderWrapper) {
            loaderWrapper.classList.add("hidden");
            setTimeout(() => (loaderWrapper.style.display = "none"), 600);
          }
        }

        var form = document.getElementById("internship-form");
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          document.getElementById("payID").click();
        });

        // Payment initiation
        document
          .getElementById("payID")
          .addEventListener("click", async function (e) {
            e.preventDefault();
            const payBtn = this;
            payBtn.disabled = true;
            payBtn.textContent = "Submitting...";

            // Collect form data
            const form = document.getElementById("internship-form");
            const formData = new FormData(form);
            const data = {};
            for (let [key, value] of formData.entries()) {
              data[key] = value;
            }

            if (!uploadedImageUrl) {
              showToast("Please upload your profile picture", "error");
              payBtn.disabled = false;
              payBtn.textContent = "Continue to Payment & Submit";
              return;
            }

            // Add profile image data
            data["data[ProfileImageUrl]"] = uploadedImageUrl;
            data["data[ProfileImagePublicId]"] = uploadedImagePublicId || "";

            // Validate required fields except PayID
            const requiredFields = [
              "data[Name]",
              "data[Email]",
              "data[Phone]",
              "data[University]",
              "data[College]",
              "data[Course]",
              "data[Branch]",
              "data[Y/S]",
              "data[Domain]",
              "data[Duration]",
              "data[Terms]",
            ];
            for (let field of requiredFields) {
              if (
                !data[field] ||
                (field === "data[Terms]" && data[field] !== "on")
              ) {
                showToast("Please fill all required fields", "error");
                payBtn.disabled = false;
                payBtn.textContent = "Continue to Payment & Submit";
                return;
              }
            }

            // Store form data in localStorage
            localStorage.setItem("internshipFormData", JSON.stringify(data));
            localStorage.setItem(
              "userName",
              data["data[Name]"]?.trim() || "User",
            );

            // Create Cashfree order
            const email = document.getElementById("contactEmail").value;
            const phone = document.getElementById("contactPhone").value;
            try {
              showLoader();
              const response = await fetch("/internship/create-order", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ data: data }),
              });
              const result = await response.json();
              hideLoader();
              if (result.success) {
                // Check if Cashfree is loaded
                if (!window.Cashfree) {
                  showToast(
                    "Payment system not loaded. Please refresh and try again.",
                    "error",
                  );
                  payBtn.disabled = false;
                  payBtn.textContent = "Continue to Payment & Submit";
                  return;
                }
                
                // Initialize Cashfree with the correct environment from backend
                const cashfree = Cashfree({ mode: result.environment || "production" });
                
                try {
                  // Initiate Cashfree checkout
                  cashfree.checkout({
                    paymentSessionId: result.payment_session_id,
                    redirectTarget: "_self",
                  });
                } catch (error) {
                  console.error("Cashfree checkout error:", error);
                  showToast(
                    "Failed to start payment. Please try again.",
                    "error",
                  );
                  payBtn.disabled = false;
                  payBtn.textContent = "Continue to Payment & Submit";
                }
              } else {
                showToast(
                  result.message || "Failed to create payment order",
                  "error",
                );
                payBtn.disabled = false;
                payBtn.textContent = "Continue to Payment & Submit";
              }
            } catch (error) {
              hideLoader();
              showToast("An error occurred. Please try again.", "error");
              payBtn.disabled = false;
              payBtn.textContent = "Continue to Payment & Submit";
            }
          });
      </script>

      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const params = new URLSearchParams(window.location.search);
          const referralCode = params.get("referral_code");
          if (referralCode) {
            const referralInput = document.getElementById("contactReferral");
            if (referralInput) {
              referralInput.value = referralCode;
              referralInput.readOnly = true;
              if (typeof verifyReferralCode === "function") {
                verifyReferralCode(referralCode);
              }
            }
          }
        });

        function showPopup(message, invoiceUrl = null) {
          const popup = document.getElementById("popup");
          const msgEl = document.getElementById("popupMsg");
          if (!popup || !msgEl) return;
          
          msgEl.innerHTML = message;
          
          const invoiceBtnContainer = document.getElementById("invoiceBtnContainer");
          const invoiceLink = document.getElementById("invoiceLink");
          if (invoiceUrl && invoiceUrl !== "undefined" && invoiceUrl !== "null" && invoiceUrl !== "") {
            if (invoiceLink) invoiceLink.href = invoiceUrl;
            if (invoiceBtnContainer) invoiceBtnContainer.style.display = "block";
          } else {
            if (invoiceBtnContainer) invoiceBtnContainer.style.display = "none";
          }
          
          // Show the popup
          popup.style.cssText = "display: flex !important; opacity: 1 !important; visibility: visible !important; z-index: 999999 !important;";
        }
        function closePopup() {
          const popup = document.getElementById("popup");
          if (popup) popup.style.cssText = "display: none !important;";
        }

        // Check for payment success
        document.addEventListener("DOMContentLoaded", () => {
          const params = new URLSearchParams(window.location.search);
          const paymentSuccess = params.get("payment_success");
          const orderId = params.get("order_id");
          const transactionId = params.get("transaction_id");
          const invoiceUrl = params.get("invoice_url");
          const queryName = params.get("name");

          // Clean URL first to avoid issues on refresh
          if (paymentSuccess) {
            window.history.replaceState({}, document.title, window.location.pathname);
          }

          if (paymentSuccess === "true") {
            // Get user name
            let userName = queryName ? decodeURIComponent(queryName) : "User";
            const formData = localStorage.getItem("internshipFormData");
            if (!queryName && formData) {
              try {
                const data = JSON.parse(formData);
                userName = data["data[Name]"]?.trim() || "User";
              } catch (e) {
                console.error("Failed to parse formData", e);
              }
            }
            // Clear localStorage
            localStorage.removeItem("internshipFormData");

            const message = `Thank you ${userName}! Your internship application and payment have been successfully processed. You will receive a confirmation email shortly with further instructions.`;
            const customReceiptUrl = orderId ? `/internship/receipt/${orderId}` : (invoiceUrl || null);

            // Show toast and popup after a short delay to ensure page is fully rendered
            setTimeout(() => {
              showToast("Payment Successful! 🎉", "success");
              showPopup(message, customReceiptUrl);
            }, 300);

            // Reset form state
            const form = document.getElementById("internship-form");
            const payBtn = document.getElementById("payID");
            if (form) form.reset();
            if (payBtn) {
              payBtn.disabled = true;
              payBtn.textContent = "Submitted";
            }
          } else if (paymentSuccess === "false") {
            setTimeout(() => {
              showToast("Payment failed or was cancelled. Please try again.", "error");
            }, 300);
          }
        });
      </script>
