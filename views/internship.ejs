                    <li class="mb-2">Last date to apply: <strong><%= lastDayStr %></strong></li>
                    <li class="mb-2">Offer Letter provide: <strong><%= lastDayStr %></strong></li>
                    <li class="mb-2">Internship Start Date: <strong><%= nextDayStr %></strong></li>
