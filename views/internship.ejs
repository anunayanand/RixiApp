</style>
                <style>
.contact.section {
    position: relative;
    overflow: hidden;
    background: #111111;
    z-index: 1;
}
.contact.section::before {
    content: "";
    position: absolute;
    top: -10%;
    left: -10%;
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, rgba(255, 102, 0, 0.15) 0%, transparent 60%);
    border-radius: 50%;
    z-index: -1;
    animation: floatOrb 12s infinite alternate;
}
.contact.section::after {
    content: "";
    position: absolute;
    bottom: -10%;
    right: -5%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, rgba(255, 102, 0, 0.1) 0%, transparent 60%);
    border-radius: 50%;
    z-index: -1;
    animation: floatOrb 15s infinite alternate-reverse;
}
@keyframes floatOrb {
    0% { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
}

/* Typography Enhancements */
.contact-form-wrapper h3, 
.contact-form-wrapper h5, 
.contact-form-wrapper label,
.contact-form-wrapper li,
.contact-form-wrapper p {
    color: #f0f0f0;
}
.contact-form-wrapper h3 { font-weight: 700; margin-bottom: 20px; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
.contact-form-wrapper h5 { font-weight: 600; }

/* Glassmorphism for main container */
.contact-form-wrapper {
    background: rgba(30, 30, 30, 0.45) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 30px;
    padding: 40px 35px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
}

/* Glassmorphic cards for details */
.contact-form-wrapper ul,
.form-header p {
    background: rgba(0, 0, 0, 0.2);
    padding: 18px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    box-shadow: inset 2px 2px 8px rgba(0,0,0,0.3);
}

/* Modern Inputs */
.form-control, .form-select, select.form-control {
    background: rgba(15, 15, 15, 0.6) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 12px !important;
    color: #fff !important;
    padding: 14px 18px !important;
    box-shadow: none !important;
    transition: all 0.3s ease;
}
.form-control:focus, .form-select:focus, select.form-control:focus {
    border-color: #ff6600 !important;
    box-shadow: 0 0 0 3px rgba(255, 102, 0, 0.25) !important;
    background: rgba(10, 10, 10, 0.8) !important;
    outline: none !important;
}

/* Steps Indicator */
.form-step { display: none; animation: fadeIn 0.5s; }
.form-step.active { display: block; }
.step-indicator { display: flex; justify-content: space-between; margin-bottom: 40px; position: relative; }
.step-indicator::before { 
    content: ''; position: absolute; top: 22px; left: 10%; width: 80%; height: 6px; 
    background: rgba(255,255,255,0.1); z-index: 1; border-radius: 10px;
}
.step { 
    width: 50px; height: 50px; border-radius: 50%; 
    display: flex; align-items: center; justify-content: center; 
    font-weight: 700; color: #777; z-index: 2; position: relative; transition: all 0.4s ease;
    background: #1f1f1f;
    border: 2px solid rgba(255,255,255,0.1);
    font-size: 1.1rem;
}
.step.active { 
    background: #ff6600; color: white; text-shadow: none;
    border-color: #ff6600;
    box-shadow: 0 0 15px rgba(255,102,0,0.4);
    transform: scale(1.1);
}
.step.completed { 
    background: #28a745; color: white; text-shadow: none;
    border-color: #28a745;
}
.step-title { text-align: center; font-size: 0.9rem; margin-top: 12px; color: #bbb; font-weight: 500; transition: color 0.3s; }
.step.active + .step-title { color: #fff; font-weight: 600; }

/* Modern Buttons */
.btn-next, .btn-prev, .submit-btn { 
    border: none; padding: 12px 30px; border-radius: 8px; cursor: pointer; 
    transition: all 0.3s ease; font-weight: 600; display: flex; align-items: center; gap: 8px; 
    font-size: 1rem; letter-spacing: 0.5px; text-shadow: none;
}
.btn-next, .submit-btn { 
    background: #ff6600; color: #fff;
    box-shadow: 0 4px 10px rgba(255, 102, 0, 0.3);
}
.btn-next:hover, .submit-btn:hover {
    background: #e65c00;
    box-shadow: 0 6px 15px rgba(255, 102, 0, 0.4);
    transform: translateY(-2px);
}
.btn-next:active, .submit-btn:active {
    transform: translateY(1px);
    box-shadow: 0 2px 5px rgba(255, 102, 0, 0.3);
}
.btn-prev { 
    background: #2a2a2a; color: #eee; 
    border: 1px solid rgba(255,255,255,0.1);
}
.btn-prev:hover {
    background: #333;
    transform: translateY(-2px);
}
.btn-prev:active {
    transform: translateY(1px);
}

.form-navigation { display: flex; justify-content: space-between; margin-top: 35px; align-items: center; gap: 15px; flex-wrap: nowrap; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

/* Upload Spinner */
.img-upload-spinner { display: none; width: 1.8rem; height: 1.8rem; border: 3px solid rgba(255,102,0, 0.2); border-radius: 50%; border-top-color: #ff6600; animation: spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* Billing Table */
.alert-secondary {
    background: rgba(0, 0, 0, 0.2) !important;
    border: 1px dashed rgba(255, 102, 0, 0.5) !important;
    border-radius: 16px !important;
    box-shadow: inset 3px 3px 8px rgba(0,0,0,0.4);
    color: #eee !important;
}
.billing-table {
    background: rgba(0, 0, 0, 0.25) !important;
    border: 1px solid rgba(255, 255, 255, 0.04) !important;
    border-radius: 16px !important;
    box-shadow: inset 3px 3px 8px rgba(0,0,0,0.4);
    padding: 20px;
    display: block; /* Table wrapper */
}
.billing-table tbody { display: table; width: 100%; }
.billing-table td { padding: 12px 10px; border-bottom: 1px solid rgba(255,255,255,0.03); color: #ddd; }
.billing-table tr:last-child td { border-bottom: none; }
.billing-table tr:last-child td { color: #fff; }

/* File input modern style */
input[type="file"] {
    padding: 14px 18px !important;
    line-height: 1.5;
}
input[type="file"]::file-selector-button {
    background: #ff6600 !important;
    color: white !important;
    font-weight: 500 !important;
    border: none !important;
    padding: 14px 18px !important;
    margin: -14px -18px; /* Offset parent padding */
    margin-inline-end: 18px;
    border-radius: 12px 0 0 12px !important; /* Match the form control rounded corners on left side */
    box-shadow: none !important; /* Removed box shadow to match flat aesthetic perfectly within input */
    cursor: pointer;
    transition: all 0.3s ease;
}
input[type="file"]::file-selector-button:hover {
    background: #e65c00 !important;
}
input[type="file"]::file-selector-button:active {
    background: #cc5200 !important;
}

/* Mobile Responsiveness */
@media (max-width: 768px) {
    .info-panel {
        padding: 20px !important;
    }
    .contact-form-wrapper {
        padding: 25px 15px !important;
    }
    .form-header p {
        padding: 15px !important;
        text-align: left !important;
    }
    .btn-next, .btn-prev, .submit-btn {
        padding: 10px 15px !important;
        font-size: 0.85rem !important;
    }
    .submit-btn span.hide-mobile {
        display: none;
    }
}
</style>

