<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View Users | Rixi Lab</title>

  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
</head>
<body style="background-color: #f4f6f9;">
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
      <div class="sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="sidebar-badge">BOOTCAMP MGR</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">Main Menu</div>
      <a href="/bootcampManager" class="nav-link">
        <i class="bi bi-grid-1x2-fill"></i>
        <span>Dashboard</span>
      </a>
      <a href="/bootcampManager/manage" class="nav-link">
        <i class="bi bi-kanban"></i>
        <span>Manage Bootcamp</span>
      </a>
      <a href="/bootcampManager/create" class="nav-link">
        <i class="bi bi-plus-square-fill"></i>
        <span>Create Bootcamp</span>
      </a>
      <a href="/bootcampManager/attendance" class="nav-link">
        <i class="bi bi-calendar-check-fill"></i>
        <span>Attendance</span>
      </a>
      <a href="/bootcampManager/users" class="nav-link active">
        <i class="bi bi-people-fill"></i>
        <span>View Users</span>
      </a>
    </nav>
  </aside>

  <div class="main-content">
    <header class="admin-topbar">
      <div class="d-flex align-items-center">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-2">
          <h4>Enrolled Bootcamp Users</h4>
        </div>
      </div>
    </header>

    <div class="content-body">
      <div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h4>Enrolled Bootcamp Users</h4>
          <p class="text-muted mb-0">View all <%= users.length %> users and their progress across bootcamps.</p>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="intern-toolbar">
        <div class="intern-toolbar-left">
          <div class="search-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text" id="userSearch" class="intern-search-input"
              placeholder="Search by name or email…" oninput="applyUserFilters()">
          </div>
          <select id="bootcampFilter" class="intern-filter-select" onchange="applyUserFilters()"
            style="margin-left: 10px;">
            <option value="all">All Bootcamps</option>
            <% 
              const bootcampSet = new Set();
              users.forEach(u => {
                if (u.enrolledBootcamps) {
                  u.enrolledBootcamps.forEach(eb => {
                    if (eb.bootcamp_id && eb.bootcamp_id.name) {
                      bootcampSet.add(eb.bootcamp_id.name);
                    }
                  });
                }
              });
              Array.from(bootcampSet).sort().forEach(b => { 
            %>
              <option value="<%= b %>"><%= b %></option>
            <% }) %>
          </select>
        </div>
        <div class="intern-toolbar-right">
          <span id="userResultCount" class="intern-count-badge">
            <%= users.length %> users
          </span>
          <button class="btn btn-sm btn-outline-secondary" style="border-radius: 20px;"
            onclick="clearUserFilters()">
            <i class="bi bi-x-circle me-1"></i>Clear
          </button>
        </div>
      </div>

      <div class="intern-table-wrap d-none d-md-block">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th width="44" class="text-center">#</th>
              <th width="56">Photo</th>
              <th>Name & Contact</th>
              <th>Bootcamps Enrolled</th>
              <th class="text-center">Total Progress</th>
            </tr>
          </thead>
          <tbody id="userTableBody">
            <% users.forEach((u, index) => { 
               const bootcampsList = u.enrolledBootcamps ? u.enrolledBootcamps.map(eb => eb.bootcamp_id ? eb.bootcamp_id.name : '').join(',') : '';
            %>
              <tr class="user-row" data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-bootcamps="<%= bootcampsList.toLowerCase() %>">
                <td class="text-center text-muted"><%= index + 1 %></td>
                <td>
                  <div class="intern-avatar-wrap">
                    <img src="<%= u.profile_image || '/img/default-avatar.png' %>" alt="<%= u.name %>" class="intern-avatar">
                  </div>
                </td>
                <td>
                  <div class="fw-bold" style="font-size:0.875rem;"><%= u.name %></div>
                  <div class="small text-muted"><i class="bi bi-envelope me-1"></i><%= u.email %></div>
                  <% if(u.phone) { %>
                    <div class="small text-muted"><i class="bi bi-telephone me-1"></i><%= u.phone %></div>
                  <% } %>
                </td>
                <td>
                  <% if (u.enrolledBootcamps && u.enrolledBootcamps.length > 0) { %>
                    <ul class="list-unstyled mb-0">
                      <% u.enrolledBootcamps.forEach(eb => { %>
                        <li class="mb-2">
                          <span class="batch-chip mb-1"><%= eb.bootcamp_id ? eb.bootcamp_id.name : 'Unknown Bootcamp' %></span>
                          <div class="d-flex align-items-center gap-2 mt-1">
                            <div class="progress" style="height: 6px; width: 100px; border-radius: 10px;">
                              <div class="progress-bar bg-success" role="progressbar" style="width: <%= eb.progress %>%; border-radius: 10px;"></div>
                            </div>
                            <span class="small fw-bold text-muted" style="font-size: 0.7rem;"><%= eb.progress %>%</span>
                          </div>
                        </li>
                      <% }) %>
                    </ul>
                  <% } else { %>
                    <span class="text-muted small">None</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <% 
                    let avg = 0; 
                    if (u.enrolledBootcamps && u.enrolledBootcamps.length > 0) {
                      let sum = u.enrolledBootcamps.reduce((acc, curr) => acc + curr.progress, 0);
                      avg = Math.round(sum / u.enrolledBootcamps.length);
                    }
                  %>
                  <div class="fw-bold fs-5 text-<%= avg === 100 ? 'success' : 'primary' %>"><%= avg %>%</div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div id="noUserResult" class="intern-empty" style="display:none;">
          <i class="bi bi-search"></i>
          <p>No users match your filters.</p>
          <button class="btn btn-sm btn-outline-secondary mt-1" onclick="clearUserFilters()">Clear Filters</button>
        </div>
      </div>

      <!-- Mobile Card Grid (< md) -->
      <div class="intern-card-grid d-md-none" id="userCardGrid">
        <% users.forEach((u) => { 
           const bootcampsList = u.enrolledBootcamps ? u.enrolledBootcamps.map(eb => eb.bootcamp_id ? eb.bootcamp_id.name : '').join(',') : '';
        %>
          <div class="intern-card user-row" data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-bootcamps="<%= bootcampsList.toLowerCase() %>">
            <div class="intern-card-top">
              <div class="intern-avatar-wrap">
                <img src="<%= u.profile_image || '/img/default-avatar.png' %>" alt="<%= u.name %>" class="intern-avatar intern-avatar-lg">
              </div>
              <div class="intern-card-info">
                <div class="fw-bold"><%= u.name %></div>
                <div class="small text-muted"><%= u.email %></div>
              </div>
            </div>
            <% if(u.phone) { %>
              <div class="intern-card-meta mb-2">
                <i class="bi bi-telephone me-1"></i><%= u.phone %>
              </div>
            <% } %>
            
            <div class="mt-2">
              <div class="small fw-bold text-muted mb-2">Enrolled Bootcamps:</div>
              <% if (u.enrolledBootcamps && u.enrolledBootcamps.length > 0) { %>
                <div class="d-flex flex-column gap-2">
                  <% u.enrolledBootcamps.forEach(eb => { %>
                    <div class="bg-light p-2 rounded border">
                      <div class="small fw-bold mb-1"><%= eb.bootcamp_id ? eb.bootcamp_id.name : 'Unknown Bootcamp' %></div>
                      <div class="d-flex align-items-center gap-2">
                        <div class="progress flex-grow-1" style="height: 6px; border-radius: 10px;">
                          <div class="progress-bar bg-success" role="progressbar" style="width: <%= eb.progress %>%; border-radius: 10px;"></div>
                        </div>
                        <span class="small fw-bold text-muted" style="font-size: 0.7rem;"><%= eb.progress %>%</span>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <span class="text-muted small">None</span>
              <% } %>
            </div>

            <div class="intern-card-actions mt-3 pt-3 border-top">
              <% 
                let avg = 0; 
                if (u.enrolledBootcamps && u.enrolledBootcamps.length > 0) {
                  let sum = u.enrolledBootcamps.reduce((acc, curr) => acc + curr.progress, 0);
                  avg = Math.round(sum / u.enrolledBootcamps.length);
                }
              %>
              <div class="w-100 d-flex justify-content-between align-items-center">
                <span class="small text-muted fw-bold">Total Progress</span>
                <span class="fw-bold fs-5 text-<%= avg === 100 ? 'success' : 'primary' %>"><%= avg %>%</span>
              </div>
            </div>
          </div>
        <% }) %>
        <div id="noUserResultMobile" class="intern-empty d-md-none" style="display:none;">
          <i class="bi bi-search"></i>
          <p>No users match your filters.</p>
          <button class="btn btn-sm btn-outline-secondary mt-1" onclick="clearUserFilters()">Clear Filters</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('sidebarToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('show');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', () => {
      document.getElementById('sidebar').classList.remove('show');
      document.getElementById('sidebarOverlay').classList.remove('show');
    });

    function applyUserFilters() {
      const searchVal = document.getElementById('userSearch').value.toLowerCase();
      const bootcampVal = document.getElementById('bootcampFilter').value.toLowerCase();
      const rows = document.querySelectorAll('.user-row');
      
      let visibleCount = 0;
      
      rows.forEach(row => {
        const name = row.getAttribute('data-name');
        const email = row.getAttribute('data-email');
        const bootcamps = row.getAttribute('data-bootcamps');
        
        const matchSearch = name.includes(searchVal) || email.includes(searchVal);
        const matchBootcamp = bootcampVal === 'all' || bootcamps.includes(bootcampVal);
        
        if (matchSearch && matchBootcamp) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });
      
      document.getElementById('userResultCount').textContent = `${visibleCount} users`;
      
      const noDesktop = document.getElementById('noUserResult');
      const noMobile = document.getElementById('noUserResultMobile');
      if (visibleCount === 0) {
        if (noDesktop) noDesktop.style.display = 'flex';
        if (noMobile) noMobile.style.display = 'flex';
      } else {
        if (noDesktop) noDesktop.style.display = 'none';
        if (noMobile) noMobile.style.display = 'none';
      }
    }

    function clearUserFilters() {
      document.getElementById('userSearch').value = '';
      document.getElementById('bootcampFilter').value = 'all';
      applyUserFilters();
    }
  </script>
</body>
</html>
