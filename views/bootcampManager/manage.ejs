<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Bootcamp | Rixi Lab</title>
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
</head>
<body style="background-color: #f4f6f9;">
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
      <div class="sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="sidebar-badge">BOOTCAMP MGR</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">Main Menu</div>
      <a href="/bootcampManager" class="nav-link">
        <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
      </a>
      <a href="/bootcampManager/manage" class="nav-link active">
        <i class="bi bi-kanban"></i><span>Manage Bootcamp</span>
      </a>
      <a href="/bootcampManager/create" class="nav-link">
        <i class="bi bi-plus-square-fill"></i><span>Create Bootcamp</span>
      </a>
      <a href="/bootcampManager/attendance" class="nav-link">
        <i class="bi bi-calendar-check-fill"></i><span>Attendance</span>
      </a>
      <a href="/bootcampManager/users" class="nav-link">
        <i class="bi bi-people-fill"></i><span>View Users</span>
      </a>
    </nav>
  </aside>

  <div class="main-content">
    <header class="admin-topbar">
      <div class="d-flex align-items-center">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-2">
          <h4>Manage Bootcamp</h4>
        </div>
      </div>
      <div class="topbar-right">
        <div class="dropdown ms-2">
          <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
            <img src="<%= manager.profile_image %>" alt="Profile" class="rounded-circle shadow-sm" width="40" height="40" style="object-fit: cover;">
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
            <li><h6 class="dropdown-header">Signed in as <br><strong><%= manager.email %></strong></h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
          </ul>
        </div>
      </div>
    </header>

    <div class="content-body">

      <div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h4><i class="bi bi-kanban me-2 text-primary"></i>Manage Bootcamp</h4>
          <p class="text-muted mb-0">View, edit, and publish your existing bootcamps.</p>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-check-circle-fill me-2"></i><%= messages.success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= messages.error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <div class="row g-4 mb-4">
        <% bootcamps.forEach(bootcamp => { %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px; overflow: hidden;">
              <div style="position: relative;">
                <img src="<%= bootcamp.banner_img %>" class="card-img-top" alt="<%= bootcamp.name %>" style="height: 180px; object-fit: cover;">
                <span class="badge <%= bootcamp.status === 'live' ? 'bg-success' : 'bg-warning text-dark' %> shadow-sm"
                  style="position: absolute; top: 15px; right: 15px; font-size: 0.75rem; border-radius: 20px; padding: 6px 12px;">
                  <i class="bi bi-<%= bootcamp.status === 'live' ? 'broadcast' : 'pencil-square' %> me-1"></i><%= bootcamp.status.toUpperCase() %>
                </span>
              </div>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title fw-bold mb-2"><%= bootcamp.name %></h5>
                <p class="card-text text-muted small flex-grow-1"><%= bootcamp.description.substring(0, 90) %>...</p>

                <div class="p-2 mb-3 bg-light rounded d-flex justify-content-between align-items-center">
                  <span class="text-primary fw-bold" style="font-size: 0.85rem;">
                    <i class="bi bi-people-fill me-1"></i> <%= bootcamp.usersEnrolled.length %> Enrolled
                  </span>
                  <span class="text-muted fw-bold" style="font-size: 0.85rem;">
                    <i class="bi bi-camera-video-fill me-1"></i> <%= bootcamp.sessions.length %> Sessions
                  </span>
                </div>

                <div class="d-flex gap-2 mt-auto">
                  <a href="/bootcampManager/edit/<%= bootcamp._id %>" class="btn btn-sm btn-outline-secondary flex-grow-1" style="border-radius: 8px;">
                    <i class="bi bi-pencil-fill me-1"></i>Edit
                  </a>
                  <form method="POST" action="/bootcampManager/bootcamp/<%= bootcamp._id %>/toggle-publish" class="flex-grow-1 m-0">
                    <button type="submit" class="btn btn-sm w-100 <%= bootcamp.status === 'live' ? 'btn-warning' : 'btn-success' %>" style="border-radius: 8px;">
                      <% if (bootcamp.status === 'live') { %>
                        <i class="bi bi-eye-slash-fill me-1"></i>Unpublish
                      <% } else { %>
                        <i class="bi bi-globe me-1"></i>Publish
                      <% } %>
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>

        <% if (bootcamps.length === 0) { %>
          <div class="col-12">
            <div class="alert alert-info shadow-sm" style="border-radius: 10px;">
              <i class="bi bi-info-circle me-2"></i> No bootcamps created yet.
              <a href="/bootcampManager/create" class="alert-link">Create one now</a>.
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('sidebarToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('show');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', () => {
      document.getElementById('sidebar').classList.remove('show');
      document.getElementById('sidebarOverlay').classList.remove('show');
    });
  </script>
</body>
</html>
