<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Bootcamp | Rixi Lab</title>
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
</head>
<body style="background-color: #f4f6f9;">
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
      <div class="sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="sidebar-badge">BOOTCAMP MGR</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">Main Menu</div>
      <a href="/bootcampManager" class="nav-link">
        <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
      </a>
      <a href="/bootcampManager/manage" class="nav-link active">
        <i class="bi bi-kanban"></i><span>Manage Bootcamp</span>
      </a>
      <a href="/bootcampManager/create" class="nav-link">
        <i class="bi bi-plus-square-fill"></i><span>Create Bootcamp</span>
      </a>
      <a href="/bootcampManager/attendance" class="nav-link">
        <i class="bi bi-calendar-check-fill"></i><span>Attendance</span>
      </a>
      <a href="/bootcampManager/users" class="nav-link">
        <i class="bi bi-people-fill"></i><span>View Users</span>
      </a>
    </nav>
  </aside>

  <div class="main-content">
    <header class="admin-topbar">
      <div class="d-flex align-items-center">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-2">
          <h4>Manage Bootcamp</h4>
        </div>
      </div>
      <div class="topbar-right">
        <div class="dropdown ms-2">
          <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
            <img src="<%= manager.profile_image %>" alt="Profile" class="rounded-circle shadow-sm" width="40" height="40" style="object-fit: cover;">
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
            <li><h6 class="dropdown-header">Signed in as <br><strong><%= manager.email %></strong></h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
          </ul>
        </div>
      </div>
    </header>

    <div class="content-body">

      <div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h4><i class="bi bi-kanban me-2 text-primary"></i>Manage Bootcamp</h4>
          <p class="text-muted mb-0">View, edit, and publish your existing bootcamps.</p>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-check-circle-fill me-2"></i><%= messages.success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= messages.error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Bootcamp Cards Grid -->
      <div class="row g-4 mb-4" id="bootcampGrid">
        <% const reversedBootcamps=[...bootcamps].reverse(); %>
        <% reversedBootcamps.forEach(bootcamp => { %>
          <div class="col-12 col-md-6 col-xl-4">
            <div class="bc-card">

              <!-- Banner with accent overlay -->
              <div class="bc-card-banner">
                <img src="<%= bootcamp.banner_img %>" alt="<%= bootcamp.name %>">
                <div class="bc-card-banner-overlay"></div>
                <!-- Status Pill -->
                <span class="bc-status-pill bc-status-<%= bootcamp.status %>">
                  <i class="bi bi-<%= bootcamp.status === 'live' ? 'broadcast' : 'pencil-square' %>"></i>
                  <%= bootcamp.status === 'live' ? 'Live' : 'Draft' %>
                </span>
              </div>

              <!-- Body -->
              <div class="bc-card-body">
                <h5 class="bc-card-title"><%= bootcamp.name %></h5>
                <p class="bc-card-desc"><%= bootcamp.description.substring(0, 85) %>…</p>

                <!-- Stats Row -->
                <div class="bc-stats-row">
                  <div class="bc-stat">
                    <i class="bi bi-people-fill"></i>
                    <span><%= bootcamp.usersEnrolled.length %></span>
                    <span class="bc-stat-lbl">Enrolled</span>
                  </div>
                  <div class="bc-stat-divider"></div>
                  <div class="bc-stat">
                    <i class="bi bi-camera-video-fill"></i>
                    <span><%= bootcamp.sessions.length %></span>
                    <span class="bc-stat-lbl">Sessions</span>
                  </div>
                </div>

                <!-- Actions -->
                <div class="bc-actions">
                  <a href="/bootcampManager/edit/<%= bootcamp._id %>" class="bc-btn bc-btn-edit">
                    <i class="bi bi-pencil-fill"></i> Edit
                  </a>
                  <form method="POST" action="/bootcampManager/bootcamp/<%= bootcamp._id %>/toggle-publish" style="flex:1; margin:0;">
                    <% if (bootcamp.status === 'live') { %>
                      <button type="submit" class="bc-btn bc-btn-unpublish w-100">
                        <i class="bi bi-eye-slash-fill"></i> Unpublish
                      </button>
                    <% } else { %>
                      <button type="submit" class="bc-btn bc-btn-publish w-100">
                        <i class="bi bi-globe"></i> Publish
                      </button>
                    <% } %>
                  </form>
                </div>
              </div>

            </div>
          </div>
        <% }) %>

        <% if (bootcamps.length === 0) { %>
          <div class="col-12">
            <div class="bc-empty">
              <i class="bi bi-inbox"></i>
              <p>No bootcamps created yet.</p>
              <a href="/bootcampManager/create" class="bc-btn bc-btn-publish" style="width:auto; display:inline-flex;">
                <i class="bi bi-plus-lg"></i> Create Bootcamp
              </a>
            </div>
          </div>
        <% } %>
      </div>

      <style>
        /* ── Bootcamp Card ── */
        .bc-card {
          background: var(--surface, #fff);
          border-radius: var(--radius-lg, 16px);
          border: 1px solid var(--border, #e5e7eb);
          box-shadow: var(--shadow-md, 0 4px 16px rgba(0,0,0,.08));
          overflow: hidden;
          display: flex;
          flex-direction: column;
          transition: var(--transition, all .25s cubic-bezier(.4,0,.2,1));
          height: 100%;
        }
        .bc-card:hover {
          transform: translateY(-5px);
          box-shadow: 0 12px 36px rgba(0,0,0,.12), 0 4px 12px rgba(255,102,0,.10);
          border-color: rgba(255,102,0,.25);
        }

        /* Banner */
        .bc-card-banner {
          position: relative;
          height: 160px;
          overflow: hidden;
          flex-shrink: 0;
        }
        .bc-card-banner img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          transition: transform .4s cubic-bezier(.4,0,.2,1);
        }
        .bc-card:hover .bc-card-banner img {
          transform: scale(1.04);
        }
        .bc-card-banner-overlay {
          position: absolute;
          inset: 0;
          background: linear-gradient(to top, rgba(13,13,26,.55) 0%, transparent 60%);
          pointer-events: none;
        }

        /* Status Pill */
        .bc-status-pill {
          position: absolute;
          top: 12px;
          right: 12px;
          display: inline-flex;
          align-items: center;
          gap: 5px;
          font-size: 0.7rem;
          font-weight: 700;
          letter-spacing: .6px;
          text-transform: uppercase;
          padding: 4px 10px;
          border-radius: 20px;
          backdrop-filter: blur(8px);
          -webkit-backdrop-filter: blur(8px);
        }
        .bc-status-live {
          background: rgba(16, 185, 129, 0.18);
          border: 1px solid rgba(16, 185, 129, 0.45);
          color: #ecfdf5;
        }
        .bc-status-draft {
          background: rgba(245, 158, 11, 0.18);
          border: 1px solid rgba(245, 158, 11, 0.45);
          color: #fef3c7;
        }

        /* Body */
        .bc-card-body {
          padding: 18px 20px 20px;
          display: flex;
          flex-direction: column;
          flex: 1;
          gap: 10px;
        }
        .bc-card-title {
          font-size: 0.95rem;
          font-weight: 700;
          color: var(--text-primary, #1a1a2e);
          margin: 0;
          line-height: 1.3;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
        .bc-card-desc {
          font-size: 0.78rem;
          color: var(--text-secondary, #6b7280);
          line-height: 1.55;
          margin: 0;
          flex: 1;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }

        /* Stats Row */
        .bc-stats-row {
          display: flex;
          align-items: center;
          background: var(--surface-alt, #f8f9fc);
          border: 1px solid var(--border, #e5e7eb);
          border-radius: var(--radius-md, 12px);
          padding: 10px 16px;
          gap: 0;
        }
        .bc-stat {
          display: flex;
          align-items: center;
          gap: 6px;
          flex: 1;
          font-size: 0.8rem;
          font-weight: 600;
          color: var(--text-primary, #1a1a2e);
        }
        .bc-stat i {
          color: var(--primary, #ff6600);
          font-size: 0.85rem;
        }
        .bc-stat-lbl {
          font-size: 0.72rem;
          font-weight: 500;
          color: var(--text-muted, #9ca3af);
        }
        .bc-stat-divider {
          width: 1px;
          height: 24px;
          background: var(--border, #e5e7eb);
          margin: 0 12px;
          flex-shrink: 0;
        }

        /* Actions */
        .bc-actions {
          display: flex;
          gap: 8px;
          margin-top: 4px;
        }
        .bc-btn {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 5px;
          padding: 7px 14px;
          border-radius: var(--radius-sm, 8px);
          font-size: 0.78rem;
          font-weight: 600;
          border: none;
          cursor: pointer;
          text-decoration: none;
          transition: var(--transition, all .25s cubic-bezier(.4,0,.2,1));
          flex: 1;
          line-height: 1;
        }
        .bc-btn-edit {
          background: var(--surface-alt, #f8f9fc);
          border: 1px solid var(--border, #e5e7eb);
          color: var(--text-primary, #1a1a2e);
        }
        .bc-btn-edit:hover {
          background: var(--primary-glow, rgba(255,102,0,.12));
          border-color: rgba(255,102,0,.35);
          color: var(--primary, #ff6600);
        }
        .bc-btn-publish {
          background: linear-gradient(135deg, #ff6600, #ff4500);
          color: #fff;
          box-shadow: 0 4px 12px rgba(255,102,0,.30);
        }
        .bc-btn-publish:hover {
          box-shadow: 0 6px 18px rgba(255,102,0,.45);
          transform: translateY(-1px);
        }
        .bc-btn-unpublish {
          background: var(--surface-alt, #f8f9fc);
          border: 1px solid #fcd34d;
          color: #b45309;
        }
        .bc-btn-unpublish:hover {
          background: #fef3c7;
          border-color: #f59e0b;
        }

        /* Empty State */
        .bc-empty {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 14px;
          padding: 60px 24px;
          background: var(--surface, #fff);
          border: 1px dashed var(--border, #e5e7eb);
          border-radius: var(--radius-lg, 16px);
          text-align: center;
        }
        .bc-empty i {
          font-size: 2.8rem;
          color: var(--text-muted, #9ca3af);
        }
        .bc-empty p {
          font-size: 0.9rem;
          color: var(--text-secondary, #6b7280);
          margin: 0;
        }

        /* Card entrance animation */
        #bootcampGrid .col-12,
        #bootcampGrid .col-md-6,
        #bootcampGrid .col-xl-4 {
          animation: bcFadeUp .35s cubic-bezier(.4,0,.2,1) both;
        }
        #bootcampGrid > *:nth-child(1) { animation-delay: .05s; }
        #bootcampGrid > *:nth-child(2) { animation-delay: .10s; }
        #bootcampGrid > *:nth-child(3) { animation-delay: .15s; }
        #bootcampGrid > *:nth-child(4) { animation-delay: .20s; }
        #bootcampGrid > *:nth-child(5) { animation-delay: .25s; }
        #bootcampGrid > *:nth-child(6) { animation-delay: .30s; }
        @keyframes bcFadeUp {
          from { opacity: 0; transform: translateY(18px); }
          to   { opacity: 1; transform: translateY(0); }
        }
      </style>

    </div>
  </div>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('sidebarToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('show');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', () => {
      document.getElementById('sidebar').classList.remove('show');
      document.getElementById('sidebarOverlay').classList.remove('show');
    });
  </script>
</body>
</html>
