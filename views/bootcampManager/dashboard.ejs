<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bootcamp Manager | Rixi Lab</title>
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/admin.css">
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
</head>
<body style="background-color: #f4f6f9;">
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
      <div class="sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="sidebar-badge">BOOTCAMP MGR</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-nav-label">Main Menu</div>
      <a href="/bootcampManager" class="nav-link active">
        <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
      </a>
      <a href="/bootcampManager/manage" class="nav-link">
        <i class="bi bi-kanban"></i><span>Manage Bootcamp</span>
      </a>
      <a href="/bootcampManager/create" class="nav-link">
        <i class="bi bi-plus-square-fill"></i><span>Create Bootcamp</span>
      </a>
      <a href="/bootcampManager/attendance" class="nav-link">
        <i class="bi bi-calendar-check-fill"></i><span>Attendance</span>
      </a>
      <a href="/bootcampManager/users" class="nav-link">
        <i class="bi bi-people-fill"></i><span>View Users</span>
      </a>
    </nav>
  </aside>

  <div class="main-content">
    <header class="admin-topbar">
      <div class="d-flex align-items-center">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-2">
          <h4>Welcome, <%= manager.name %></h4>
        </div>
      </div>
      <div class="topbar-right">
        <div class="dropdown ms-2">
          <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
            <img src="<%= manager.profile_image %>" alt="Profile" class="rounded-circle shadow-sm" width="40" height="40" style="object-fit: cover;">
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
            <li><h6 class="dropdown-header">Signed in as <br><strong><%= manager.email %></strong></h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
          </ul>
        </div>
      </div>
    </header>

    <div class="content-body">
      
      <div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h4>Bootcamp Overview</h4>
          <p class="text-muted mb-0">Real-time insights and bootcamp management.</p>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-check-circle-fill me-2"></i><%= messages.success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 8px;">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= messages.error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% 
        let totalEnrolled = 0;
        let liveCount = 0;
        let draftCount = 0;
        bootcamps.forEach(b => {
          totalEnrolled += b.usersEnrolled.length;
          if(b.status === 'live') liveCount++;
          else draftCount++;
        });
      %>

      <!-- Stats Cards Row (admin.ejs style) -->
      <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="stat-card stat-card-1">
            <i class="bi bi-grid-fill stat-icon"></i>
            <div class="stat-label">Total Bootcamps</div>
            <div class="stat-value"><%= bootcamps.length %></div>
            <div class="stat-sub">Across all statuses</div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="stat-card stat-card-2">
            <i class="bi bi-broadcast stat-icon"></i>
            <div class="stat-label">Live Bootcamps</div>
            <div class="stat-value"><%= liveCount %></div>
            <div class="stat-sub">Published to users</div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="stat-card stat-card-3">
            <i class="bi bi-pencil-square stat-icon"></i>
            <div class="stat-label">Draft Bootcamps</div>
            <div class="stat-value"><%= draftCount %></div>
            <div class="stat-sub">Pending publication</div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
          <div class="stat-card stat-card-4">
            <i class="bi bi-people-fill stat-icon"></i>
            <div class="stat-label">Total Enrolled</div>
            <div class="stat-value"><%= totalEnrolled %></div>
            <div class="stat-sub">Active bootcamp users</div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="row g-4 mb-5">
        <div class="col-lg-8">
          <div class="chart-card">
            <div class="chart-card-header">
              <h5><i class="bi bi-graph-up-arrow"></i> Enrollment Analytics</h5>
            </div>
            <div class="chart-container" style="position: relative; height:300px; width:100%">
              <canvas id="enrollmentChart"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="chart-card h-100 d-flex flex-column">
            <div class="chart-card-header">
              <h5><i class="bi bi-pie-chart-fill"></i> Status Distribution</h5>
            </div>
            <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1" style="min-height: 250px;">
              <canvas id="statusChart" style="max-height: 200px; max-width: 200px;"></canvas>
            </div>
          </div>
        </div>
      </div>



    </div>
  </div>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.getElementById('sidebarToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('show');
      document.getElementById('sidebarOverlay').classList.toggle('show');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', () => {
      document.getElementById('sidebar').classList.remove('show');
      document.getElementById('sidebarOverlay').classList.remove('show');
    });

    // Chart logic
    document.addEventListener("DOMContentLoaded", function() {
      // Gather data from EJS
      const bootcamps = <%- JSON.stringify(bootcamps.map(b => ({name: b.name, enrolled: b.usersEnrolled.length, status: b.status}))) %>;
      
      const names = bootcamps.map(b => b.name.substring(0, 15) + '...');
      const enrollments = bootcamps.map(b => b.enrolled);

      const live = bootcamps.filter(b => b.status === 'live').length;
      const draft = bootcamps.filter(b => b.status === 'draft').length;

      // Bar Chart
      if(document.getElementById('enrollmentChart')) {
        new Chart(document.getElementById('enrollmentChart'), {
          type: 'bar',
          data: {
            labels: names,
            datasets: [{
              label: 'Enrolled Users',
              data: enrollments,
              backgroundColor: 'rgba(99, 102, 241, 0.8)',
              borderRadius: 6
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: { y: { beginAtZero: true } },
            plugins: {
              legend: { display: false }
            }
          }
        });
      }

      // Doughnut Chart
      if(document.getElementById('statusChart')) {
        new Chart(document.getElementById('statusChart'), {
          type: 'doughnut',
          data: {
            labels: ['Live', 'Draft'],
            datasets: [{
              data: [live, draft],
              backgroundColor: ['rgba(16, 185, 129, 0.8)', 'rgba(245, 158, 11, 0.8)'],
              borderWidth: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
              legend: { position: 'bottom' }
            }
          }
        });
      }
    });
  </script>
</body>
</html>
