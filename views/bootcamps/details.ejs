<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= bootcamp.name %> | Rixi Lab</title>

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900&display=swap"
    rel="stylesheet" />

  <!-- Vendor CSS Files -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/js/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
  <link href="/js/vendor/glightbox/css/glightbox.min.css" rel="stylesheet" />
  <link href="/js/vendor/swiper/swiper-bundle.min.css" rel="stylesheet" />

  <!-- Main CSS File -->
  <link href="/css/main.css" rel="stylesheet" />

  <style>
    .banner-hero {
      width: 100%;
      height: 350px;
      object-fit: cover;
      margin-top: 80px; /* offset for fixed header */
    }

    .glass-panel {
      background: var(--surface-color, #ffffff);
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
      margin-top: -80px;
      position: relative;
      z-index: 10;
    }

    .title-glow {
      font-weight: 700;
      font-size: 2.5rem;
      color: var(--heading-color, #212529);
    }

    .session-item {
      background: rgba(0,0,0,0.02);
      border-left: 4px solid var(--accent-color, #ff6600);
      border-radius: 0 8px 8px 0;
      padding: 1rem;
      margin-bottom: 1rem;
      transition: all 0.3s ease;
    }
    .session-item:hover {
      background: rgba(0,0,0,0.04);
      transform: translateX(5px);
    }

    .register-card {
      position: sticky;
      top: 100px;
      background: var(--surface-color, #ffffff);
      border: 1px solid rgba(0,0,0,0.05);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      margin-top: -80px;
      z-index: 10;
    }

    .price-tag {
      font-size: 3rem;
      font-weight: 700;
      color: var(--heading-color, #212529);
      margin: 1.5rem 0;
    }

    .btn-action {
      background: var(--accent-color, #ff6600);
      color: var(--contrast-color, #ffffff);
      border: none;
      width: 100%;
      padding: 14px;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-action:hover {
      background: #e65c00;
      color: var(--contrast-color, #ffffff);
      transform: translateY(-2px);
    }
    
    .form-dark .form-control {
      background: #ffffff;
      border: 1px solid rgba(0,0,0,0.1);
      color: var(--default-color, #444444);
      border-radius: 8px;
      padding: 12px;
    }
    .form-dark .form-control:focus {
      border-color: var(--accent-color, #ff6600);
      box-shadow: 0 0 0 3px rgba(255, 102, 0, 0.2);
    }
  </style>
</head>
<body class="index-page">
  <%- include('../partials/loader') %>
  
  <header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container position-relative d-flex align-items-center justify-content-between">
      <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="" />
        <h1 class="sitename">Rixi Lab</h1>
      </a>

      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/internship">Internship</a></li>
          <li><a href="/cap">CAP</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#services">Services</a></li>
          <li><a href="/certificate">Certificate</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>

      <a class="btn-getstarted" href="/login">Login</a>
    </div>
  </header>

  <main class="main">
    <img src="<%= bootcamp.banner_img %>" alt="<%= bootcamp.name %>" class="banner-hero">

    <div class="container" style="padding-bottom: 5rem;">
      <div class="row g-5">
        
        <!-- Left Panel: Details -->
        <div class="col-lg-8">
          <div class="glass-panel">
            <a href="/bootcamps" class="text-decoration-none d-flex align-items-center mb-4" style="color: var(--accent-color, #ff6600);">
              <i class="bi bi-arrow-left me-2"></i> Back to Bootcamps
            </a>

            <h1 class="title-glow mb-3 text-white"><%= bootcamp.name %></h1>
            
            <div class="d-flex gap-4 mb-4 text-white">
              <div><i class="bi bi-people-fill text-primary me-2"></i> <%= bootcamp.usersEnrolled.length %> Enrolled</div>
              <div><i class="bi bi-camera-video-fill text-primary me-2"></i> <%= bootcamp.sessions.length %> Sessions</div>
            </div>

            <h5 class="fw-bold mb-3 text-white">About the Bootcamp</h5>
            <p class="text-white" style="line-height: 1.8; font-size: 1.1rem; white-space: pre-wrap;"><%= bootcamp.description %></p>

            <hr class="my-5" style="border-color: rgba(0,0,0,0.1);">

            <h5 class="fw-bold mb-4 text-white">Curriculum / Sessions</h5>
            
            <% if(bootcamp.sessions.length === 0) { %>
              <div class="text-white fst-italic">Sessions are currently being finalized.</div>
            <% } else { %>
              <% bootcamp.sessions.forEach(s => { %>
                <div class="session-item">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong class="fs-5 text-white"><%= s.session_id %></strong>
                    <span class="badge bg-light border text-dark">
                      <i class="bi bi-calendar-event me-1"></i> <%= new Date(s.time).toLocaleString('en-IN') %>
                    </span>
                  </div>
                  <% if (s.details) { %>
                    <p class="text-white mb-2 small"><%= s.details %></p>
                  <% } %>
                  <div class="small" style="color: var(--accent-color, #ff6600);"><i class="bi bi-person-video3 me-1"></i> Instructor: <%= s.instructor %></div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Right Panel: Registration -->
        <div class="col-lg-4">
          <div class="register-card">
            <h4 class="text-white fw-bold">Ready to Start?</h4>
            
            <div class="price-tag">
              <% if(bootcamp.isPaid) { %>
                <i class="bi bi-currency-rupee" style="font-size: 2.5rem;"></i><%= bootcamp.payment.amount %>
              <% } else { %>
                FREE
              <% } %>
            </div>

            <p class="text-white mb-4 small">Secure your spot today and get exclusive access to all live sessions and materials.</p>

            <form action="/bootcamps/register/<%= bootcamp._id %>" method="POST" class="form-dark text-start">
              <div class="mb-3">
                <label class="form-label small text-white fw-semibold">Full Name</label>
                <input type="text" name="name" class="form-control" required placeholder="John Doe">
              </div>
              <div class="mb-3">
                <label class="form-label small text-white fw-semibold">Email Address</label>
                <input type="email" name="email" class="form-control" required placeholder="john@example.com">
              </div>
              <div class="mb-4">
                <label class="form-label small text-white fw-semibold">Phone Number</label>
                <input type="text" name="phone" class="form-control" required placeholder="+91 9876543210">
              </div>
              
              <button type="submit" class="btn-action">
                <% if(bootcamp.isPaid) { %>
                  Proceed to Pay
                <% } else { %>
                  Register Now
                <% } %>
              </button>
            </form>

          </div>
        </div>

      </div>
    </div>
  </main>

  <%- include('../partials/toaster') %>

  <footer id="footer" class="footer light-background">
    <div class="footer-top">
      <div class="container">
        <div class="row gy-4">
          <div class="col-lg-4 col-md-6 footer-about">
            <a href="/" class="logo d-flex align-items-center">
              <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo" style="height: 2rem !important" />
              <span class="sitename">Rixi Lab</span>
            </a>
            <div class="footer-contact pt-3">
              <p>Bhatpar Rani, Deoria,</p>
              <p>Uttar Pradesh, 274506 INDIA</p>
              <p class="mt-3">
                <strong>Phone:</strong>
                <span>+91 7617803891 Whatsapp Only</span>
              </p>
              <p><strong>Email:</strong> <span>rixilab7@gmail.com</span></p>
            </div>
          </div>

          <div class="col-lg-2 col-md-3 footer-links">
            <h4>Useful Links</h4>
            <ul>
              <li><a href="#">Home</a></li>
              <li><a href="#">About us</a></li>
              <li><a href="#">Services</a></li>
              <li><a href="#">Terms of service</a></li>
              <li><a href="#">Privacy policy</a></li>
            </ul>
          </div>

          <div class="col-lg-2 col-md-3 footer-links">
            <h4>Our Services</h4>
            <ul>
              <li><a href="#">Web Design</a></li>
              <li><a href="#">Web Development</a></li>
              <li><a href="#">Product Management</a></li>
              <li><a href="#">Marketing</a></li>
              <li><a href="#">Graphic Design</a></li>
            </ul>
          </div>

          <div class="col-lg-2 col-md-3 footer-links">
            <h4>Internships & Training</h4>
            <ul>
              <li><a href="#">Full Stack Web Development</a></li>
              <li><a href="#">UI/UX Design</a></li>
              <li><a href="#">Live Project Experience</a></li>
              <li><a href="#">Canva Premium free</a></li>
              <li><a href="#">Career Mentorship</a></li>
            </ul>
          </div>

          <div class="col-lg-2 col-md-3 footer-links">
            <h4>Courses & Certification</h4>
            <ul>
              <li><a href="#">Training Certificate</a></li>
              <li><a href="#">Internship Certificate</a></li>
              <li><a href="#">Couce Certificate.</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="copyright text-center">
      <div
        class="container d-flex flex-column flex-lg-row justify-content-center justify-content-lg-between align-items-center">
        <div class="d-flex flex-column align-items-center align-items-lg-start">
          <div>
            © Copyright 2025-26 <strong><span>Rixi Lab</span></strong>. All Rights Reserved
          </div>
          <div class="credits">Designed by <a href="#">Rixi Lab</a></div>
        </div>

        <div class="social-links order-first order-lg-last mb-3 mb-lg-0">
          <a href="https://www.linkedin.com/company/rixilab"><i class="bi bi-linkedin"></i></a>
          <a href="https://www.facebook.com/rixilab"><i class="bi bi-facebook"></i></a>
          <a href="https://www.instagram.com/rixilab.in"><i class="bi bi-instagram"></i></a>
          <a href=""><i class="bi bi-twitter-x"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i
      class="bi bi-arrow-up-short"></i></a>

  <!-- Vendor JS Files -->
  <script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/vendor/aos/aos.js"></script>
  <script src="/js/vendor/glightbox/js/glightbox.min.js"></script>
  <script src="/js/vendor/purecounter/purecounter_vanilla.js"></script>
  <script src="/js/vendor/typed.js/typed.umd.js"></script>
  <script src="/js/vendor/swiper/swiper-bundle.min.js"></script>

  <!-- Main JS File -->
  <script src="/js/main.js"></script>
</body>
</html>
