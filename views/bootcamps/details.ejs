<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title><%= bootcamp.name %> | Rixi Lab Bootcamps</title>
  <meta name="description" content="<%= bootcamp.description.substring(0, 155) %>">

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Raleway:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Vendor CSS Files -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/js/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
  <link href="/js/vendor/glightbox/css/glightbox.min.css" rel="stylesheet" />
  <link href="/js/vendor/swiper/swiper-bundle.min.css" rel="stylesheet" />

  <!-- Main CSS File -->
  <link href="/css/main.css" rel="stylesheet" />

  <style>
    :root {
      --accent: var(--accent-color, #ff6600);
      --accent-soft: rgba(255,102,0,0.08);
      --surface: var(--surface-color, #ffffff);
      --heading: var(--heading-color, #212529);
      --text: var(--default-color, #444444);
      --border: rgba(0,0,0,0.07);
      --shadow-sm: 0 2px 12px rgba(0,0,0,0.06);
      --shadow-md: 0 12px 40px rgba(0,0,0,0.1);
      --radius: 20px;
      --radius-sm: 12px;
    }

    /* body { font-family: 'Inter', sans-serif; background-color: var(--bg, #f8f9fa); } */

    /* ── Hero Banner ── */
    .dt-hero {
      position: relative;
      width: 100%;
      height: 420px;
      margin-top: 78px; 
    }
    .dt-hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      -webkit-mask-image: linear-gradient(to top, transparent 0%, black 50%);
      mask-image: linear-gradient(to top, transparent 0%, black 50%);
    }
    .dt-hero-content {
      position: absolute;
      bottom: 2rem;
      left: 0;
      right: 0;
      z-index: 10;
    }
    .dt-hero-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: rgba(255,255,255,0.85);
      font-size: 0.85rem;
      font-weight: 500;
      text-decoration: none;
      margin-bottom: 0.75rem;
      transition: color 0.2s;
    }
    .dt-hero-back:hover { color: #fff; }
    .dt-hero-title {
      font-family: 'Raleway', sans-serif;
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-weight: 800;
      color: #fff;
      margin-bottom: 0.6rem;
      text-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }
    .dt-hero-chips { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .dt-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,0.18);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.25);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 500;
      padding: 4px 12px;
      border-radius: 50px;
    }
    .dt-chip i { font-size: 0.8rem; }

    /* ── Share Button & Popover ── */
    .dt-share-btn {
      background: rgba(255,255,255,0.22);
      border: 1px solid rgba(255,255,255,0.35);
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 0.78rem;
      font-weight: 500;
      color: #fff;
      transition: background 0.2s, border-color 0.2s;
    }
    .dt-share-btn:hover {
      background: rgba(255,255,255,0.32);
      border-color: rgba(255,255,255,0.55);
    }
    .dt-share-popover {
      display: none;
      position: absolute;
      bottom: calc(100% + 14px);
      left: 0;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
      padding: 1rem 1.1rem 0.8rem;
      min-width: 210px;
      z-index: 200;
      animation: popIn .2s cubic-bezier(.4,0,.2,1);
    }
    .dt-share-popover.show { display: block; }
    @keyframes popIn {
      from { opacity:0; transform: translateY(8px) scale(.97); }
      to   { opacity:1; transform: translateY(0)  scale(1); }
    }
    .dt-share-popover-arrow {
      position: absolute;
      bottom: -7px;
      left: 22px;
      width: 14px;
      height: 14px;
      background: #fff;
      border-radius: 2px;
      transform: rotate(45deg);
      box-shadow: 3px 3px 8px rgba(0,0,0,0.08);
    }
    .dt-share-title {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 0.7rem;
    }
    .dt-share-options {
      display: flex;
      gap: 8px;
    }
    .dt-share-opt {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      background: #f8f9fc;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 10px 6px;
      font-size: 0.68rem;
      font-weight: 600;
      color: #1a1a2e;
      cursor: pointer;
      text-decoration: none;
      transition: background .18s, border-color .18s, color .18s;
    }
    .dt-share-opt i { font-size: 1.15rem; }
    .dt-share-opt:hover { background: rgba(255,102,0,.08); border-color: rgba(255,102,0,.3); color: #ff6600; }
    #whatsappShare:hover { background: rgba(37,211,102,.08); border-color: rgba(37,211,102,.35); color: #25d366; }
    #twitterShare:hover  { background: rgba(0,0,0,.06);      border-color: rgba(0,0,0,.2);       color: #000; }
    .dt-copy-feedback {
      display: none;
      margin-top: 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: #10b981;
      text-align: center;
    }

    /* ── Layout ── */
    .dt-body { padding: 2.5rem 0 5rem; }

    /* ── Panel (left) ── */
    .dt-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2.2rem;
      box-shadow: var(--shadow-sm);
      margin-bottom: 1.5rem;
    }
    .dt-section-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .dt-section-title {
      font-family: 'Raleway', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--heading);
      margin-bottom: 1.2rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--border);
    }
    .dt-desc {
      font-size: 0.97rem;
      color: var(--text);
      line-height: 1.8;
      white-space: pre-wrap;
    }

    /* ── Sessions Accordion ── */
    .dt-session {
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      margin-bottom: 0.75rem;
      background: var(--surface);
      overflow: hidden;
      transition: all 0.25s ease;
    }
    .dt-session:hover {
      border-color: rgba(255,102,0,0.3);
      box-shadow: 0 4px 16px rgba(255,102,0,0.05);
    }
    .dt-session-header {
      display: flex;
      gap: 1rem;
      padding: 1rem 1.2rem;
      cursor: pointer;
      align-items: center;
      user-select: none;
    }
    .dt-session-num {
      flex-shrink: 0;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--accent-soft);
      color: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.85rem;
    }
    .dt-session-info { flex: 1; min-width: 0; }
    .dt-session-id {
      font-weight: 700;
      font-size: 0.98rem;
      color: var(--heading);
      margin-bottom: 0.2rem;
    }
    .dt-session-meta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .dt-session-instructor {
      font-size: 0.8rem;
      color: var(--accent);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .dt-session-tag {
      font-size: 0.75rem;
      color: var(--text);
      opacity: 0.7;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .dt-session-toggle {
      color: var(--text);
      opacity: 0.5;
      transition: transform 0.3s ease;
    }
    .dt-session.active .dt-session-toggle {
      transform: rotate(180deg);
    }
    .dt-session-body {
      display: none;
      padding: 0 1.2rem 1.2rem 4.5rem; /* align with text */
    }
    .dt-session.active .dt-session-body {
      display: block;
      animation: fadeIn 0.3s ease;
    }
    .dt-session-body ul {
      margin: 0;
      padding-left: 1rem;
      font-size: 0.9rem;
      color: var(--text);
      line-height: 1.6;
    }
    .dt-session-body ul li {
      margin-bottom: 0.35rem;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Register Card (right sticky) ── */
    .dt-register-wrap { position: sticky; top: 100px; }
    .dt-register-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
      overflow: hidden;
    }
    .dt-register-header {
      background: linear-gradient(135deg, #ff6600 0%, #ff8c38 100%);
      padding: 1.6rem 1.8rem 1.4rem;
      color: #fff;
      text-align: center;
    }
    .dt-register-header h4 {
      font-family: 'Raleway', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.15rem;
    }
    .dt-register-header p {
      font-size: 0.8rem;
      opacity: 0.85;
      margin: 0;
    }
    .dt-price {
      display: block;
      font-size: 2.6rem;
      font-weight: 800;
      color: #fff;
      margin: 0.5rem 0 0;
      line-height: 1;
    }
    .dt-price small { font-size: 1.4rem; font-weight: 600; }
    .dt-register-body { padding: 1.6rem 1.8rem; }
    .dt-form-label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.35rem;
      display: block;
    }
    .dt-form-input {
      width: 100%;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: var(--radius-sm);
      padding: 10px 14px;
      font-size: 0.9rem;
      color: #ffffff;
      outline: none;
      transition: all 0.3s ease;
      font-family: 'Inter', sans-serif;
    }
    .dt-form-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(255,102,0,0.25);
      background: rgba(0, 0, 0, 0.9);
      color: #ffffff;
    }
    .dt-form-input::placeholder { color: rgba(255, 255, 255, 0.6); opacity: 1; }
    .dt-submit-btn {
      width: 100%;
      background: linear-gradient(135deg, #ff6600 0%, #ff8030 100%);
      color: #fff;
      border: none;
      border-radius: var(--radius-sm);
      padding: 13px;
      font-size: 0.98rem;
      font-weight: 700;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: all 0.25s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      letter-spacing: 0.02em;
    }
    /* .dt-submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(255,102,0,0.35);
    } */
    .dt-trust {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      margin-top: 0.9rem;
      font-size: 0.75rem;
      color: var(--text);
      opacity: 0.55;
    }
    .no-hover:hover {
    background: #ff6600 !important;
    transform: none !important;
    box-shadow: none !important;
    color: white !important;
  }
    /* ── Animate ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-up { animation: fadeUp 0.5s ease both; }
  </style>
</head>

<body class="index-page">
  <%- include('../partials/loader') %>

  <!-- ── Header (theme-consistent) ── -->
  <header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container position-relative d-flex align-items-center justify-content-between">
      <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo" />
        <h1 class="sitename">Rixi Lab</h1>
      </a>

      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/internship">Internship</a></li>
          <li><a href="/cap">CAP</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#services">Services</a></li>
          <li><a href="/bootcamps" class="active">Bootcamps</a></li>
          <li><a href="/certificate">Certificate</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>

      <a class="btn-getstarted" href="/login">Login</a>
    </div>
  </header>

  <main class="main">

    <!-- ── Hero Banner ── -->
    <div class="dt-hero">
      <img src="<%= bootcamp.banner_img %>" alt="<%= bootcamp.name %>" class="dt-hero-img">
      <div class="dt-hero-content animate-up">
        <div class="container">
          <a href="/bootcamps" class="dt-hero-back">
            <i class="bi bi-arrow-left"></i> All Bootcamps
          </a>
          <h1 class="dt-hero-title"><%= bootcamp.name %></h1>
          <div class="dt-hero-chips" style="position:relative;">
            <span class="dt-chip"><i class="bi bi-people-fill"></i> <%= bootcamp.usersEnrolled.length %> Enrolled</span>
            <span class="dt-chip"><i class="bi bi-camera-video-fill"></i> <%= bootcamp.sessions.length %> Sessions</span>
            <% if (bootcamp.isPaid) { %>
              <span class="dt-chip"><i class="bi bi-currency-rupee"></i><%= bootcamp.payment.amount %></span>
            <% } else { %>
              <span class="dt-chip"><i class="bi bi-lightning-charge-fill"></i> FREE</span>
            <% } %>
            <!-- Share Button -->
            <button class="dt-chip dt-share-btn" id="shareBtn" title="Share this bootcamp">
              <i class="bi bi-share-fill"></i> Share
            </button>
            <!-- Share Popover -->
            <div class="dt-share-popover" id="sharePopover">
              <div class="dt-share-popover-arrow"></div>
              <p class="dt-share-title">Share this Bootcamp</p>
              <div class="dt-share-options">
                <button class="dt-share-opt" id="copyLinkBtn" title="Copy link">
                  <i class="bi bi-link-45deg"></i>
                  <span>Copy Link</span>
                </button>
                <a class="dt-share-opt" id="whatsappShare" href="#" target="_blank" rel="noopener" title="Share on WhatsApp">
                  <i class="bi bi-whatsapp"></i>
                  <span>WhatsApp</span>
                </a>
                <a class="dt-share-opt" id="twitterShare" href="#" target="_blank" rel="noopener" title="Share on X/Twitter">
                  <i class="bi bi-twitter-x"></i>
                  <span>X / Twitter</span>
                </a>
              </div>
              <div class="dt-copy-feedback" id="copyFeedback">Link copied!</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Body ── -->
    <div class="dt-body">
      <div class="container">
        <div class="row g-4 align-items-start">

          <!-- ── Left: Details ── -->
          <div class="col-lg-8">

            <!-- About -->
            <div class="dt-panel animate-up" style="animation-delay:0.05s">
              <div class="dt-section-label">Overview</div>
              <div class="dt-section-title">About the Bootcamp</div>
              <p class="dt-desc"><%= bootcamp.description %></p>
            </div>

            <!-- Sessions -->
            <div class="dt-panel animate-up" style="animation-delay:0.1s">
              <div class="dt-section-label">Curriculum</div>
              <div class="dt-section-title">Sessions & Schedule</div>

              <% if (bootcamp.sessions.length === 0) { %>
                <p style="color:var(--text);opacity:0.6;font-style:italic;font-size:0.9rem;">
                  Sessions are currently being finalized. Check back soon.
                </p>
              <% } else { %>
                <% bootcamp.sessions.forEach((s, idx) => { %>
                  <div class="dt-session animate-up" style="animation-delay:<%= 0.12 + idx * 0.04 %>s">
                    <div class="dt-session-header" onclick="this.parentElement.classList.toggle('active')">
                      <div class="dt-session-num"><%= idx + 1 %></div>
                      <div class="dt-session-info">
                        <div class="dt-session-id"><%= s.session_name %></div>
                        <div class="dt-session-meta">
                          <span class="dt-session-instructor">
                            <i class="bi bi-person-badge-fill"></i> <%= s.instructor %>
                          </span>
                          <span class="dt-session-tag">
                            <i class="bi bi-calendar-event"></i>
                            <%= new Date(s.time).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                          </span>
                        </div>
                      </div>
                      <div class="dt-session-toggle">
                        <i class="bi bi-chevron-down"></i>
                      </div>
                    </div>
                    <% if (s.details) { %>
                      <div class="dt-session-body">
                        <ul>
                          <% s.details.split('\n').filter(d => d.trim().length > 0).forEach(point => { %>
                            <li><%= point.replace(/^-/, '').trim() %></li>
                          <% }) %>
                        </ul>
                      </div>
                    <% } %>
                  </div>
                <% }) %>
              <% } %>
            </div>

          </div>

          <!-- ── Right: Register Card ── -->
          <div class="col-lg-4">
            <div class="dt-register-wrap animate-up" style="animation-delay:0.08s">
              <div class="dt-register-card">

                <% if (bootcamp.status === 'closed') { %>
                  <!-- Closed State -->
                  <div class="dt-register-header" style="background: linear-gradient(135deg, #475569 0%, #64748b 100%);">
                    <h4><i class="bi bi-lock-fill me-2"></i>Registration Closed</h4>
                    <p>This bootcamp is no longer accepting registrations</p>
                  </div>
                  <div class="dt-register-body" style="text-align:center; padding: 2rem 1.8rem;">
                    <div style="width:64px;height:64px;background:rgba(100,116,139,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:#64748b;margin:0 auto 1.2rem;">
                      <i class="bi bi-lock-fill"></i>
                    </div>
                    <p style="font-size:0.92rem;color:var(--text);line-height:1.7;margin-bottom:1.2rem;">
                      Registrations for <strong><%= bootcamp.name %></strong> are currently closed. Check back later or explore other bootcamps.
                    </p>
                    <a href="/bootcamps" class="dt-submit-btn" style="background:linear-gradient(135deg,#475569,#64748b);text-decoration:none;">
                      <i class="bi bi-arrow-left"></i> Browse Bootcamps
                    </a>
                  </div>

                <% } else { %>
                  <!-- Header -->
                  <div class="dt-register-header">
                    <h4>Ready to Start?</h4>
                    <p>Secure your spot in this bootcamp</p>
                    <% if (bootcamp.isPaid) { %>
                      <span class="dt-price"><small><i class="bi bi-currency-rupee"></i></small><%= bootcamp.payment.amount %></span>
                    <% } else { %>
                      <span class="dt-price">FREE</span>
                    <% } %>
                  </div>

                  <!-- Form -->
                  <div class="dt-register-body">
                    <form action="/bootcamps/register/<%= bootcamp._id %>" method="POST">

                      <div class="mb-3">
                        <label class="dt-form-label">Full Name</label>
                        <input type="text" name="name" class="dt-form-input" required placeholder="John Doe">
                      </div>

                      <div class="mb-3">
                        <label class="dt-form-label">Email Address</label>
                        <input type="email" name="email" class="dt-form-input" required placeholder="john@example.com">
                      </div>

                      <div class="mb-4">
                        <label class="dt-form-label">Phone Number</label>
                        <input type="text" name="phone" class="dt-form-input" required placeholder="+91 98765 43210">
                      </div>

                      <button type="submit" class="dt-submit-btn">
                        <% if (bootcamp.isPaid) { %>
                          <i class="bi bi-shield-lock-fill"></i> Proceed to Pay
                        <% } else { %>
                          <i class="bi bi-rocket-takeoff-fill"></i> Register Now — Free
                        <% } %>
                      </button>

                      <div class="dt-trust">
                        <i class="bi bi-shield-check"></i>
                        Secure &amp; encrypted registration
                      </div>
                    </form>
                  </div>
                <% } %>

              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </main>

  <%- include('../partials/toaster') %>
  <%- include('../partials/footer') %>

  <!-- Registration Confirmation Modal -->
 ```html
<div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="background-color: #040000; color: #f8f8f8; border-radius: var(--radius); border: none; box-shadow: var(--shadow-md);">
      
      <div class="modal-header border-0 pb-0" style="justify-content: flex-end;">
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body text-center pt-0 pb-4 px-4">
        
        <div style="width: 70px; height: 70px; background: rgba(40, 167, 69, 0.15); color: #28a745; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1.5rem;">
          <i class="bi bi-check-lg"></i>
        </div>

        <h4 style="font-family: 'Raleway', sans-serif; font-weight: 700; color: #f8f8f8; margin-bottom: 0.8rem;">
          Registration Successful!
        </h4>

        <p style="color: #f8f8f8; font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem;">
          Thank you for registering for <strong><%= bootcamp.name %></strong>. We've sent the login details and further instructions to your email.
        </p>

        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          
          <a href="/bootcamp-portal/login" class="dt-submit-btn no-hover" style="text-decoration: none; display: inline-flex; width: auto; padding: 10px 24px; min-width: 140px; margin: 0 auto;">
            Go to Login
          </a>

          <a href="/bootcamps" class="dt-submit-btn no-hover" style="text-decoration: none; display: inline-flex; width: auto; padding: 10px 24px; min-width: 140px; margin: 0 auto;">
            Okay
          </a>

        </div>
      </div>
    </div>
  </div>
</div>
  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
    <i class="bi bi-arrow-up-short"></i>
  </a>

  <!-- Vendor JS Files -->
  <script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/vendor/aos/aos.js"></script>
  <script src="/js/vendor/glightbox/js/glightbox.min.js"></script>
  <script src="/js/vendor/purecounter/purecounter_vanilla.js"></script>
  <script src="/js/vendor/swiper/swiper-bundle.min.js"></script>

  <!-- Main JS File -->
  <script src="/js/main.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // ── Registration modal ──
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('registered') === 'true') {
        const confirmationModal = new bootstrap.Modal(document.getElementById('confirmationModal'));
        confirmationModal.show();
        const newUrl = window.location.pathname;
        window.history.replaceState({}, document.title, newUrl);
      }

      // ── Share button ──
      const shareBtn    = document.getElementById('shareBtn');
      const sharePopover = document.getElementById('sharePopover');
      const copyLinkBtn = document.getElementById('copyLinkBtn');
      const copyFeedback = document.getElementById('copyFeedback');
      const whatsappShare = document.getElementById('whatsappShare');
      const twitterShare  = document.getElementById('twitterShare');

      const pageUrl   = window.location.href;
      const pageTitle = '<%= bootcamp.name %> — Rixi Lab Bootcamp';

      // Set dynamic share URLs
      if (whatsappShare) {
        whatsappShare.href = `https://wa.me/?text=${encodeURIComponent(pageTitle + '\n' + pageUrl)}`;
      }
      if (twitterShare) {
        twitterShare.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(pageTitle)}&url=${encodeURIComponent(pageUrl)}`;
      }

      if (shareBtn) {
        shareBtn.addEventListener('click', async function (e) {
          e.stopPropagation();

          // Try native share (mobile)
          if (navigator.share) {
            try {
              await navigator.share({ title: pageTitle, url: pageUrl });
              return;
            } catch (_) { /* user cancelled */ }
          }

          // Fallback: toggle popover
          sharePopover.classList.toggle('show');
        });
      }

      // Copy link
      if (copyLinkBtn) {
        copyLinkBtn.addEventListener('click', async function () {
          try {
            await navigator.clipboard.writeText(pageUrl);
          } catch (_) {
            const ta = document.createElement('textarea');
            ta.value = pageUrl;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
          copyFeedback.style.display = 'block';
          setTimeout(() => { copyFeedback.style.display = 'none'; }, 2000);
        });
      }

      // Close popover on outside click
      document.addEventListener('click', function (e) {
        if (sharePopover && sharePopover.classList.contains('show')) {
          if (!sharePopover.contains(e.target) && e.target !== shareBtn) {
            sharePopover.classList.remove('show');
          }
        }
      });
    });
  </script>
</body>
</html>
