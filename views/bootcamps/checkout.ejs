<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Complete Payment | Rixi Lab</title>

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />

  <!-- Vendor CSS Files -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/main.css" rel="stylesheet" />

  <!-- Using Cashfree JS SDK V3 -->
  <script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>

  <style>
    body {
      background-color: var(--background-color, #f8f9fa);
      color: var(--default-color, #444444);
      font-family: var(--default-font, 'Roboto', sans-serif);
    }
    .loader-container {
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--surface-color, #ffffff);
    }
    .spinner-border {
      width: 3rem;
      height: 3rem;
      color: var(--accent-color, #ff6600);
    }
  </style>
</head>
<body class="index-page">
  <div class="loader-container">
    <div class="spinner-border mb-4" role="status"></div>
    <h3 class="fw-bold" style="color: var(--heading-color, #212529);">Initializing Secure Checkout...</h3>
    <p class="text-white">Please do not close or refresh this window.</p>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const mode = window.location.hostname.includes('localhost') ? 'sandbox' : 'production';
      const cashfree = Cashfree({ mode: mode }); 
      
      cashfree.checkout({
        paymentSessionId: "<%= paymentSessionId %>"
      }).then(function(result) {
        if(result.error){
            alert("Payment encountered an error: " + result.error.message);
            window.history.back();
        }
        if(result.redirect){
            console.log("Redirection handled by cashfree");
        }
      });
    });
  </script>
</body>
</html>
