<!-- 🌟 RixiLab — Minimal Glassmorphism Global Loader -->
<style>
  #rixiLoaderOverlay {
    position: fixed;
    inset: 0;
    /* Clean transparent backdrop */
    background: rgba(255, 255, 255, 0.2);
    /* Outer blur */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  body.dark-mode #rixiLoaderOverlay {
    background: rgba(15, 15, 20, 0.4);
  }

  /* Glassmorphism Container */
  .rixi-glass-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  body.dark-mode .rixi-glass-loader {
    background: rgba(30, 30, 40, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  #rixiLoaderOverlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Modern Smooth Spinner */
  .rixi-minimal-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid rgba(255, 102, 0, 0.15);
    border-top-color: #ff6600;
    border-right-color: transparent;
    border-bottom-color: transparent;
    border-radius: 50%;
    animation: minimalSpin 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
  }

  @keyframes minimalSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<div id="rixiLoaderOverlay">
  <div class="rixi-glass-loader">
    <div class="rixi-minimal-spinner"></div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const loaderOverlay = document.getElementById("rixiLoaderOverlay");
    
    // Hide loader on load
    window.addEventListener("load", () => {
      if (loaderOverlay) {
        loaderOverlay.classList.add("hidden");
        // Remove from flow after transition
        setTimeout(() => { loaderOverlay.style.display = "none"; }, 300);
      }
    });

    // Show loader when navigating away
    window.addEventListener("beforeunload", () => {
      if (loaderOverlay) {
        loaderOverlay.style.display = "flex";
        // Force reflow
        void loaderOverlay.offsetWidth;
        loaderOverlay.classList.remove("hidden");
      }
    });

    // Attach click listeners to standard links to show loader immediately
    document.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        // Only target normal navigation links
        if (href && !href.startsWith("#") && !href.startsWith("javascript") && link.target !== "_blank" && !link.dataset.bsToggle && !link.dataset.bsTarget) {
          if (loaderOverlay) {
            loaderOverlay.style.display = "flex";
            void loaderOverlay.offsetWidth;
            loaderOverlay.classList.remove("hidden");
          }
        }
      });
    });
  });
</script>
