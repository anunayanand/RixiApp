<!-- Vendor JS -->
<script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
 <script>
function showToaster(type, message) {
  if (typeof showToast === "function") {
    showToast(message, type);
  } else {
    alert(message);
  }
}
</script>

<!-- MAIN JS -->
<script>

// ------------------- SEND OTP -------------------
document.getElementById("sendOtpBtn").onclick = async () => {
  const intern_id = document.getElementById("intern_id").value;
  const email = document.getElementById("email").value;
  const sendBtn = document.getElementById("sendOtpBtn");
  
  if (!intern_id || !email) {
    showToaster("error", "Please enter Intern ID and Email");
    return;
  }
  
  const originalBtnHTML = sendBtn.innerHTML;
  sendBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> <span style="margin-left: 5px;">Sending...</span>`;
  sendBtn.disabled = true;

  try {
    const res = await fetch("/send-otp", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ intern_id, email })
    });

    const data = await res.json();
    console.log(data);

    if (data.success) {
      showToaster("success", data.flash || data.msg);

      document.getElementById("otpSection").style.display = "block";
      document.getElementById("resetPasswordBtn").style.display = "block";
      
      // Restore button state before hiding it (or if they want to resend later)
      sendBtn.innerHTML = originalBtnHTML;
      sendBtn.disabled = false;
      sendBtn.style.display = "none";
    } else {
      showToaster("error", data.flash || data.msg);
      sendBtn.innerHTML = originalBtnHTML;
      sendBtn.disabled = false;
    }
  } catch (err) {
    showToaster("error", "Failed to send OTP. Please try again.");
    sendBtn.innerHTML = originalBtnHTML;
    sendBtn.disabled = false;
  }
};

// ------------------- VERIFY OTP -------------------
document.getElementById("resetPasswordBtn").onclick = async () => {
  const intern_id = document.getElementById("intern_id").value;
  const email = document.getElementById("email").value;
  const otp = document.getElementById("otp").value;
  const resetBtn = document.getElementById("resetPasswordBtn");

  if (!otp) {
    showToaster("error", "Please enter the OTP");
    return;
  }

  const originalBtnHTML = resetBtn.innerHTML;
  resetBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> <span style="margin-left: 5px;">Verifying...</span>`;
  resetBtn.disabled = true;

  try {
    const res = await fetch("/verify-reset", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ intern_id, email, otp })
    });

    const data = await res.json();

    if (data.success) {
      showToaster("success", data.flash || data.msg);

      // Reset ALL fields
      document.getElementById("resetForm").reset();

      // Hide OTP section again
      document.getElementById("otpSection").style.display = "none";
      // Hide Reset Password button
      document.getElementById("resetPasswordBtn").style.display = "none";
      
      // Also restore button for future use if needed
      resetBtn.innerHTML = originalBtnHTML;
      resetBtn.disabled = false;

      // SHOW SUCCESS POPUP
      const modal = new bootstrap.Modal(document.getElementById("passwordResetModal"));
      modal.show();

      // Redirect when clicking OK
      document.getElementById("modalOkBtn").onclick = () => {
          window.location.href = "/login";
      };

    } else {
      showToaster("error", data.flash || data.msg);
      resetBtn.innerHTML = originalBtnHTML;
      resetBtn.disabled = false;
    }
  } catch (err) {
    showToaster("error", "Failed to verify OTP. Please try again.");
    resetBtn.innerHTML = originalBtnHTML;
    resetBtn.disabled = false;
  }
};

</script>

</body>
