<main class="main"><br><br><br>

<section id="contact" class="contact section">

  <div class="container section-title pb-4">
    <h2>Reset Password</h2>
  </div>

  <div class="container">
    <div class="row d-flex justify-content-center">

      <div class="col-lg-6">
        <div class="contact-form-wrapper">
          <div class="form-header">
            <h3>Reset Your Password</h3>
          </div>

          <form id="resetForm" class="php-email-form needs-validation" novalidate>

            <div class="mb-3">
              <label class="form-label">Intern ID</label>
              <input type="text" class="form-control" id="intern_id" placeholder="Enter your Intern ID" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Email Address</label>
              <input type="email" class="form-control" id="email" placeholder="Enter your email" required>
            </div>

            <!-- OTP Field -->
            <div class="mb-3" id="otpSection" style="display:none;">
              <label class="form-label">Enter OTP</label>
              <input type="text" class="form-control" id="otp" placeholder="Enter the OTP sent to your email" >
            </div>

            <div class="mb-2 text-center" id="errorMsg"></div>

            <!-- Send OTP -->
            <button type="button" id="sendOtpBtn" class="submit-btn w-100">
              <span >Send OTP</span>
              <i class="bi bi-arrow-right"></i>
            </button>

            <!-- Reset Password -->
            <button type="button" id="resetPasswordBtn" class="submit-btn w-100 mt-3" style="display:none;">
              <span>Reset Password</span>
              <i class="bi bi-arrow-right"></i>
            </button>

          </form>

        </div>
      </div>

    </div>
  </div>

</section>

<!-- Password Reset Successful Modal -->
<div class="modal fade" id="passwordResetModal" tabindex="-1" aria-hidden="true">
