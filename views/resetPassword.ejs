      <div class="modal-header">
        <h5 class="modal-title">Password Reset Successfully</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body text-white">
  Your password has been reset successfully.<br><br>
  <strong>Your new password is set to your Intern ID.</strong><br><br>
  <i>Kindly log in using your email and Intern ID as the password, and make sure to update your password after logging in.</i>
</div>


      <div class="modal-footer">
        <button type="button" id="modalOkBtn" class="btn w-100 text-white" style="background-color: #ff6600; font-weight: 500">
          OK
        </button>
      </div>

    </div>
  </div>
</div>


