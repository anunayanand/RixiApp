<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Ambassador Dashboard | Rixi Lab</title>
    <meta name="description" content="" />
    <meta name="keywords" content="" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />
    <link href="/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Main CSS -->
    <link href="/css/intern.css" rel="stylesheet" />

    <style>
      /* Ambassador Specific Overrides */
      .amb-badge-gold {
        color: #ffb347;
      }

      .amb-badge-silver {
        color: #c7cedb;
      }

      .amb-badge-bronze {
        color: #d17a3f;
      }

      .amb-badge-none {
        color: #6b7280;
      }
      
      .amb-referral-card {
        background: linear-gradient(135deg, rgba(255,102,0,0.1), rgba(0,0,0,0));
        border: 1px dashed var(--primary);
        border-radius: var(--radius-lg);
        padding: 20px;
        text-align: center;
      }
      .amb-referral-code {
        font-family: monospace;
        font-size: 1.5rem;
        color: var(--primary);
        font-weight: bold;
        letter-spacing: 2px;
        padding: 10px;
        background: rgba(0,0,0,0.3);
        border-radius: var(--radius-sm);
        display: inline-block;
        margin: 10px 0;
      }
      .amb-copy-btn {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-primary);
        transition: var(--transition);
      }
      .amb-copy-btn:hover {
        background: var(--primary);
        color: white;
      }
      .amb-copy-btn.copied {
        background: #10b981;
        color: white;
        border-color: #10b981;
      }
      
      .amb-intern-row {
        background: var(--surface);
        border-radius: var(--radius-lg);
        padding: 16px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        border-left: 4px solid var(--primary);
        box-shadow: var(--shadow-sm);
      }
      .amb-intern-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--primary-glow);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
        margin-right: 16px;
      }
      
      /* Ambassador Table Styles */
      .amb-table {
        width: 100%;
        border-collapse: collapse;
      }
      .amb-table th {
        padding: 16px 20px;
        text-align: left;
        color: var(--text-muted, #9ca3af);
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 2px solid rgba(255, 102, 0, 0.2);
        white-space: nowrap;
      }
      .amb-table td {
        padding: 10px 20px;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: var(--text-primary, #ffffff);
      }
      .amb-table tbody tr {
        transition: background-color 0.2s ease;
      }
      .amb-table tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.03);
      }
      .amb-table tbody tr:last-child td {
        border-bottom: none;
      }
      

      /* Badge Progress Steps */
      .amb-badge-steps {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin: 40px 0;
        padding: 0 20px;
      }
      .amb-badge-step-line {
        position: absolute;
        top: 15px;
        left: 30px;
        right: 30px;
        height: 4px;
        background: var(--surface-alt);
        z-index: 1;
      }
      .amb-badge-step-progress {
        position: absolute;
        top: 15px;
        left: 30px;
        height: 4px;
        background: var(--primary);
        z-index: 2;
        transition: width 0.5s ease;
      }
      .amb-badge-step {
        position: relative;
        z-index: 3;
        text-align: center;
        width: 60px;
      }
      .amb-badge-step-dot {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--surface-alt);
        border: 4px solid var(--body-bg);
        margin: 0 auto 10px;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .amb-badge-step.active .amb-badge-step-dot,
      .amb-badge-step.completed .amb-badge-step-dot {
        background: var(--primary);
        box-shadow: 0 0 15px var(--primary-glow);
      }
      .amb-badge-step-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
      }
      .amb-badge-step.active .amb-badge-step-label {
        color: var(--primary);
      }
      .amb-badge-step.completed .amb-badge-step-label {
        color: var(--text-primary);
      }

      .section-eyebrow {
        font-size: 0.85rem;
        color: var(--primary);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
      }
      .section-heading {
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 25px;
      }
      
      /* Dark Forms */
      .dark-form-input {
        background-color: #1e1e1e !important;
        border: 1px solid #27272a !important;
        color: #fff !important;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        box-shadow: none !important;
        transition: border-color 0.2s;
      }
      .dark-form-input:focus {
        border-color: #ff6600 !important;
        outline: none !important;
      }
      .dark-form-input::placeholder {
        color: rgba(255, 255, 255, 0.25);
      }
      .dark-input-group {
        display: flex;
        background-color: #1e1e1e;
        border: 1px solid #27272a;
        border-radius: 12px;
        overflow: hidden;
        transition: border-color 0.2s;
      }
      .dark-input-group:focus-within {
        border-color: #ff6600;
      }
      .dark-input-group .dark-input {
        border: none !important;
        border-radius: 0;
        background-color: transparent !important;
        box-shadow: none !important;
        color: #fff !important;
        flex-grow: 1;
        padding: 0.75rem 1rem;
      }
      .dark-input-group .dark-input:focus {
        outline: none !important;
      }
      .dark-input-group-text {
        background-color: transparent;
        color: #fff;
        border: none;
        border-right: 1px solid #27272a;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
      }
      .dark-submit-btn {
        background-color: #ff6600;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        transition: background-color 0.2s, transform 0.1s;
      }
      .dark-submit-btn:hover {
        background-color: #e65c00;
        color: #fff;
      }
      .dark-submit-btn:active {
        transform: scale(0.98);
      }
    </style>
  </head>

  <body>
    <%- include('partials/loader') %>
    <div class="id-sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="id-sidebar" id="sidebar">
      <div class="id-sidebar-brand">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab" />
        <div class="id-sidebar-brand-text">
          <h2>Rixi Lab</h2>
          <span class="id-sidebar-badge">AMBASSADOR</span>
        </div>
      </div>

      <div class="id-sidebar-profile">
        <div class="id-profile-img-wrap" data-bs-toggle="modal" data-bs-target="#updateProfileModal">
          <img src="<%= ambassador.img_url %>" alt="Profile" />
        </div>
        <h4><%= ambassador.name %></h4>
        <p><%= ambassador.ambassador_id %></p>
        <div class="id-sidebar-profile-stats">
          <div>
            <span>Referred</span>
            <strong><%= ambassador.internCount %></strong>
          </div>
          <div>
            <span>Badge</span>
            <strong class="amb-badge-<%= (badge || 'none').toLowerCase() %>"><%= badge %></strong>
          </div>
        </div>
      </div>

      <nav class="id-sidebar-nav">
        <div class="id-sidebar-nav-label">Menu</div>
        <a href="#dashboard" class="active" onclick="switchSection('dashboard', this)">
          <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </a>
        <a href="#interns" onclick="switchSection('interns', this)">
          <i class="bi bi-people-fill"></i> Interns
        </a>
        <a href="#rewards" onclick="switchSection('rewards', this)">
          <i class="bi bi-trophy-fill"></i> Rewards
        </a>
        <a href="#documents" onclick="switchSection('documents', this)">
          <i class="bi bi-file-earmark-text-fill"></i> Documents
        </a>
        
        <div class="d-md-none mt-4">
          <div class="id-sidebar-nav-label">Account</div>
          <a href="#" class="text-danger" data-bs-toggle="modal" data-bs-target="#logoutModal">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        </div>
      </nav>

      <div class="id-sidebar-footer">
        Technical Support<br>
        <a href="mailto:support@rixilab.tech" style="color: var(--primary);">support@rixilab.tech</a><br>
        &copy; 2025 Rixi Lab
      </div>
    </aside>

    <main class="id-main-content">
      <header class="id-topbar">
        <div class="id-topbar-left">
          <button class="id-sidebar-toggle d-md-none" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
          </button>
          <div>
            <h4 id="topbarTitle">Dashboard</h4>
            <p>Welcome , <%= ambassador.name.trim() %></p>
          </div>
        </div>
        <div class="id-topbar-right">
          <div class="dropdown" >
            <button class="id-topbar-btn" type="button" data-bs-toggle="dropdown">
              <img src="<%= ambassador.img_url %>" alt="Profile" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
            </button>
            <ul class="dropdown-menu dropdown-menu-end profile-dropdown-menu bg-dark" >
              <li class="text-white"><a class="dropdown-item text-white" href="#" data-bs-toggle="modal" data-bs-target="#updateProfileModal"><i class="bi bi-person-badge"></i> Update Photo</a></li>
              <li class="text-white"><a class="dropdown-item text-white" href="#" data-bs-toggle="modal" data-bs-target="#passwordModal"><i class="bi bi-shield-lock"></i> Change Password</a></li>
              <li><hr class="dropdown-divider"></li>
              <li class="text-white"><a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#logoutModal"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
            </ul>
          </div>
        </div>
      </header>

      <div class="id-content-body">
        <section id="dashboard" class="id-section active">
          <div class="row g-4 mb-4">
            <div class="col-md-4">
              <div class="id-stat-card">
                <div class="id-stat-icon"><i class="bi bi-people-fill"></i></div>
                <div class="id-stat-title">Interns Referred</div>
                <div class="id-stat-value"><%= ambassador.internCount %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="id-stat-card">
                <div class="id-stat-icon"><i class="bi bi-currency-rupee"></i></div>
                <div class="id-stat-title">Total Earnings</div>
                <div class="id-stat-value">₹<%= earnings %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="id-stat-card ">
                <div class="id-stat-icon"><i class="bi bi-award-fill"></i></div>
                <div class="id-stat-title">Badge</div>
                <div class="id-stat-value amb-badge-<%= (badge || 'none').toLowerCase() %>"><%= badge %></div>
              </div>
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-md-6">
              <div class="id-glass-panel h-100">
                <div class="id-panel-title">
                  <i class="bi bi-bank"></i> Ambassador Details
                </div>
                <ul class="id-info-list">
                  <li>
                    <span class="id-info-label">University</span>
                    <span class="id-info-value"><%= ambassador.university %></span>
                  </li>
                   <li>
                    <span class="id-info-label">Joining Date</span>
                    <span class="id-info-value">
                      <% const d = new Date(ambassador.joining_date); const formattedDate = d.toLocaleString("en-US", { month: "short", day: "2-digit", year: "numeric" }).replace(/,/g, ""); %>
                      <%= formattedDate %>
                    </span>
                  </li>
                  <li>
                    <span class="id-info-label">Discount %</span>
                    <span class="id-info-value"><%= ambassador.discountPercent %>%</span>
                  </li>
                  <li>
                    <span class="id-info-label">Commission %</span>
                    <span class="id-info-value"><%= ambassador.equity %>%</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="col-md-6">
              <div class="id-glass-panel h-100">
                <div class="id-panel-title">
                  <i class="bi bi-person-lines-fill"></i> Personal Details
                </div>
                <ul class="id-info-list">
                  <li>
                    <span class="id-info-label">Name</span>
                    <span class="id-info-value"><%= ambassador.name %></span>
                  </li>
                  <li>
                    <span class="id-info-label">Gender</span>
                    <span class="id-info-value"><%= ambassador.gender %></span>
                  </li>
                  <li>
                    <span class="id-info-label">College</span>
                    <span class="id-info-value"><%= ambassador.college %></span>
                  </li>
                  <li>
                    <span class="id-info-label">Address</span>
                    <span class="id-info-value"><%= ambassador.address.street %>, <%= ambassador.address.city %>, <%= ambassador.address.state %> <%= ambassador.address.country %> - <%= ambassador.address.pincode %></span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="id-glass-panel mb-0 p-4 position-relative overflow-hidden" style="border: 1px solid rgba(173, 250, 80, 0.422); border-radius: 16px;">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-4">
              <!-- Left: Text Info -->
              <div class="text-center text-md-start">
                <h5 class="fw-bold text-white mb-2">
                  Internship Registration Form
                </h5>
                <p class="text-white-50 small mb-0" style="max-width: 400px; line-height: 1.5;">
                  Invite your friends to join using your unique referral code. Earn <%= ambassador.equity %>% commission when they successfully register.
                </p>
              </div>

              <!-- Right: Referral Actions -->
              <div class="d-flex flex-column flex-sm-row align-items-center gap-3 w-100 justify-content-md-end" style="max-width: 450px; z-index: 1;">
                <!-- Code Box -->
                <div class="d-flex align-items-center rounded-pill" style="background-color: #161616; padding: 1px 1rem;">
                  <span class="text-white-50 me-3" style="font-size: 1rem;">Refferal Code : </span>
                  <span class="fw-bold text-white font-monospace" id="referralCodeText" style="letter-spacing: 1px; font-size: 1.25rem;"><%= ambassador.referralId %></span>
                </div>
                <!-- Actions -->
                <button class="btn btn-primary-custom rounded-pill px-4 py-2 d-flex align-items-center flex-shrink-0 bg-success" onclick="shareReferral('<%= ambassador.referralId %>')" style="font-weight: 600;">
                  <i class="bi bi-share-fill me-2"></i> Share
                </button>
              </div>
            </div>
          </div>
        </section>

        <section id="interns" class="id-section">
          <p class="section-eyebrow">Your Network</p>
          <h2 class="section-heading">Referred Interns</h2>

          <% if (referredInterns && referredInterns.length > 0) { %>
            <!-- Desktop Table View -->
            <div class="id-glass-panel p-0 overflow-hidden d-none d-md-block">
              <div class="table-responsive">
                <table class="amb-table">
                  <thead>
                    <tr>
                      <th>Intern</th>
                      <th class="d-none d-md-table-cell">Domain</th>
                      <th class="d-none d-sm-table-cell">Joining Date</th>
                      <th class="text-end">Earned</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% referredInterns.forEach((intern) => { %>
                      <tr>
                        <td>
                          <div class="d-flex align-items-center">
                            <% if (intern.img_url) { %>
                              <img src="<%= intern.img_url %>" alt="<%= intern.name %>" class="rounded-circle me-3 flex-shrink-0" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid rgba(255,102,0,0.3);">
                            <% } else { %>
                              <div class="amb-intern-avatar me-3 flex-shrink-0" style="margin-right: 16px !important;">
                                <%= intern.name.charAt(0).toUpperCase() %>
                              </div>
                            <% } %>
                            <div>
                              <h6 class="mb-1 text-white fw-bold"><%= intern.name %></h6>
                              <p class="mb-0 text-secondary small"><%= intern.email %></p>
                            </div>
                          </div>
                        </td>
                        <td class="d-none d-md-table-cell">
                          <span class="text-white-50"><%= intern.domain %></span>
                        </td>
                        <td class="d-none d-sm-table-cell text-white-50 small">
                          <%= new Date(intern.joining_date).toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" }) %>
                        </td>
                        <td class="text-end">
                          <h6 class="mb-1 text-success fw-bold">₹<%= intern.equity_earned || 0 %></h6>
                          <!-- <small class="text-muted" style="font-size: 0.75rem;">Earned</small> -->
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Mobile Card View -->
            <div class="d-block d-md-none">
              <div class="row g-3">
                <% referredInterns.forEach((intern) => { %>
                  <div class="col-12">
                    <div class="id-glass-panel p-3 d-flex flex-column gap-2" style="background: rgba(0,0,0,0.2);">
                      <div class="d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-center">
                          <% if (intern.img_url) { %>
                            <img src="<%= intern.img_url %>" alt="<%= intern.name %>" class="rounded-circle me-3 flex-shrink-0" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid rgba(255,102,0,0.3);">
                          <% } else { %>
                            <div class="amb-intern-avatar me-3 flex-shrink-0" style="margin-right: 16px !important;">
                              <%= intern.name.charAt(0).toUpperCase() %>
                            </div>
                          <% } %>
                          <div>
                            <h6 class="mb-1 text-white fw-bold text-truncate" style="max-width: 150px;"><%= intern.name %></h6>
                            <p class="mb-0 text-secondary small text-truncate" style="max-width: 150px;"><%= intern.email %></p>
                          </div>
                        </div>
                        <div class="text-end ps-2 flex-shrink-0">
                          <h6 class="mb-1 text-success fw-bold">₹<%= intern.equity_earned || 0 %></h6>
                        </div>
                      </div>
                      <div class="d-flex justify-content-between mt-2 pt-2 border-top border-secondary border-opacity-25">
                        <span class="text-white-50 small"><i class="bi bi-briefcase me-1"></i><%= intern.domain %></span>
                        <span class="text-white-50 small"><i class="bi bi-calendar-event me-1"></i><%= new Date(intern.joining_date).toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" }) %></span>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="bi bi-people display-1 text-muted mb-3 opacity-25"></i>
              <p class="text-secondary mb-0">No interns have been referred yet.</p>
            </div>
          <% } %>
        </section>

        <section id="rewards" class="id-section">
          <p class="section-eyebrow">Your Earnings</p>
          <h2 class="section-heading">Rewards & Withdrawals</h2>

          <!-- Badge Progress -->
          <div class="amb-badge-steps">
            <div class="amb-badge-step-line"></div>
            <% 
              const badges = ["None", "Bronze", "Silver", "Gold"];
              let badgeIndex = badges.indexOf(badge);
              if (badgeIndex === -1) badgeIndex = 0;
              const progressWidth = badgeIndex === 0 ? 0 : (badgeIndex / 3) * 100;
            %>
            <div class="amb-badge-step-progress" style="width: <%= progressWidth %>%;"></div>
            
            <% badges.forEach((b, i) => { 
                let stateClass = "";
                if (i < badgeIndex) stateClass = "completed";
                else if (i === badgeIndex) stateClass = "active";
            %>
            <div class="amb-badge-step <%= stateClass %>">
              <div class="amb-badge-step-dot">
                <% if (i < badgeIndex) { %>
                  <i class="bi bi-check-lg text-white"></i>
                <% } else if (i === badgeIndex && i !== 0) { %>
                  <i class="bi bi-star-fill text-white"></i>
                <% } else if (i === 0) { %>
                  <i class="bi bi-circle"></i>
                <% } %>
              </div>
              <div class="amb-badge-step-label"><%= b %></div>
            </div>
            <% }); %>
          </div>

          <!-- 📈 Financial Statistics Grid -->
          <div class="row g-4 mb-4">
            <div class="col-md-4">
              <div class="id-stat-card">
                <div class="id-stat-icon"><i class="bi bi-wallet2"></i></div>
                <div class="id-stat-title">Available Balance</div>
                <div class="id-stat-value" style="color: #ff6600;">₹<%= availableBalance.toFixed(2) %></div>
                <small class="text-secondary d-block mt-2" style="font-size: 0.75rem;">Earnings minus withdrawals</small>
              </div>
            </div>
            <div class="col-md-4">
              <div class="id-stat-card">
                <div class="id-stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="id-stat-title">Total Earnings</div>
                <div class="id-stat-value">₹<%= earnings.toFixed(2) %></div>
                <small class="text-secondary d-block mt-2" style="font-size: 0.75rem;">Cumulative commission</small>
              </div>
            </div>
            <div class="col-md-4">
              <div class="id-stat-card">
                <div class="id-stat-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="id-stat-title">Total Withdrawn</div>
