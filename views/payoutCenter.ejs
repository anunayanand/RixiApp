  <!-- Custom Alert/Confirm Modal -->
  

  <script>
    // Tab Switching
    document.querySelectorAll('.sidebar-menu li[data-target]').forEach(li => {
      li.addEventListener('click', () => {
        document.querySelectorAll('.sidebar-menu li').forEach(el => el.classList.remove('active'));
        li.classList.add('active');
        
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.getElementById(li.getAttribute('data-target')).classList.add('active');
      });
    });

    // Modals
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }

    // Loader & Custom Alert
    function showLoader() { document.getElementById('pageLoader').classList.add('active'); }
    function hideLoader() { document.getElementById('pageLoader').classList.remove('active'); }

    function customAlert(message, title="Notice", type="alert") {
      return new Promise((resolve) => {
        document.getElementById('customAlertTitle').innerText = title;
        document.getElementById('customAlertMessage').innerText = message;
        const actions = document.getElementById('customAlertActions');
        
        if(type === 'confirm') {
          actions.innerHTML = `
            <button class="btn btn-outline" id="cAlertCancel">Cancel</button>
            <button class="btn btn-primary" id="cAlertConfirm">Confirm</button>
          `;
          document.getElementById('cAlertCancel').onclick = () => { closeCustomAlert(); resolve(false); };
          document.getElementById('cAlertConfirm').onclick = () => { closeCustomAlert(); resolve(true); };
        } else {
          actions.innerHTML = `<button class="btn btn-primary" id="cAlertOk">OK</button>`;
          document.getElementById('cAlertOk').onclick = () => { closeCustomAlert(); resolve(true); };
        }
        document.getElementById('customAlertModal').classList.add('active');
      });
    }

    function closeCustomAlert() {
      document.getElementById('customAlertModal').classList.remove('active');
    }

    // Disable button helper
    function disableButton(btn) {
      if(btn) {
        btn.disabled = true;
        btn.dataset.originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        btn.style.opacity = "0.7";
        btn.style.cursor = "not-allowed";
      }
    }
    function enableButton(btn) {
      if(btn) {
        btn.disabled = false;
        btn.innerHTML = btn.dataset.originalText || 'Submit';
        btn.style.opacity = "1";
        btn.style.cursor = "pointer";
      }
    }

    // Approve Flow
    function openApproveModal(txId, name, amount, type, pfId = '') {
      document.getElementById('app_txId').value = txId;
      document.getElementById('app_name').value = name;
      document.getElementById('app_amount').value = amount;
      document.getElementById('app_type').value = type;
      document.getElementById('app_pfId').value = pfId;
      
      document.getElementById('approveTitle').innerText = type === 'pf' ? 'Approve PF Withdrawal' : 'Approve Ambassador Withdrawal';
      document.getElementById('approveModal').classList.add('active');
    }

    document.getElementById('approveForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const txId = document.getElementById('app_txId').value;
      const type = document.getElementById('app_type').value;
      const pfId = document.getElementById('app_pfId').value;
      const amount = document.getElementById('app_amount').value;
      
      const payload = {
        title: document.getElementById('app_title').value,
        transactionId: document.getElementById('app_txnId').value,
        amount: amount,
        sendMail: document.getElementById('app_sendMail').checked
      };

      let url = type === 'pf' 
        ? `/superAdmin/payouts/admin/pf-approve/${txId}/${pfId}`
        : `/superAdmin/payouts/ambassador/approve/${txId}`;

      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('approveModal');
          await refreshPayoutData();
          await customAlert('Approved successfully!', 'Success');
        } else {
          await customAlert(data.message || 'Error occurred', 'Error');
          enableButton(btn);
        }
      } catch (err) {
        hideLoader();
        await customAlert('Server error', 'Error');
        enableButton(btn);
      }
    });

    // Reject Flows
    async function rejectTransaction(txId, type) {
      const confirmed = await customAlert('Are you sure you want to reject this request?', 'Confirm Action', 'confirm');
      if(!confirmed) return;
      
      showLoader();
      const url = `/superAdmin/payouts/ambassador/reject/${txId}`;
      try {
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          await refreshPayoutData();
        }
        else await customAlert(data.message, 'Error');
      } catch(e) { hideLoader(); await customAlert('Error', 'Error'); }
    }

    async function rejectPF(adminId, pfId) {
      const confirmed = await customAlert('Are you sure you want to reject this PF request?', 'Confirm Action', 'confirm');
      if(!confirmed) return;

      showLoader();
      const url = `/superAdmin/payouts/admin/pf-reject/${adminId}/${pfId}`;
      try {
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          await refreshPayoutData();
        }
        else await customAlert(data.message, 'Error');
      } catch(e) { hideLoader(); await customAlert('Error', 'Error'); }
    }

    // Payroll Flow
    function openEditPayrollModal(admin) {
      document.getElementById('pay_adminId').value = admin._id;
      document.getElementById('pay_name').value = admin.name;
      document.getElementById('pay_month').value = '';
      
      // Default to the most recent month if any, otherwise 0
      const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 
        ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] 
        : null;

      document.getElementById('pay_basic').value = latest?.basicSalary || 0;
      document.getElementById('pay_bonus').value = latest?.performanceBonus || 0;
      document.getElementById('pay_pf').value = latest?.providentFund || 0;
      document.getElementById('pay_tax').value = latest?.professionalTax || 0;
      document.getElementById('pay_upi').value = admin.upiId || '';
      
      document.getElementById('payrollModal').classList.add('active');
    }

    document.getElementById('payrollForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const adminId = document.getElementById('pay_adminId').value;
      const payload = {
        month: document.getElementById('pay_month').value,
        basicSalary: document.getElementById('pay_basic').value,
        performanceBonus: document.getElementById('pay_bonus').value,
        providentFund: document.getElementById('pay_pf').value,
        professionalTax: document.getElementById('pay_tax').value,
        upiId: document.getElementById('pay_upi').value,
      };

      try {
        const res = await fetch(`/superAdmin/payouts/admin/update-payroll/${adminId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('payrollModal');
          await refreshPayoutData();
          await customAlert('Payroll updated successfully!', 'Success');
        } else {
          await customAlert(data.message, 'Error');
          enableButton(btn);
        }
      } catch(err) { 
        hideLoader(); 
        await customAlert('Error', 'Error'); 
        enableButton(btn);
      }
    });

    let currentAdminPayroll = [];

    function updateSettleCalculations() {
      const selectedMonth = document.getElementById('set_month').value;
      const p = currentAdminPayroll.find(m => m.month === selectedMonth);
      if (p) {
        const gross = (p.basicSalary || 0) + (p.performanceBonus || 0);
        const ded = (p.providentFund || 0) + (p.professionalTax || 0);
        const net = gross - ded;
        document.getElementById('set_gross').innerText = `₹${gross}`;
        document.getElementById('set_ded').innerText = `₹${ded}`;
        document.getElementById('set_net').innerText = `₹${net}`;
        document.getElementById('set_title').value = `Salary for ${selectedMonth}`;
      } else {
        document.getElementById('set_gross').innerText = `₹0`;
        document.getElementById('set_ded').innerText = `₹0`;
        document.getElementById('set_net').innerText = `₹0`;
        document.getElementById('set_title').value = ``;
      }
    }

    function openSettleSalaryModal(admin) {
      document.getElementById('set_adminId').value = admin._id;
      document.getElementById('set_name').value = admin.name;
      
      currentAdminPayroll = admin.monthlyPayroll || [];
      const monthSelect = document.getElementById('set_month');
      monthSelect.innerHTML = '<option value="">Select a month...</option>';
      
      // Sort months descending
      const sortedPayroll = [...currentAdminPayroll].sort((a,b) => b.month.localeCompare(a.month));
      
      sortedPayroll.forEach(p => {
        monthSelect.innerHTML += `<option value="${p.month}">${p.month}</option>`;
      });

      document.getElementById('set_gross').innerText = `₹0`;
      document.getElementById('set_ded').innerText = `₹0`;
      document.getElementById('set_net').innerText = `₹0`;
      document.getElementById('set_title').value = ``;
      document.getElementById('set_txnId').value = ``;

      document.getElementById('settleModal').classList.add('active');
    }

    document.getElementById('settleForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const adminId = document.getElementById('set_adminId').value;
      const payload = {
        month: document.getElementById('set_month').value,
        title: document.getElementById('set_title').value,
        transactionId: document.getElementById('set_txnId').value,
        sendMail: document.getElementById('set_sendMail').checked
      };

      try {
        const res = await fetch(`/superAdmin/payouts/admin/settle/${adminId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('settleModal');
          await refreshPayoutData();
          await customAlert('Salary settled successfully!', 'Success');
        } else {
          await customAlert(data.message, 'Error');
          enableButton(btn);
        }
      } catch(err) { 
        hideLoader(); 
        await customAlert('Error', 'Error'); 
        enableButton(btn);
      }
    });

  </script>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    // SweetAlert for custom alert
    function customAlert(message, title="Notice", type="alert") {
      return new Promise((resolve) => {
        if(type === 'confirm') {
          Swal.fire({
            title: title,
            text: message,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff6600',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Confirm'
          }).then((result) => {
            resolve(result.isConfirmed);
          });
        } else {
          Swal.fire({
            title: title,
            text: message,
            icon: type === 'Error' ? 'error' : 'success',
            confirmButtonColor: '#ff6600'
          }).then(() => {
            resolve(true);
          });
        }
      });
    }

    // Map custom modals to bootstrap modals
    let modalsMap = {};
    function getModal(id) {
      if(!modalsMap[id]) {
        const el = document.getElementById(id);
        if(el) modalsMap[id] = new bootstrap.Modal(el);
      }
      return modalsMap[id];
    }
    
    const originalOpenApprove = typeof openApproveModal === 'function' ? openApproveModal : null;
    window.openApproveModal = function(txId, name, amount, type, pfId = '') {
      document.getElementById('app_txId').value = txId;
      document.getElementById('app_name').value = name;
      document.getElementById('app_amount').value = amount;
      document.getElementById('app_type').value = type;
      document.getElementById('app_pfId').value = pfId;
      document.getElementById('approveTitle').innerText = type === 'pf' ? 'Approve PF Withdrawal' : 'Approve Ambassador Withdrawal';
      getModal('approveModal').show();
    };
    
    const originalOpenEdit = typeof openEditPayrollModal === 'function' ? openEditPayrollModal : null;
    window.openEditPayrollModal = function(admin) {
      document.getElementById('pay_adminId').value = admin._id;
      document.getElementById('pay_name').value = admin.name;
      document.getElementById('pay_month').value = '';
      const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] : null;
      document.getElementById('pay_basic').value = latest?.basicSalary || 0;
      document.getElementById('pay_bonus').value = latest?.performanceBonus || 0;
      document.getElementById('pay_pf').value = latest?.providentFund || 0;
      document.getElementById('pay_tax').value = latest?.professionalTax || 0;
      document.getElementById('pay_upi').value = admin.upiId || '';
      getModal('payrollModal').show();
    };

    const originalOpenSettle = typeof openSettleSalaryModal === 'function' ? openSettleSalaryModal : null;
    window.openSettleSalaryModal = function(admin) {
      document.getElementById('set_adminId').value = admin._id;
      document.getElementById('set_name').value = admin.name;
      currentAdminPayroll = admin.monthlyPayroll || [];
      const monthSelect = document.getElementById('set_month');
      monthSelect.innerHTML = '<option value="">Select a month...</option>';
      const sortedPayroll = [...currentAdminPayroll].sort((a,b) => b.month.localeCompare(a.month));
      sortedPayroll.forEach(p => { 
        const [yyyy, mm] = p.month.split('-');
        const date = new Date(yyyy, mm - 1);
        const display = date.toLocaleString('default', { month: 'long', year: 'numeric' });
        monthSelect.innerHTML += `<option value="${p.month}">${display}</option>`; 
      });
      document.getElementById('set_gross').innerText = `₹0`;
      document.getElementById('set_ded').innerText = `₹0`;
      document.getElementById('set_net').innerText = `₹0`;
      document.getElementById('set_title').value = ``;
      document.getElementById('set_txnId').value = ``;
      getModal('settleModal').show();
    };
    
    window.closeModal = function(id) {
       getModal(id).hide();
    }
    
    // Sidebar toggle
    document.getElementById('sidebarToggle').addEventListener('click', function() {
      document.getElementById('sidebar').classList.toggle('active');
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('active');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', function() {
      document.getElementById('sidebar').classList.remove('active', 'open');
      this.classList.remove('active');
    });

    // Flatpickr for month picking
    flatpickr("#pay_month", {
      plugins: [
        new monthSelectPlugin({
          shorthand: true,
          dateFormat: "Y-m", 
          altFormat: "F Y"
        })
      ],
      altInput: true
    });
  
    // Global function to refresh data without reloading
    window.refreshPayoutData = async function() {
      try {
        const res = await fetch(window.location.href);
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        const activeTabLink = document.querySelector('.sidebar-nav .nav-link.active');
        const activeTabId = activeTabLink ? activeTabLink.getAttribute('data-bs-target') : '#tab-dashboard';
        
        const newContent = doc.getElementById('payoutTabsContent');
        if(newContent) {
          document.getElementById('payoutTabsContent').innerHTML = newContent.innerHTML;
        }
        
        document.querySelectorAll('#payoutTabsContent .tab-pane').forEach(pane => {
          pane.classList.remove('show', 'active');
        });
        const activePane = document.querySelector(activeTabId);
        if(activePane) activePane.classList.add('show', 'active');
        
        if (typeof initPayoutCharts === 'function') initPayoutCharts();
      } catch (e) {
        console.error("Error refreshing data dynamically", e);
      }
    };

    // Analytics Charts Logic
    let doughnutChart = null;
    let lineChart = null;

    window.initPayoutCharts = function() {
      const dataEl = document.getElementById('payoutDataJSON');
      if (!dataEl) return;
      const parsedData = JSON.parse(dataEl.textContent);
      const transactions = parsedData.transactions;
      const interns = parsedData.interns;
      
      // Data Processing for Doughnut Chart
      let ambassadorTotal = 0;
      let adminTotal = 0;
      let pfTotal = 0;
      
      const monthlyData = {};
      const monthlyIncomeData = {};
      
      // Initialize last 6 months in order
      const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      const d = new Date();
      d.setDate(1);
      const last6Months = [];
      for (let i = 5; i >= 0; i--) {
        const temp = new Date(d.getFullYear(), d.getMonth() - i, 1);
        const label = monthNames[temp.getMonth()] + " " + temp.getFullYear().toString().slice(-2);
        last6Months.push(label);
        monthlyData[label] = 0;
        monthlyIncomeData[label] = 0;
      }

      transactions.forEach(t => {
        if (t.status === "Approved") {
          // Process Distribution
          if (t.type === "AmbassadorWithdrawal") ambassadorTotal += t.amount;
          else if (t.type === "AdminSalary") adminTotal += t.amount;
          else if (t.type === "PFWithdrawal") pfTotal += t.amount;
          
          // Process Monthly Trend
          if (t.processedAt) {
            const date = new Date(t.processedAt);
            const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
            if (monthlyData[label] !== undefined) {
              monthlyData[label] += t.amount;
            }
          }
        }
      });

      interns.forEach(intern => {
        let date = null;
        if (intern.batch_no) {
           const parsed = new Date(intern.batch_no);
           if (!isNaN(parsed)) date = parsed;
        }
        if (!date && intern.createdAt) {
           date = new Date(intern.createdAt);
        }
        if (date) {
           const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
           if (monthlyIncomeData[label] !== undefined) {
             monthlyIncomeData[label] += (intern.amountPaid || 0);
           }
        }
      });

      // Render Doughnut Chart
      const doughnutCtx = document.getElementById('payoutDoughnutChart');
      if (doughnutCtx) {
        if(doughnutChart) doughnutChart.destroy();
        doughnutChart = new Chart(doughnutCtx, {
          type: 'doughnut',
          data: {
            labels: ['Ambassadors', 'Admin Salary', 'PF Withdrawals'],
            datasets: [{
              data: [ambassadorTotal, adminTotal, pfTotal],
              backgroundColor: ['#6366f1', '#10b981', '#f59e0b'],
              borderWidth: 0,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: { color: '#888', padding: 20, font: { family: 'Montserrat' } }
              }
            },
            cutout: '75%'
          }
        });
      }

      // Render Line Chart
      const lineCtx = document.getElementById('payoutLineChart');
      if (lineCtx) {
        if(lineChart) lineChart.destroy();
        lineChart = new Chart(lineCtx, {
          type: 'line',
          data: {
            labels: last6Months,
            datasets: [
              {
                label: 'Income (₹)',
                data: last6Months.map(m => monthlyIncomeData[m]),
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4
              },
              {
                label: 'Payouts (₹)',
                data: last6Months.map(m => monthlyData[m]),
                borderColor: '#ef4444',
                backgroundColor: 'rgba(239, 68, 68, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { 
                display: true, 
                position: 'top', 
                labels: { color: '#888', font: { family: 'Montserrat' } } 
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                ticks: { color: '#888', font: { family: 'Montserrat' } }
              },
              x: {
                grid: { display: false, drawBorder: false },
                ticks: { color: '#888', font: { family: 'Montserrat' } }
              }
            }
          }
        });
      }
    };

    document.addEventListener("DOMContentLoaded", function() {
      initPayoutCharts();
      
      document.querySelectorAll('.sidebar-nav .nav-link').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 768) {
            document.getElementById('sidebar').classList.remove('active', 'open');
            document.getElementById('sidebarOverlay').classList.remove('active');
          }
        });
      });
    });
  </script>
</body>
</html>
  