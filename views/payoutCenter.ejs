          <input type="number" id="red_money" class="form-control" required placeholder="Cost of the voucher">
        </div>
        <div class="mb-3">
          <label>Voucher / Gift Card Code <span class="text-danger">*</span></label>
          <input type="text" id="red_code" class="form-control" required placeholder="Enter the code to send to the intern">
        </div>
        <div class="mb-3">
          <label>Payment Title (for Records)</label>
