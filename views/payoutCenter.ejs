<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Super Admin Dashboard | Rixi Lab</title>

  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  
  <!-- Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/superAdmin.css">
  <link rel="stylesheet" href="/css/mailCenter.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon">  
  
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <style>
    /* Payout Center Table Off-White Background */
    #payoutTabsContent .table-responsive {
      background-color: var(--surface-alt);
    }
    #payoutTabsContent .mail-table thead th {
      background-color: var(--surface-alt) !important;
    }
    /* Mobile Responsive Sidebar Toggle */
    .sidebar-toggle-btn {
      display: none;
      background: transparent;
      border: none;
      font-size: 1.5rem;
      color: var(--text-primary);
      cursor: pointer;
      padding: 0;
    }
    @media (max-width: 768px) {
      .sidebar-toggle-btn {
        display: inline-flex;
      }
    }
  </style>
</head>
<body>
<% 
const totalInterns = (typeof interns !== 'undefined' && interns) ? interns.length : 0;
%>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo">
      <div class="sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="sidebar-badge" style="border-color: #ff6600;">SUPER ADMIN</span>
      </div>
    </div>

    <nav class="sidebar-nav nav flex-column" role="tablist">
      <div class="sidebar-nav-label">Payouts</div>
      <a href="#tab-dashboard" class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-dashboard" role="tab">
        <i class="bi bi-grid-1x2-fill"></i>
        <span>Dashboard</span>
      </a>
      <a href="#tab-ambassador" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ambassador" role="tab">
        <i class="bi bi-people-fill"></i>
        <span>Ambassador Withdrawals</span>
      </a>
      <a href="#tab-admin-salary" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-admin-salary" role="tab">
        <i class="bi bi-cash-stack"></i>
        <span>Admin Salary</span>
      </a>
      <a href="#tab-pf" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pf" role="tab">
        <i class="bi bi-piggy-bank-fill"></i>
        <span>PF Withdrawals</span>
      </a>
      <a href="#tab-history" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-history" role="tab">
        <i class="bi bi-clock-history"></i>
        <span>Transaction History</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <small>Copyright © 2026 Rixi Lab. All rights reserved.</small>
    </div>
  </aside>

  
  <!-- Main Content Wrapper -->
  <div class="main-content">
<!-- Topbar -->
    <header class="admin-topbar">
      <div class="d-flex align-items-center">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div class="topbar-left ms-2">
          <h4>Welcome, <%= superAdmin.name.split(' ')[0] %></h4>
          <p class="d-none d-sm-block"><%= superAdmin.designation %></p>
        </div>
      </div>

      <div class="topbar-right">
        <!-- Back to Dashboard -->
        <a href="/superAdmin" class="topbar-btn" title="Back to Dashboard" style="color: inherit; text-decoration: none;">
          <i class="bi bi-arrow-left-circle"></i>
        </a>

        <!-- Notification Bell -->
        <div class="dropdown">
          <button class="topbar-btn" data-bs-toggle="dropdown" aria-expanded="false" id="notificationButton">
            <i class="bi bi-bell"></i>
            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="unreadBadge" style="font-size: 0.6rem;">
                <%= unreadCount > 9 ? '9+' : unreadCount %>
              </span>
            <% } else { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="unreadBadge">0</span>
            <% } %>
          </button>
          
          <ul class="dropdown-menu dropdown-menu-end notif-dropdown shadow-lg" style="width: 320px;" id="notificationList">
            <li class="notif-header d-flex justify-content-between align-items-center p-2 border-bottom">
              <span class="fw-bold">Notifications</span>
              <button id="clearAllBtn" class="btn btn-xs btn-outline-secondary py-0" style="font-size: 0.7rem; display: none;">Clear All</button>
            </li>
            <div id="notificationItems" style="max-height: 300px; overflow-y: auto;">
              <li class="p-4 text-center text-muted small">Loading...</li>
            </div>
          </ul>
        </div>

        <!-- User Profile Dropdown -->
        <div class="dropdown ms-2">
          <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
            <img src="<%= superAdmin.img_url %>" alt="Profile" class="rounded-circle border border-2 border-white shadow-sm" width="40" height="40" style="object-fit: cover;">
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
            <li><h6 class="dropdown-header">Signed in as <br><strong><%= superAdmin.email %></strong></h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#" data-bs-toggle="modal" onclick="window.location.href='/superAdmin'"><i class="bi bi-person me-2"></i> Update Photo</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="#" data-bs-toggle="modal" data-bs-target="#logoutModal"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
          </ul>
        </div>

      </div>
    </header>

    
    <!-- Content Body -->
    <div class="content-body">
      <%- include("partials/toaster") %>
      <%- include('partials/loader') %>

      <!-- <div class="page-header">
        <h4>💳 Payout Center</h4>
        <p>Manage Ambassador Withdrawals, Admin Payroll, and PF.</p>
      </div> -->
      
      <div class="tab-content" id="payoutTabsContent">
        <script id="payoutDataJSON" type="application/json">
          {"transactions": <%- JSON.stringify(transactions || []).replace(/</g, '\\u003c') %>, "interns": <%- JSON.stringify(interns || []).replace(/</g, '\\u003c') %>}
        </script>
        <!-- Dashboard -->
        <div class="tab-pane fade show active" id="tab-dashboard" role="tabpanel">
          <!-- Stats -->
          <div class="row g-4 mb-4">
            <div class="col-12 col-sm-6 col-xl-3">
              <div class="stat-card stat-card-1">
                <i class="bi bi-wallet2 stat-icon"></i>
                <div class="stat-label">Total Income</div>
                <div class="stat-value">₹<%= stats.totalIncome %></div>
                <div class="stat-sub">Registrations</div>
              </div>
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
              <div class="stat-card stat-card-2">
                <i class="bi bi-cash-stack stat-icon"></i>
                <div class="stat-label">Total Paid Out</div>
                <div class="stat-value">₹<%= stats.totalPaidOut %></div>
                <div class="stat-sub">All time</div>
              </div>
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
              <div class="stat-card stat-card-3">
                <i class="bi bi-hourglass-split stat-icon"></i>
                <div class="stat-label">Pending Requests</div>
                <div class="stat-value"><%= stats.pendingCount %></div>
                <div class="stat-sub">Requires action</div>
              </div>
            </div>
            <div class="col-12 col-sm-6 col-xl-3">
              <div class="stat-card stat-card-4">
                <i class="bi bi-calendar-check-fill stat-icon"></i>
                <div class="stat-label">This Month</div>
                <div class="stat-value">₹<%= stats.thisMonthPayouts %></div>
                <div class="stat-sub">Recent payouts</div>
              </div>
            </div>
          </div>

          <!-- Analytics Charts -->
          <div class="row g-4 mb-4">
            <div class="col-12 col-lg-6">
              <div class="mail-section-card p-4 h-100">
                <h5 class="mb-4 fw-bold">Payout Distribution</h5>
                <div style="position: relative; height: 300px; width: 100%; display: flex; justify-content: center;">
                  <canvas id="payoutDoughnutChart"></canvas>
                </div>
              </div>
            </div>
            <div class="col-12 col-lg-6">
              <div class="mail-section-card p-4 h-100">
                <h5 class="mb-4 fw-bold">Income vs Payouts (Last 6 Months)</h5>
                <div style="position: relative; height: 300px; width: 100%;">
                  <canvas id="payoutLineChart"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Ambassador Withdrawals -->
        <div class="tab-pane fade" id="tab-ambassador" role="tabpanel">
          <div class="mail-section-card">
            <div class="table-responsive d-none d-md-block" style="max-height: 500px; overflow-y: auto; overflow-x: auto; border-radius: 12px; border: 1px solid var(--border);">
              <table class="mail-table">
                  <thead>
                    <tr>
                      <th>Date</th><th>Name</th><th>Email</th><th>Amount</th><th>Details</th><th>Status</th><th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% const amWithdrawals = transactions.filter(t => t.type === 'AmbassadorWithdrawal' && t.status === 'Pending'); %>
                    <% if(amWithdrawals.length === 0) { %>
                      <tr><td colspan="7" class="text-center py-4 text-muted">No pending requests</td></tr>
                    <% } else { %>
                      <% amWithdrawals.forEach(t => { %>
                        <tr id="row-<%= t._id %>">
                          <td data-label="Date"><%= new Date(t.requestedAt).toLocaleDateString() %></td>
                          <td data-label="Name"><span class="fw-semibold"><%= t.recipientName %></span></td>
                          <td data-label="Email"><%= t.recipientEmail %></td>
                          <td data-label="Amount"><strong class="text-dark">₹<%= t.amount %></strong></td>
                          <td data-label="Details"><span class="badge bg-light text-dark border"><%= t.paymentDetails %></span></td>
                          <td data-label="Status"><span class="mail-badge mail-badge-pending"><i class="bi bi-clock me-1"></i>Pending</span></td>
                          <td data-label="Action">
                            <button class="btn btn-sm btn-success rounded-pill px-3 me-1" onclick="openApproveModal('<%= t._id %>', '<%= t.recipientName %>', '<%= t.amount %>', 'ambassador')"><i class="bi bi-check-lg"></i></button>
                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="rejectTransaction('<%= t._id %>', 'ambassador')"><i class="bi bi-x-lg"></i></button>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Card Grid (< md) -->
              <div class="intern-card-grid d-md-none mt-3">
                <% if(amWithdrawals.length === 0) { %>
                  <div class="text-center py-4 text-muted w-100">No pending requests</div>
                <% } else { %>
                  <% amWithdrawals.forEach(t => { %>
                    <div class="intern-card" id="card-<%= t._id %>">
                      <div class="intern-card-top">
                        <div class="intern-card-info">
                          <div class="fw-bold"><%= t.recipientName %></div>
                          <div class="small font-monospace text-muted"><%= t.recipientEmail %></div>
                        </div>
                        <span class="mail-badge mail-badge-pending"><i class="bi bi-clock me-1"></i>Pending</span>
                      </div>
                      <div class="intern-card-meta mb-2">
                        <div class="d-flex justify-content-between w-100">
                           <span><i class="bi bi-calendar3 me-1"></i> <%= new Date(t.requestedAt).toLocaleDateString() %></span>
                           <strong class="text-dark fs-5">₹<%= t.amount %></strong>
                        </div>
                      </div>
                      <div class="intern-card-meta mb-3">
                        <span class="badge bg-light text-dark border"><%= t.paymentDetails %></span>
                      </div>
                      <div class="intern-card-actions d-flex gap-2">
                        <button class="btn btn-sm btn-success flex-fill rounded-pill" onclick="openApproveModal('<%= t._id %>', '<%= t.recipientName %>', '<%= t.amount %>', 'ambassador')"><i class="bi bi-check-lg me-1"></i>Approve</button>
                        <button class="btn btn-sm btn-outline-danger flex-fill rounded-pill" onclick="rejectTransaction('<%= t._id %>', 'ambassador')"><i class="bi bi-x-lg me-1"></i>Reject</button>
                      </div>
                    </div>
                  <% }) %>
                <% } %>
              </div>
          </div>
        </div>

        <!-- Admin Salary -->
        <div class="tab-pane fade" id="tab-admin-salary" role="tabpanel">
          <div class="mail-section-card">
            <div class="table-responsive d-none d-md-block" style="max-height: 500px; overflow-y: auto; overflow-x: auto; border-radius: 12px; border: 1px solid var(--border);">
              <table class="mail-table">
                  <thead>
                    <tr>
                      <th>Admin Name</th><th>Basic</th><th>Bonus</th><th>PF</th><th>Tax</th><th>UPI</th><th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% admins.forEach(admin => { %>
                      <% const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] : null; %>
                      <tr id="admin-row-<%= admin._id %>">
                        <td data-label="Admin Name"><span class="fw-semibold"><%= admin.name %></span></td>
                        <td id="basic-<%= admin._id %>" data-label="Basic">₹<%= latest?.basicSalary || 0 %></td>
                        <td id="bonus-<%= admin._id %>" data-label="Bonus">₹<%= latest?.performanceBonus || 0 %></td>
                        <td data-label="PF"><span class="text-danger" id="pf-<%= admin._id %>">₹<%= latest?.providentFund || 0 %></span></td>
                        <td data-label="Tax"><span class="text-danger" id="tax-<%= admin._id %>">₹<%= latest?.professionalTax || 0 %></span></td>
                        <td id="upi-<%= admin._id %>" data-label="UPI"><%= admin.upiId || 'N/A' %></td>
                        <td data-label="Actions">
                          <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1" onclick='openEditPayrollModal(<%- JSON.stringify(admin) %>)'><i class="bi bi-pencil"></i> Edit</button>
                          <button class="btn btn-sm btn-primary rounded-pill px-3" onclick='openSettleSalaryModal(<%- JSON.stringify(admin) %>)'><i class="bi bi-cash-stack"></i> Settle</button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Card Grid (< md) -->
              <div class="intern-card-grid d-md-none mt-3">
                <% admins.forEach(admin => { %>
                  <% const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] : null; %>
                  <div class="intern-card" id="card-admin-<%= admin._id %>">
                    <div class="intern-card-top">
                      <div class="intern-card-info">
                        <div class="fw-bold fs-5"><%= admin.name %></div>
                        <div class="small font-monospace text-muted mt-1"><i class="bi bi-wallet me-1"></i>UPI: <%= admin.upiId || 'N/A' %></div>
                      </div>
                    </div>
                    <div class="intern-card-meta mb-3">
                      <div class="row g-2 w-100">
                        <div class="col-6">
                           <div class="small text-muted">Basic</div>
                           <div class="fw-semibold" id="card-basic-<%= admin._id %>">₹<%= latest?.basicSalary || 0 %></div>
                        </div>
                        <div class="col-6 text-end">
                           <div class="small text-muted">Bonus</div>
                           <div class="fw-semibold text-success" id="card-bonus-<%= admin._id %>">₹<%= latest?.performanceBonus || 0 %></div>
                        </div>
                        <div class="col-6">
                           <div class="small text-muted">PF</div>
                           <div class="fw-semibold text-danger" id="card-pf-<%= admin._id %>">₹<%= latest?.providentFund || 0 %></div>
                        </div>
                        <div class="col-6 text-end">
                           <div class="small text-muted">Tax</div>
                           <div class="fw-semibold text-danger" id="card-tax-<%= admin._id %>">₹<%= latest?.professionalTax || 0 %></div>
                        </div>
                      </div>
                    </div>
                    <div class="intern-card-actions d-flex gap-2">
                      <button class="btn btn-sm btn-outline-primary flex-fill rounded-pill" onclick='openEditPayrollModal(<%- JSON.stringify(admin) %>)'><i class="bi bi-pencil me-1"></i>Edit</button>
                      <button class="btn btn-sm btn-primary flex-fill rounded-pill" onclick='openSettleSalaryModal(<%- JSON.stringify(admin) %>)'><i class="bi bi-cash-stack me-1"></i>Settle</button>
                    </div>
                  </div>
                <% }) %>
              </div>
          </div>
        </div>

        <!-- PF Withdrawals -->
        <div class="tab-pane fade" id="tab-pf" role="tabpanel">
          <div class="mail-section-card">
            <div class="table-responsive d-none d-md-block" style="max-height: 500px; overflow-y: auto; overflow-x: auto; border-radius: 12px; border: 1px solid var(--border);">
              <table class="mail-table">
                  <thead>
                    <tr>
                      <th>Date</th><th>Admin Name</th><th>Amount</th><th>Details</th><th>Status</th><th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% let hasPF = false; %>
                    <% admins.forEach(admin => { %>
                      <% (admin.pfWithdrawals || []).forEach(pf => { %>
                        <% if(pf.status === 'Pending') { hasPF = true; %>
                          <tr id="pf-row-<%= pf._id %>">
                            <td data-label="Date"><%= new Date(pf.requestedAt).toLocaleDateString() %></td>
                            <td data-label="Admin Name"><span class="fw-semibold"><%= admin.name %></span></td>
                            <td data-label="Amount"><strong class="text-dark">₹<%= pf.amount %></strong></td>
                            <td data-label="Details"><span class="badge bg-light text-dark border"><%= pf.paymentDetails %></span></td>
                            <td data-label="Status"><span class="mail-badge mail-badge-pending"><i class="bi bi-clock me-1"></i>Pending</span></td>
                            <td data-label="Action">
                              <button class="btn btn-sm btn-success rounded-pill px-3 me-1" onclick="openApproveModal('<%= admin._id %>', '<%= admin.name %>', '<%= pf.amount %>', 'pf', '<%= pf._id %>')"><i class="bi bi-check-lg"></i></button>
                              <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="rejectPF('<%= admin._id %>', '<%= pf._id %>')"><i class="bi bi-x-lg"></i></button>
                            </td>
                          </tr>
                        <% } %>
                      <% }) %>
                    <% }) %>
                    <% if(!hasPF) { %>
                      <tr><td colspan="6" class="text-center py-4 text-muted">No pending requests</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Card Grid (< md) -->
              <div class="intern-card-grid d-md-none mt-3">
                <% let hasPFCard = false; %>
                <% admins.forEach(admin => { %>
                  <% (admin.pfWithdrawals || []).forEach(pf => { %>
                    <% if(pf.status === 'Pending') { hasPFCard = true; %>
                      <div class="intern-card" id="card-pf-<%= pf._id %>">
                        <div class="intern-card-top">
                          <div class="intern-card-info">
                            <div class="fw-bold"><%= admin.name %></div>
                            <div class="small text-muted"><i class="bi bi-calendar3 me-1"></i><%= new Date(pf.requestedAt).toLocaleDateString() %></div>
                          </div>
                          <span class="mail-badge mail-badge-pending"><i class="bi bi-clock me-1"></i>Pending</span>
                        </div>
                        <div class="intern-card-meta mb-2">
                          <div class="d-flex justify-content-between w-100 align-items-center">
                             <span class="badge bg-light text-dark border"><%= pf.paymentDetails %></span>
                             <strong class="text-dark fs-5">₹<%= pf.amount %></strong>
                          </div>
                        </div>
                        <div class="intern-card-actions d-flex gap-2 mt-3">
                          <button class="btn btn-sm btn-success flex-fill rounded-pill" onclick="openApproveModal('<%= admin._id %>', '<%= admin.name %>', '<%= pf.amount %>', 'pf', '<%= pf._id %>')"><i class="bi bi-check-lg me-1"></i>Approve</button>
                          <button class="btn btn-sm btn-outline-danger flex-fill rounded-pill" onclick="rejectPF('<%= admin._id %>', '<%= pf._id %>')"><i class="bi bi-x-lg me-1"></i>Reject</button>
                        </div>
                      </div>
                    <% } %>
                  <% }) %>
                <% }) %>
                <% if(!hasPFCard) { %>
                  <div class="text-center py-4 text-muted w-100">No pending requests</div>
                <% } %>
              </div>
          </div>
        </div>

        <!-- Transaction History -->
        <div class="tab-pane fade" id="tab-history" role="tabpanel">
          <div class="mail-section-card">
            <div class="table-responsive d-none d-md-block" style="max-height: 500px; overflow-y: auto; overflow-x: auto; border-radius: 12px; border: 1px solid var(--border);">
              <table class="mail-table">
                  <thead>
                    <tr>
                      <th>Date</th><th>Recipient</th><th>Type</th><th>Amount</th><th>Status</th><th>Txn ID</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% transactions.forEach(t => { %>
                      <tr>
                        <td data-label="Date"><%= new Date(t.requestedAt).toLocaleDateString() %></td>
                        <td data-label="Recipient"><span class="fw-semibold"><%= t.recipientName %></span></td>
                        <td data-label="Type"><span class="badge bg-secondary"><%= t.type %></span></td>
                        <td data-label="Amount"><strong class="text-dark">₹<%= t.amount %></strong></td>
                        <td data-label="Status">
                          <% if(t.status === 'Approved'){ %>
                            <span class="mail-badge mail-badge-sent"><i class="bi bi-check-circle me-1"></i>Approved</span>
                          <% } else if(t.status === 'Rejected'){ %>
                            <span class="mail-badge mail-badge-pending" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: rgba(239, 68, 68, 0.3);"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                          <% } else { %>
                            <span class="mail-badge mail-badge-pending"><i class="bi bi-clock me-1"></i>Pending</span>
                          <% } %>
                        </td>
                        <td data-label="Txn ID"><small class="text-muted"><%= t.transactionId || '-' %></small></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Card Grid (< md) -->
