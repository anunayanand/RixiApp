  <!-- Loader -->
  <div class="loader-overlay" id="pageLoader">
    <div class="spinner"></div>
    <div style="margin-top:15px; color:#fff;">Processing...</div>
  </div>

  <!-- Custom Alert/Confirm Modal -->
  
  <!-- Secret Key Modal -->
  <div class="modal fade" tabindex="-1" id="secretModal" data-has-secret="<%= hasSecretKey %>">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content p-3 border-0 shadow">
        
        <!-- View 1: Set PIN -->
        <div id="view-set-pin" class="d-none">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title text-center w-100 fw-bold">Set New PIN</h5>
            <button type="button" class="btn-close position-absolute" style="right: 15px; top: 15px;" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <p class="text-muted small mb-3">Create a 4-digit secret key to view secure stats</p>
            <input type="password" id="newSecretKeyInput" class="form-control text-center fs-3 fw-bold" style="letter-spacing: 0.5em; border-radius: 12px;" placeholder="****">
            <div id="setSecretError" class="text-danger small mt-2 d-none fw-semibold">Error</div>
          </div>
          <div class="modal-footer border-0 pt-0 justify-content-center">
            <button type="button" class="btn btn-primary w-100 rounded-pill py-2" onclick="setSecretKey()">Set PIN</button>
          </div>
        </div>

        <!-- View 2: Verify PIN -->
        <div id="view-verify-pin" class="d-none">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title text-center w-100 fw-bold">Enter PIN</h5>
            <button type="button" class="btn-close position-absolute" style="right: 15px; top: 15px;" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <p class="text-muted small mb-3">Provide your secret key to view total income</p>
            <input type="password" id="secretKeyInput" class="form-control text-center fs-3 fw-bold" style="letter-spacing: 0.5em; border-radius: 12px;" placeholder="****">
            <div id="secretError" class="text-danger small mt-2 d-none fw-semibold">Invalid secret key</div>
          </div>
          <div class="modal-footer border-0 pt-0 flex-column">
            <button type="button" class="btn btn-primary w-100 rounded-pill py-2 mb-2" onclick="verifySecretKey()">Verify & View</button>
            <a href="#" class="text-decoration-none small" onclick="showResetView(event)">Forgot PIN?</a>
          </div>
        </div>

        <!-- View 3: Reset PIN -->
        <div id="view-reset-pin" class="d-none">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title text-center w-100 fw-bold">Reset PIN</h5>
            <button type="button" class="btn-close position-absolute" style="right: 15px; top: 15px;" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="text-muted small text-center mb-3">Verify your account password</p>
            <input type="password" id="resetPasswordInput" class="form-control mb-3" placeholder="Account Password">
            <input type="password" id="resetNewPinInput" class="form-control text-center fs-4 fw-bold" style="letter-spacing: 0.5em; border-radius: 12px;" placeholder="New PIN">
            <div id="resetSecretError" class="text-danger small mt-2 d-none fw-semibold text-center">Error</div>
          </div>
          <div class="modal-footer border-0 pt-0 flex-column">
            <button type="button" class="btn btn-danger w-100 rounded-pill py-2 mb-2" onclick="resetSecretKey()">Reset PIN</button>
            <a href="#" class="text-decoration-none small text-muted" onclick="showVerifyView(event)">Back</a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // Tab Switching
    document.querySelectorAll('.sidebar-menu li[data-target]').forEach(li => {
      li.addEventListener('click', () => {
        document.querySelectorAll('.sidebar-menu li').forEach(el => el.classList.remove('active'));
        li.classList.add('active');
        
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.getElementById(li.getAttribute('data-target')).classList.add('active');
      });
    });

    // Modals
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }

    // Loader & Custom Alert
    function showLoader() { document.getElementById('pageLoader').classList.add('active'); }
    function hideLoader() { document.getElementById('pageLoader').classList.remove('active'); }

    function customAlert(message, title="Notice", type="alert") {
      return new Promise((resolve) => {
        document.getElementById('customAlertTitle').innerText = title;
        document.getElementById('customAlertMessage').innerText = message;
        const actions = document.getElementById('customAlertActions');
        
        if(type === 'confirm') {
          actions.innerHTML = `
            <button class="btn btn-outline" id="cAlertCancel">Cancel</button>
            <button class="btn btn-primary" id="cAlertConfirm">Confirm</button>
          `;
          document.getElementById('cAlertCancel').onclick = () => { closeCustomAlert(); resolve(false); };
          document.getElementById('cAlertConfirm').onclick = () => { closeCustomAlert(); resolve(true); };
        } else {
          actions.innerHTML = `<button class="btn btn-primary" id="cAlertOk">OK</button>`;
          document.getElementById('cAlertOk').onclick = () => { closeCustomAlert(); resolve(true); };
        }
        document.getElementById('customAlertModal').classList.add('active');
      });
    }

    function closeCustomAlert() {
      document.getElementById('customAlertModal').classList.remove('active');
    }

    // Disable button helper
    function disableButton(btn) {
      if(btn) {
        btn.disabled = true;
        btn.dataset.originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        btn.style.opacity = "0.7";
        btn.style.cursor = "not-allowed";
      }
    }
    function enableButton(btn) {
      if(btn) {
        btn.disabled = false;
        btn.innerHTML = btn.dataset.originalText || 'Submit';
        btn.style.opacity = "1";
        btn.style.cursor = "pointer";
      }
    }

    // Approve Flow
    function openApproveModal(txId, name, amount, type, pfId = '', upiId = '') {
      document.getElementById('app_txId').value = txId;
      document.getElementById('app_name').value = name;
      document.getElementById('app_amount').value = amount;
      document.getElementById('app_type').value = type;
      document.getElementById('app_pfId').value = pfId;
      
      const qrContainer = document.getElementById('qrCodeContainer');
      if (qrContainer) {
        if (upiId && upiId.includes('@')) {
          const upiUrl = `upi://pay?pa=${upiId}&pn=${encodeURIComponent(name)}&am=${amount}`;
          const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(upiUrl)}`;
          qrContainer.innerHTML = `<img src="${qrUrl}" alt="UPI QR Code" class="img-fluid rounded border p-2 mb-1" style="background: white;" />
                                   <div class="small fw-bold text-success">${upiId}</div>`;
          qrContainer.style.display = 'block';
        } else if (upiId) {
          qrContainer.innerHTML = `<div class="alert alert-secondary border small text-center m-0">Payment Details:<br><strong>${upiId}</strong></div>`;
          qrContainer.style.display = 'block';
        } else {
          qrContainer.style.display = 'none';
        }
      }
      
      document.getElementById('approveTitle').innerText = type === 'pf' ? 'Approve PF Withdrawal' : 'Approve Ambassador Withdrawal';
      document.getElementById('approveModal').classList.add('active');
    }

    document.getElementById('approveForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const txId = document.getElementById('app_txId').value;
      const type = document.getElementById('app_type').value;
      const pfId = document.getElementById('app_pfId').value;
      const amount = document.getElementById('app_amount').value;
      
      const payload = {
        title: document.getElementById('app_title').value,
        transactionId: document.getElementById('app_txnId').value,
        amount: amount,
        sendMail: document.getElementById('app_sendMail').checked
      };

      let url = type === 'pf' 
        ? `/superAdmin/payouts/admin/pf-approve/${txId}/${pfId}`
        : `/superAdmin/payouts/ambassador/approve/${txId}`;

      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('approveModal');
          await refreshPayoutData();
          await customAlert('Approved successfully!', 'Success');
        } else {
          await customAlert(data.message || 'Error occurred', 'Error');
          enableButton(btn);
        }
      } catch (err) {
        hideLoader();
        await customAlert('Server error', 'Error');
        enableButton(btn);
      }
    });

    // Reject Flows
    async function rejectTransaction(txId, type) {
      const confirmed = await customAlert('Are you sure you want to reject this request?', 'Confirm Action', 'confirm');
      if(!confirmed) return;
      
      showLoader();
      const url = `/superAdmin/payouts/ambassador/reject/${txId}`;
      try {
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          await refreshPayoutData();
        }
        else await customAlert(data.message, 'Error');
      } catch(e) { hideLoader(); await customAlert('Error', 'Error'); }
    }

    async function rejectPF(adminId, pfId) {
      const confirmed = await customAlert('Are you sure you want to reject this PF request?', 'Confirm Action', 'confirm');
      if(!confirmed) return;

      showLoader();
      const url = `/superAdmin/payouts/admin/pf-reject/${adminId}/${pfId}`;
      try {
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          await refreshPayoutData();
        }
        else await customAlert(data.message, 'Error');
      } catch(e) { hideLoader(); await customAlert('Error', 'Error'); }
    }

    // Payroll Flow
    function openEditPayrollModal(admin) {
      document.getElementById('pay_adminId').value = admin._id;
      document.getElementById('pay_name').value = admin.name;
      document.getElementById('pay_month').value = '';
      
      // Default to the most recent month if any, otherwise 0
      const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 
        ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] 
        : null;

      document.getElementById('pay_basic').value = latest?.basicSalary || 0;
      document.getElementById('pay_bonus').value = latest?.performanceBonus || 0;
      document.getElementById('pay_pf').value = latest?.providentFund || 0;
      document.getElementById('pay_tax').value = latest?.professionalTax || 0;
      document.getElementById('pay_upi').value = admin.upiId || '';
      
      document.getElementById('payrollModal').classList.add('active');
    }

    document.getElementById('payrollForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const adminId = document.getElementById('pay_adminId').value;
      const payload = {
        month: document.getElementById('pay_month').value,
        basicSalary: document.getElementById('pay_basic').value,
        performanceBonus: document.getElementById('pay_bonus').value,
        providentFund: document.getElementById('pay_pf').value,
        professionalTax: document.getElementById('pay_tax').value,
        upiId: document.getElementById('pay_upi').value,
      };

      try {
        const res = await fetch(`/superAdmin/payouts/admin/update-payroll/${adminId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('payrollModal');
          await refreshPayoutData();
          await customAlert('Payroll updated successfully!', 'Success');
        } else {
          await customAlert(data.message, 'Error');
          enableButton(btn);
        }
      } catch(err) { 
        hideLoader(); 
        await customAlert('Error', 'Error'); 
        enableButton(btn);
      }
    });

    let currentAdminPayroll = [];
    let currentSettleAdmin = null;

    function updateSettleCalculations() {
      const selectedMonth = document.getElementById('set_month').value;
      const p = currentAdminPayroll.find(m => m.month === selectedMonth);
      const qrContainer = document.getElementById('settleQrCodeContainer');
      
      if (p) {
        const gross = (p.basicSalary || 0) + (p.performanceBonus || 0);
        const ded = (p.providentFund || 0) + (p.professionalTax || 0);
        const net = gross - ded;
        document.getElementById('set_gross').innerText = `₹${gross.toFixed(2)}`;
        document.getElementById('set_ded').innerText = `₹${ded.toFixed(2)}`;
        document.getElementById('set_net').innerText = `₹${net.toFixed(2)}`;
        document.getElementById('set_title').value = `Salary for ${selectedMonth}`;
        
        if (qrContainer && currentSettleAdmin) {
          const upiId = currentSettleAdmin.upiId;
          if (upiId && upiId.includes('@')) {
            const upiUrl = `upi://pay?pa=${upiId}&pn=${encodeURIComponent(currentSettleAdmin.name)}&am=${net}`;
            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(upiUrl)}`;
            qrContainer.innerHTML = `<img src="${qrUrl}" alt="UPI QR Code" class="img-fluid rounded border p-2 mb-1" style="background: white;" />
                                     <div class="small fw-bold text-success">${upiId}</div>`;
            qrContainer.style.display = 'block';
          } else if (upiId) {
            qrContainer.innerHTML = `<div class="alert alert-secondary border small text-center m-0">UPI ID:<br><strong>${upiId}</strong></div>`;
            qrContainer.style.display = 'block';
          } else {
            qrContainer.style.display = 'none';
          }
        }
      } else {
        document.getElementById('set_gross').innerText = `₹0.00`;
        document.getElementById('set_ded').innerText = `₹0.00`;
        document.getElementById('set_net').innerText = `₹0.00`;
        document.getElementById('set_title').value = ``;
        if (qrContainer) qrContainer.style.display = 'none';
      }
    }

    function openSettleSalaryModal(admin) {
      currentSettleAdmin = admin;
      document.getElementById('set_adminId').value = admin._id;
      document.getElementById('set_name').value = admin.name;
      
      currentAdminPayroll = admin.monthlyPayroll || [];
      const monthSelect = document.getElementById('set_month');
      monthSelect.innerHTML = '<option value="">Select a month...</option>';
      
      // Sort months descending
      const sortedPayroll = [...currentAdminPayroll].sort((a,b) => b.month.localeCompare(a.month));
      
      sortedPayroll.forEach(p => {
        monthSelect.innerHTML += `<option value="${p.month}">${p.month}</option>`;
      });

      document.getElementById('set_gross').innerText = `₹0.00`;
      document.getElementById('set_ded').innerText = `₹0.00`;
      document.getElementById('set_net').innerText = `₹0.00`;
      document.getElementById('set_title').value = ``;
      document.getElementById('set_txnId').value = ``;

      document.getElementById('settleModal').classList.add('active');
    }

    document.getElementById('settleForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const adminId = document.getElementById('set_adminId').value;
      const payload = {
        month: document.getElementById('set_month').value,
        title: document.getElementById('set_title').value,
        transactionId: document.getElementById('set_txnId').value,
        sendMail: document.getElementById('set_sendMail').checked
      };

      try {
        const res = await fetch(`/superAdmin/payouts/admin/settle/${adminId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        hideLoader();
        if(data.success) {
          closeModal('settleModal');
          await refreshPayoutData();
          await customAlert('Salary settled successfully!', 'Success');
        } else {
          await customAlert(data.message, 'Error');
          enableButton(btn);
        }
      } catch(err) { 
        hideLoader(); 
        await customAlert('Error', 'Error'); 
        enableButton(btn);
      }
    });

    // Secret Modal Logic
    let hasSecretKey = document.getElementById('secretModal').getAttribute('data-has-secret') === 'true';

    let cachedTotalIncome = null;
    let cachedAvailableBalance = null;
    let activeToggleTarget = null;

    function toggleSecretVisibility(target) {
      let el = null;
      let icon = null;
      let cachedValue = null;

      if (target === 'income') {
        el = document.getElementById('totalIncomeValue');
        icon = document.getElementById('totalIncomeIcon');
        cachedValue = cachedTotalIncome;
      } else if (target === 'balance') {
        el = document.getElementById('availableBalanceValue');
        icon = document.getElementById('availableBalanceIcon');
        cachedValue = cachedAvailableBalance;
      }

      if (!el) return;

      if (el.innerText !== '*****') {
        el.innerText = '*****';
        if (icon) {
          icon.classList.remove('bi-eye-slash');
          icon.classList.add('bi-eye');
        }
      } else {
        if (cachedValue !== null) {
          el.innerText = cachedValue;
          if (icon) {
            icon.classList.remove('bi-eye');
            icon.classList.add('bi-eye-slash');
          }
        } else {
          activeToggleTarget = target;
          openSecretModal();
        }
      }
    }

    function openSecretModal() {
      // Reset fields
      document.getElementById('secretKeyInput').value = '';
      document.getElementById('newSecretKeyInput').value = '';
      document.getElementById('resetPasswordInput').value = '';
      document.getElementById('resetNewPinInput').value = '';
      
      document.getElementById('secretError').classList.add('d-none');
      document.getElementById('setSecretError').classList.add('d-none');
      document.getElementById('resetSecretError').classList.add('d-none');

      if (hasSecretKey) {
        showVerifyView();
      } else {
        showSetView();
      }
      getModal('secretModal').show();
    }

    function showSetView() {
      document.getElementById('view-set-pin').classList.remove('d-none');
      document.getElementById('view-verify-pin').classList.add('d-none');
      document.getElementById('view-reset-pin').classList.add('d-none');
    }

    function showVerifyView(e) {
      if(e) e.preventDefault();
      document.getElementById('view-set-pin').classList.add('d-none');
      document.getElementById('view-verify-pin').classList.remove('d-none');
      document.getElementById('view-reset-pin').classList.add('d-none');
    }

    function showResetView(e) {
      if(e) e.preventDefault();
      document.getElementById('view-set-pin').classList.add('d-none');
      document.getElementById('view-verify-pin').classList.add('d-none');
      document.getElementById('view-reset-pin').classList.remove('d-none');
    }

    async function setSecretKey() {
      const newSecret = document.getElementById('newSecretKeyInput').value;
      if (!newSecret || newSecret.length < 4) {
        const errEl = document.getElementById('setSecretError');
        errEl.innerText = 'PIN must be at least 4 digits';
        errEl.classList.remove('d-none');
        return;
      }

      const btn = document.querySelector('#view-set-pin .btn-primary');
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Saving...';
      btn.disabled = true;

      try {
        const res = await axios.post('/superAdmin/payouts/set-secret', { new_secret: newSecret });
        if(res.data.success) {
          hasSecretKey = true;
          document.getElementById('secretModal').setAttribute('data-has-secret', 'true');
          showVerifyView();
        }
      } catch(err) {
        const errEl = document.getElementById('setSecretError');
        errEl.innerText = err.response?.data?.message || 'Error setting PIN';
        errEl.classList.remove('d-none');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

    async function verifySecretKey() {
      const secret = document.getElementById('secretKeyInput').value;
      if(!secret) return;
      
      const btn = document.querySelector('#view-verify-pin .btn-primary');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Verifying...';
      btn.disabled = true;

      try {
        const res = await axios.post('/superAdmin/payouts/verify-secret', { secret_key: secret });
        if(res.data.success) {
          cachedTotalIncome = Number(res.data.totalIncome).toFixed(2);
          cachedAvailableBalance = Number(res.data.availableBalance).toFixed(2);
          
          if (activeToggleTarget === 'income') {
            document.getElementById('totalIncomeValue').innerText = cachedTotalIncome;
            const icon = document.getElementById('totalIncomeIcon');
            if(icon) {
              icon.classList.remove('bi-eye');
              icon.classList.add('bi-eye-slash');
            }
          } else if (activeToggleTarget === 'balance') {
            const abEl = document.getElementById('availableBalanceValue');
            if (abEl) abEl.innerText = cachedAvailableBalance;
            const icon = document.getElementById('availableBalanceIcon');
            if(icon) {
              icon.classList.remove('bi-eye');
              icon.classList.add('bi-eye-slash');
            }
          }
          getModal('secretModal').hide();
        }
      } catch(err) {
        document.getElementById('secretError').innerText = err.response?.data?.message || "Invalid secret key";
        document.getElementById('secretError').classList.remove('d-none');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

    async function resetSecretKey() {
      const password = document.getElementById('resetPasswordInput').value;
      const newSecret = document.getElementById('resetNewPinInput').value;
      
      if (!password || !newSecret || newSecret.length < 4) {
        const errEl = document.getElementById('resetSecretError');
        errEl.innerText = 'Password and new 4-digit PIN required';
        errEl.classList.remove('d-none');
        return;
      }

      const btn = document.querySelector('#view-reset-pin .btn-danger');
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Resetting...';
      btn.disabled = true;

      try {
        const res = await axios.post('/superAdmin/payouts/reset-secret', { password, new_secret: newSecret });
        if(res.data.success) {
          await customAlert('PIN reset successfully!', 'Success');
          showVerifyView();
        }
      } catch(err) {
        const errEl = document.getElementById('resetSecretError');
        errEl.innerText = err.response?.data?.message || 'Error resetting PIN';
        errEl.classList.remove('d-none');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

    // Expenditure Form Logic
    document.getElementById('expenditureForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();

      const payload = {
        title: document.getElementById('exp_title').value,
        amount: document.getElementById('exp_amount').value,
        date: document.getElementById('exp_date').value,
        txnId: document.getElementById('exp_txnId').value,
        description: document.getElementById('exp_description').value
      };

      try {
        const res = await axios.post('/superAdmin/payouts/expenditure', payload);
        if(res.data.success) {
          e.target.reset();
          await refreshPayoutData();
          await customAlert('Expenditure added successfully!', 'Success');
          document.getElementById('expenditure-history-tab').click();
        }
      } catch(err) {
        console.error(err);
        await customAlert(err.response?.data?.message || 'Error adding expenditure', 'Error');
      } finally {
        enableButton(btn);
        hideLoader();
      }
    });

    // Intern Redemption Logic
    function openApproveRedemptionModal(id, name, reward) {
      document.getElementById('red_id').value = id;
      document.getElementById('red_name').value = name;
      document.getElementById('red_reward').value = reward;
      document.getElementById('red_money').value = '';
      document.getElementById('red_code').value = '';
      document.getElementById('red_title').value = reward + ' Redemption';
      document.getElementById('red_txnId').value = '';
      
      getModal('approveRedemptionModal').show();
    }

    document.getElementById('approveRedemptionForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      disableButton(btn);
      showLoader();
      const id = document.getElementById('red_id').value;
      const payload = {
        moneySpent: document.getElementById('red_money').value,
        voucherCode: document.getElementById('red_code').value,
        title: document.getElementById('red_title').value,
        transactionId: document.getElementById('red_txnId').value,
        sendMail: document.getElementById('red_sendMail').checked
      };

      try {
        const res = await axios.post(`/superAdmin/payouts/intern/approve-redemption/${id}`, payload);
        if(res.data.success) {
          closeModal('approveRedemptionModal');
          e.target.reset();
          await customAlert('Redemption approved successfully!', 'Success');
          // Hide row visually
          const row = document.getElementById(`row-red-${id}`);
          if (row) row.style.display = 'none';
          const card = document.getElementById(`card-red-${id}`);
          if (card) card.style.display = 'none';
        }
      } catch(err) {
        console.error(err);
        await customAlert(err.response?.data?.message || 'Error processing redemption', 'Error');
      } finally {
        enableButton(btn);
        hideLoader();
      }
    });

    async function rejectRedemption(id) {
      const confirmAction = await customAlert('Are you sure you want to reject this request? Points will be refunded to the intern.', 'Confirm Rejection', 'confirm');
      if(confirmAction) {
        showLoader();
        try {
          const res = await axios.post(`/superAdmin/payouts/intern/reject-redemption/${id}`);
          if(res.data.success) {
            await customAlert('Redemption rejected.', 'Success');
            const row = document.getElementById(`row-red-${id}`);
            if (row) row.style.display = 'none';
            const card = document.getElementById(`card-red-${id}`);
            if (card) card.style.display = 'none';
          }
        } catch(err) {
          console.error(err);
          await customAlert(err.response?.data?.message || 'Error rejecting request', 'Error');
        } finally {
          hideLoader();
        }
      }
    }

  </script>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    // SweetAlert for custom alert
    function customAlert(message, title="Notice", type="alert") {
      return new Promise((resolve) => {
        if(type === 'confirm') {
          Swal.fire({
            title: title,
            text: message,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff6600',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Confirm'
          }).then((result) => {
            resolve(result.isConfirmed);
          });
        } else {
          Swal.fire({
            title: title,
            text: message,
            icon: type === 'Error' ? 'error' : 'success',
            confirmButtonColor: '#ff6600'
          }).then(() => {
            resolve(true);
          });
        }
      });
    }

    // Map custom modals to bootstrap modals
    let modalsMap = {};
    function getModal(id) {
      if(!modalsMap[id]) {
        const el = document.getElementById(id);
        if(el) modalsMap[id] = new bootstrap.Modal(el);
      }
      return modalsMap[id];
    }
    
    const originalOpenApprove = typeof openApproveModal === 'function' ? openApproveModal : null;
    window.openApproveModal = function(txId, name, amount, type, pfId = '', upiId = '') {
      document.getElementById('app_txId').value = txId;
      document.getElementById('app_name').value = name;
      document.getElementById('app_amount').value = amount;
      document.getElementById('app_type').value = type;
      document.getElementById('app_pfId').value = pfId;
      
      const qrContainer = document.getElementById('qrCodeContainer');
      if (qrContainer) {
        if (upiId && upiId.includes('@')) {
          const upiUrl = `upi://pay?pa=${upiId}&pn=${encodeURIComponent(name)}&am=${amount}`;
          const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(upiUrl)}`;
          qrContainer.innerHTML = `<img src="${qrUrl}" alt="UPI QR Code" class="img-fluid rounded border p-2 mb-1" style="background: white;" />
                                   <div class="small fw-bold text-success">${upiId}</div>`;
          qrContainer.style.display = 'block';
        } else if (upiId) {
          qrContainer.innerHTML = `<div class="alert alert-secondary border small text-center m-0">Payment Details:<br><strong>${upiId}</strong></div>`;
          qrContainer.style.display = 'block';
        } else {
          qrContainer.style.display = 'none';
        }
      }
      
      document.getElementById('approveTitle').innerText = type === 'pf' ? 'Approve PF Withdrawal' : 'Approve Ambassador Withdrawal';
      getModal('approveModal').show();
    };
    
    const originalOpenEdit = typeof openEditPayrollModal === 'function' ? openEditPayrollModal : null;
    window.openEditPayrollModal = function(admin) {
      document.getElementById('pay_adminId').value = admin._id;
      document.getElementById('pay_name').value = admin.name;
      document.getElementById('pay_month').value = '';
      const latest = admin.monthlyPayroll && admin.monthlyPayroll.length > 0 ? admin.monthlyPayroll[admin.monthlyPayroll.length - 1] : null;
      document.getElementById('pay_basic').value = latest?.basicSalary || 0;
      document.getElementById('pay_bonus').value = latest?.performanceBonus || 0;
      document.getElementById('pay_pf').value = latest?.providentFund || 0;
      document.getElementById('pay_tax').value = latest?.professionalTax || 0;
      document.getElementById('pay_upi').value = admin.upiId || '';
      getModal('payrollModal').show();
    };

    const originalOpenSettle = typeof openSettleSalaryModal === 'function' ? openSettleSalaryModal : null;
    window.openSettleSalaryModal = function(admin) {
      currentSettleAdmin = admin;
      document.getElementById('set_adminId').value = admin._id;
      document.getElementById('set_name').value = admin.name;
      currentAdminPayroll = admin.monthlyPayroll || [];
      const monthSelect = document.getElementById('set_month');
      monthSelect.innerHTML = '<option value="">Select a month...</option>';
      const sortedPayroll = [...currentAdminPayroll].sort((a,b) => b.month.localeCompare(a.month));
      sortedPayroll.forEach(p => { 
        const [yyyy, mm] = p.month.split('-');
        const date = new Date(yyyy, mm - 1);
        const display = date.toLocaleString('default', { month: 'long', year: 'numeric' });
        monthSelect.innerHTML += `<option value="${p.month}">${display}</option>`; 
      });
      document.getElementById('set_gross').innerText = `₹0.00`;
      document.getElementById('set_ded').innerText = `₹0.00`;
      document.getElementById('set_net').innerText = `₹0.00`;
      document.getElementById('set_title').value = ``;
      document.getElementById('set_txnId').value = ``;
      getModal('settleModal').show();
    };
    
    window.closeModal = function(id) {
       getModal(id).hide();
    }
    
    // Sidebar toggle
    document.getElementById('sidebarToggle').addEventListener('click', function() {
      document.getElementById('sidebar').classList.toggle('active');
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('active');
    });
    document.getElementById('sidebarOverlay').addEventListener('click', function() {
      document.getElementById('sidebar').classList.remove('active', 'open');
      this.classList.remove('active');
    });

    // Flatpickr for month picking
    flatpickr("#pay_month", {
      plugins: [
        new monthSelectPlugin({
          shorthand: true,
          dateFormat: "Y-m", 
          altFormat: "F Y"
        })
      ],
      altInput: true
    });
  
    // Global function to refresh data without reloading
    window.refreshPayoutData = async function() {
      try {
        const res = await fetch(window.location.href);
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        
        const activeTabLink = document.querySelector('.sidebar-nav .nav-link.active');
        const activeTabId = activeTabLink ? activeTabLink.getAttribute('data-bs-target') : '#tab-dashboard';
        
        const newContent = doc.getElementById('payoutTabsContent');
        if(newContent) {
          document.getElementById('payoutTabsContent').innerHTML = newContent.innerHTML;
        }
        
        document.querySelectorAll('#payoutTabsContent .tab-pane').forEach(pane => {
          pane.classList.remove('show', 'active');
        });
        const activePane = document.querySelector(activeTabId);
        if(activePane) activePane.classList.add('show', 'active');
        
        if (typeof initPayoutCharts === 'function') initPayoutCharts();
      } catch (e) {
        console.error("Error refreshing data dynamically", e);
      }
    };

    // Analytics Charts Logic
    let doughnutChart = null;
    let lineChart = null;

    window.initPayoutCharts = function() {
      const dataEl = document.getElementById('payoutDataJSON');
      if (!dataEl) return;
      const parsedData = JSON.parse(dataEl.textContent);
      const transactions = parsedData.transactions;
      const interns = parsedData.interns;
      const expenditures = parsedData.expenditures || [];
      const redemptionRequests = parsedData.redemptionRequests || [];
      
      // Data Processing for Doughnut Chart
      let ambassadorTotal = 0;
      let adminTotal = 0;
      let pfTotal = 0;
      let expTotal = 0;
      let redTotal = 0;
      let certIncomeTotal = 0;
      
      const monthlyData = {};
      const monthlyIncomeData = {};
      
      // Initialize last 6 months in order
      const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      const d = new Date();
      d.setDate(1);
      const last6Months = [];
      for (let i = 5; i >= 0; i--) {
        const temp = new Date(d.getFullYear(), d.getMonth() - i, 1);
        const label = monthNames[temp.getMonth()] + " " + temp.getFullYear().toString().slice(-2);
        last6Months.push(label);
        monthlyData[label] = 0;
        monthlyIncomeData[label] = 0;
      }

      transactions.forEach(t => {
        if (t.status === "Approved") {
          // Process Distribution
          if (t.type === "AmbassadorWithdrawal") ambassadorTotal += t.amount;
          else if (t.type === "AdminSalary") adminTotal += t.amount;
          else if (t.type === "PFWithdrawal") pfTotal += t.amount;
          else if (t.type === "CertificatePurchase") certIncomeTotal += t.amount;
          
          // Process Monthly Trend
          const dateStr = t.processedAt || t.requestedAt;
          if (dateStr) {
            const date = new Date(dateStr);
            const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
            if (monthlyData[label] !== undefined) {
              if (t.type === "CertificatePurchase") {
                monthlyIncomeData[label] += t.amount;
              } else {
                monthlyData[label] += t.amount;
              }
            }
          }
        }
      });

      interns.forEach(intern => {
        let date = null;
        if (intern.joining_date || intern.createdAt) {
           date = new Date(intern.joining_date || intern.createdAt);
        } else if (intern.batch_no) {
           const parsed = new Date(intern.batch_no);
           if (!isNaN(parsed)) date = parsed;
        }
        if (date) {
           const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
           if (monthlyIncomeData[label] !== undefined) {
             monthlyIncomeData[label] += (intern.amountPaid || 0);
           }
        }
      });

      expenditures.forEach(exp => {
        expTotal += exp.amount || 0;
        if (exp.date) {
            const date = new Date(exp.date);
            const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
            if (monthlyData[label] !== undefined) {
              monthlyData[label] += exp.amount || 0;
            }
        }
      });

      redemptionRequests.forEach(r => {
        if (r.status === "Approved") {
          const moneySpent = r.moneySpent || 0;
          redTotal += moneySpent;
          if (r.processedAt) {
            const date = new Date(r.processedAt);
            const label = monthNames[date.getMonth()] + " " + date.getFullYear().toString().slice(-2);
            if (monthlyData[label] !== undefined) {
              monthlyData[label] += moneySpent;
            }
          }
        }
      });

      // Render Doughnut Chart
      const doughnutCtx = document.getElementById('payoutDoughnutChart');
      if (doughnutCtx) {
        if(doughnutChart) doughnutChart.destroy();
        doughnutChart = new Chart(doughnutCtx, {
          type: 'doughnut',
          data: {
            labels: ['Ambassadors', 'Admin Salary', 'PF Withdrawals', 'Expenditures', 'Intern Redeemed'],
            datasets: [{
              data: [ambassadorTotal, adminTotal, pfTotal, expTotal, redTotal],
              backgroundColor: ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#06b6d4'],
              borderWidth: 0,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: { color: '#888', padding: 20, font: { family: 'Montserrat' } }
              }
            },
            cutout: '75%'
          }
        });
      }

      // Render Line Chart
      const lineCtx = document.getElementById('payoutLineChart');
      if (lineCtx) {
        if(lineChart) lineChart.destroy();
        lineChart = new Chart(lineCtx, {
          type: 'line',
          data: {
            labels: last6Months,
            datasets: [
              {
                label: 'Income (₹)',
                data: last6Months.map(m => monthlyIncomeData[m]),
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4
              },
              {
                label: 'Payouts (₹)',
                data: last6Months.map(m => monthlyData[m]),
                borderColor: '#ef4444',
                backgroundColor: 'rgba(239, 68, 68, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { 
                display: true, 
                position: 'top', 
                labels: { color: '#888', font: { family: 'Montserrat' } } 
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                ticks: { color: '#888', font: { family: 'Montserrat' } }
              },
              x: {
                grid: { display: false, drawBorder: false },
                ticks: { color: '#888', font: { family: 'Montserrat' } }
              }
            }
          }
        });
      }
    };

    document.addEventListener("DOMContentLoaded", function() {
      initPayoutCharts();
      
      document.querySelectorAll('.sidebar-nav .nav-link').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 768) {
            document.getElementById('sidebar').classList.remove('active', 'open');
            document.getElementById('sidebarOverlay').classList.remove('active');
          }
        });
      });
    });
  </script>
</body>
</html>
  