  <script>
    function copyQrLink(empId, signature) {
      if (!empId) {
        showToast("Employee ID is missing for this admin.", "error");
        return;
      }
      const qrUrl = window.location.origin + "/profile/" + empId + "?sig=" + signature;
      navigator.clipboard.writeText(qrUrl).then(() => {
        showToast("QR Link copied to clipboard!", "success");
      }).catch(err => {
        console.error("Failed to copy link: ", err);
        showToast("Failed to copy link. Check console for details.", "error");
      });
    }

    // Global Modal Fix: Append all modals to body to prevent them from being trapped inside overflow containers
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.modal').forEach(modal => {
        document.body.appendChild(modal);
      });
    });
