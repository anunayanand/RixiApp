          <% 
          let serialNo = 1;
          interns.filter(i => i.isPassed && !i.completionSent).forEach(i => { 
          %>
            <tr data-status="<%= i.completionSent ? 'sent' : 'notSent' %>"
                data-batch="<%= i.batch_no %>" 
