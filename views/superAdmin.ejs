            </td>
          </tr>
          <!-- No data available message -->
          <tr id="noDataMessage" style="display: none;">
            <td colspan="5" class="text-center py-5 text-muted">
              <i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>
              No data available
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </form>
</section>

