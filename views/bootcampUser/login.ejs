<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>Bootcamp Login | Rixi Lab Technologies</title>
  <meta name="description" content="">
  <meta name="keywords" content="">

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon">
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
    rel="stylesheet">
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&family=Special+Elite&display=swap"
    rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/js/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/js/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
  <link href="/js/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="/css/main.css" rel="stylesheet">
  <link href="/css/validation.css" rel="stylesheet">

  <style>
          .login-tab-switcher {
            display: flex;
            justify-content: center;
            gap: 0;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,102,0,0.25);
            border-radius: 50px;
            padding: 5px;
            max-width: 380px;
            margin: 0 auto;
          }
          .login-tab {
            flex: 1;
            padding: 9px 18px;
            border: none;
            border-radius: 50px;
            background: transparent;
            color: #aaa;
            font-size: 0.82rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
            letter-spacing: 0.03em;
          }
          .login-tab i {
            margin-right: 5px;
          }
          .login-tab.active {
            background: linear-gradient(135deg, #ff6600, #ff8c00);
            color: #fff;
            box-shadow: 0 4px 14px rgba(255,102,0,0.4);
          }
          .login-tab:hover:not(.active) {
            color: #ff6600;
            background: rgba(255,102,0,0.08);
          }
          .form-subtitle {
            color: #ff6600;
            font-size: 0.78rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin: 4px 0 0;
            font-weight: 600;
          }
          .bootcamp-login-icon {
            animation: pulse-icon 2s ease-in-out infinite;
          }
          @keyframes pulse-icon {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.08); opacity: 0.85; }
          }
          #loginForm, #bootcampPanel {
            transition: opacity 0.3s ease;
          }
        </style>
</head>

<body class="index-page">
  <%- include('../partials/loader') %>
    <header id="header" class="header d-flex align-items-center fixed-top">
      <div class="container position-relative d-flex align-items-center justify-content-between">

        <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
          <img src="/img/New Web Logo.svg" alt="" style="min-height: 55px; max-height: 55px; margin-left: 0px;">  
        </a>

        <nav id="navmenu" class="navmenu">
          <ul>
            <li><a href="/" class="active">Home</a></li>
            <li><a href="/internship">Internship</a></li>
            <li><a href="/cap">CAP</a></li>
            <li><a href="/#about">About</a></li>
            <li><a href="/#services">Services</a></li>
            <li><a href="/bootcamp">Bootcamps</a></li>
            <li><a href="/certificate">Certificate</a></li>
            <li><a href="/#contact" style="color: white !important;">Contact</a></li>
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        <a class="btn-getstarted" href="/internship">Internship</a>

      </div>
    </header>

    <main class="main "><br><br>
      <section id="contact" class="contact section ">
        <div class="container  section-title" data-aos="fade-up">
          <h2>Bootcamp Login</h2>
        </div>

          <div class="container mb-4" data-aos="fade-up" data-aos-delay="50">
          <div class="login-tab-switcher">
            <button class="login-tab" id="tab-intern" onclick="window.location.href='/login'">
              <i class="bi bi-person-badge"></i> Intern
            </button>
            <button class="login-tab" id="tab-ambassador" onclick="window.location.href='/login'">
              <i class="bi bi-star"></i> Ambassador
            </button>
            <!-- <button class="login-tab" id="tab-bootcamp" onclick="switchTab('bootcamp')"> -->
            <a class="login-tab active" id="tab-bootcamp" >
              <i class="bi bi-laptop"></i> Bootcamp
            </a>
          </div>
        </div>

        <div class="container" data-aos="fade-up" data-aos-delay="100">
          <div class="row d-flex justify-content-center">
            <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
              <div class="contact-form-wrapper">
                <div class="form-header">
                  <h3>Enter your registered email <br> to receive an OTP</h3>
                </div>

                <% if(messages && messages.error) { %>
                  <div class="alert alert-danger text-center border-0 rounded-3"><%= messages.error %></div>
                <% } %>

                <form class="php-email-form needs-validation" action="/bootcamp-portal/send-otp" method="POST" novalidate>
                  <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" placeholder="Enter your email address" required>
                  </div>

                  <div class="mb-2 text-center" id="errorMsg"></div>

                  <button type="submit" class="submit-btn">
                    <span>Send Secure OTP</span>
                    <i class="bi bi-arrow-right"></i>
                  </button>
                </form>

              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <%- include("../partials/toaster") %>
      <%- include("../partials/smallFooter") %>

      <!-- Scroll Top -->
      <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

      <!-- Vendor JS Files -->
      <script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
      <script src="/js/vendor/aos/aos.js"></script>
      <script src="/js/vendor/glightbox/js/glightbox.min.js"></script>
      <script src="/js/vendor/purecounter/purecounter_vanilla.js"></script>
      <script src="/js/vendor/typed.js/typed.umd.js"></script>
      <script src="/js/vendor/swiper/swiper-bundle.min.js"></script>

      <!-- Main JS File -->
      <script src="/js/main.js"></script>

      <nav class="mobile-bottom-nav d-xl-none">
        <a href="/" class="bottom-nav-item">
          <i class="bi bi-house"></i><span>Home</span>
        </a>
        <a href="/internship" class="bottom-nav-item">
          <i class="bi bi-laptop"></i><span>Internship</span>
        </a>
        <a href="/cap" class="bottom-nav-item">
          <i class="bi bi-mortarboard"></i><span>CAP</span>
        </a>
        <a href="/certificate" class="bottom-nav-item">
          <i class="bi bi-award"></i><span>Certificate</span>
        </a>
        <a href="/bootcamp-portal/login" class="bottom-nav-item active">
          <i class="bi bi-person"></i><span>Login</span>
        </a>
      </nav>
</body>
</html>
