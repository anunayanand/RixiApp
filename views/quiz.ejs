  <script>
  async function takeScreenshotAndUpload() {
  const video = document.getElementById('userVideo');
  if (!video || video.readyState < 2) return;

  const canvas = document.createElement('canvas');
  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;

  const ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

  // Convert canvas to Blob
  canvas.toBlob(async (blob) => {
    if (!blob) return;

    const formData = new FormData();
    formData.append("screenshot", blob, "screenshot.png");
    formData.append("intern_id", "<%= intern._id %>");

    try {
      const res = await fetch("/upload-screenshot", {
        method: "POST",
        body: formData
      });

      const data = await res.json();
      console.log("Screenshot Uploaded:", data);
    } catch (err) {
      console.error("Screenshot upload failed", err);
    }
  }, "image/png");
}

  </script>
  <script>
    function isMobileDevice() {
      // Check User Agent
      if (/Mobi|Android|iPhone|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
        return true;
      }
      
      // Check iPad specifically (some newer iPads report as MacIntel but have touch)
      if (/iPad/i.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1)) {
        return true;
      }

      if (navigator.userAgentData && navigator.userAgentData.mobile) {
        return true;
      }

      // Check screen width (tablets commonly up to 1024px, we want strictly desktop)
      if (window.innerWidth <= 1024 || screen.width <= 1024) {
        return true;
      }

      return false;
    }

    // Immediately block if not desktop
    if (isMobileDevice()) {
      window.location.replace("/mobile-blocked"); // Use replace to prevent back navigation
    }
    
    // Also re-check on resize in case they resize DevTools or window
    window.addEventListener('resize', () => {
      if (window.innerWidth <= 1024 && quizStarted) {
        document.body.innerHTML = '<div style="background:var(--body-bg); height:100vh; display:flex; align-items:center; justify-content:center; color:white; font-family:Inter; font-size:1.5rem; text-align:center; padding:2rem;">Quiz is only accessible on Desktop in Fullscreen mode.</div>';
        setTimeout(() => window.location.replace("/mobile-blocked"), 2000);
      }
    });

  </script>



<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.12.0"></script>
<script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/face-detection@1.0.3"></script>
<script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/face-detection/dist/face-detection.min.js"></script>

<script>
let detector;
let faceMissingSince = null;
let warningShown = false;
let violationCount = 0;

const video = document.getElementById("userVideo");
const warningSound = document.getElementById("warningSound");

// ✅ Create warning box
const warningBox = document.createElement("div");
warningBox.style.position = "fixed";
warningBox.style.bottom = "20px";
warningBox.style.right = "20px";
warningBox.style.background = "rgba(255, 0, 0, 0.85)";
warningBox.style.color = "#fff";
warningBox.style.padding = "12px 18px";
warningBox.style.borderRadius = "8px";
warningBox.style.fontSize = "14px";
warningBox.style.fontWeight = "600";
warningBox.style.zIndex = "9999";
warningBox.style.display = "none";
warningBox.innerText = "⚠ Face not detected! Please stay visible.";
document.body.appendChild(warningBox);

// ✅ Start webcam
async function startCamera() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;
  } catch (err) {
    console.error("Camera error:", err);
  }
}

// ✅ Load TensorFlow face detector
async function loadFaceDetector() {
  console.log("⏳ Loading face detector model...");
  detector = await faceDetection.createDetector(
    faceDetection.SupportedModels.MediaPipeFaceDetector,
    { runtime: "tfjs", maxFaces: 1 }
  );
  console.log("✅ Face detection model loaded.");
}

// ✅ Monitor face
async function monitorFace() {
  if (!detector || video.readyState < 2) return;

  try {
    const faces = await detector.estimateFaces(video, { flipHorizontal: false });

    if (faces.length > 0) {
      // Face detected → reset everything
      warningBox.style.display = "none";
      faceMissingSince = null;
      warningShown = false;
      warningSound.pause();
      warningSound.currentTime = 0;
      video.style.border = "1px solid #ff6600";
    } else {
      // Face not detected
      if (!faceMissingSince) faceMissingSince = Date.now();
      const secondsAbsent = (Date.now() - faceMissingSince) / 1000;

      if (secondsAbsent > 3 && !warningShown) { // 3 seconds threshold
        warningShown = true;
        warningSound.loop = true;
        warningSound.play().catch(() => {});
        warningBox.style.display = "block";
        violationCount++;
        console.warn(`⚠ Face missing for ${secondsAbsent.toFixed(1)}s (violation ${violationCount})`);
      }
      if (secondsAbsent > 10) { // auto-submit after 10 sec
        warningBox.innerText = "🚨 Face absent for too long. Quiz auto-submitting.";
        warningSound.pause();
        warningSound.currentTime = 0;
        setTimeout(() => document.getElementById("quizForm").submit(), 2000);
      }

      video.style.border = "3px solid red";

      if (violationCount >= 3) {
        warningBox.innerText = "🚨 Multiple face absences detected. Quiz auto-submitting.";
        warningSound.pause();
        warningSound.currentTime = 0;
        setTimeout(() => document.getElementById("quizForm").submit(), 3000);
      }
    }
  } catch (err) {
    console.error("Face detection error:", err);
  }
}

// ✅ Start monitoring
async function startFaceMonitoring() {
  await loadFaceDetector();
  setInterval(monitorFace, 1000); // check every 1 second
}

// 🔗 Start quiz button
document.getElementById("startQuizBtn").addEventListener("click", async () => {
  await startCamera();
  setTimeout(() => startFaceMonitoring(), 2000); // wait for camera to start
});
</script>

