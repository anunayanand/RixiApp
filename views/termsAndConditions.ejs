    .legal-content-wrapper {
      padding-left: 30px;
    }

    .legal-section-card {
      background: var(--card-bg);
      border: 1px solid rgba(255, 255, 255, 0.03);
      border-radius: 24px;
      padding: 40px;
      margin-bottom: 40px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .legal-section-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 20px rgba(255,102,0,0.05);
      border-color: rgba(255,102,0,0.15);
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 25px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .section-number {
      background: linear-gradient(135deg, rgba(255, 102, 0, 0.2) 0%, rgba(255, 102, 0, 0.05) 100%);
      color: var(--brand-color);
      min-width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      font-weight: 800;
      font-size: 1.2rem;
      border: 1px solid rgba(255, 102, 0, 0.2);
    }

    .legal-section-card h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
      margin: 0;
      letter-spacing: -0.5px;
    }

    .legal-section-card p, .legal-section-card li {
      color: var(--text-muted);
      line-height: 1.8;
      font-size: 1.05rem;
      margin-bottom: 15px;
    }

    .legal-section-card h3 {
      font-size: 1.3rem;
      font-weight: 600;
      color: #fff;
      margin-top: 30px;
      margin-bottom: 15px;
    }

    .legal-section-card ul, .legal-section-card ol {
      padding-left: 20px;
      margin-bottom: 20px;
    }

    .legal-section-card li {
      margin-bottom: 10px;
    }

    .legal-section-card a {
      color: var(--brand-color);
      text-decoration: none;
      position: relative;
      font-weight: 500;
    }
    
    .legal-section-card a::after {
      content: '';
      position: absolute;
      width: 100%;
      transform: scaleX(0);
      height: 1px;
      bottom: -2px;
      left: 0;
      background-color: var(--brand-color);
      transform-origin: bottom right;
      transition: transform 0.25s ease-out;
    }
    
    .legal-section-card a:hover::after {
      transform: scaleX(1);
      transform-origin: bottom left;
    }

    .contact-box {
      background: linear-gradient(135deg, rgba(255, 102, 0, 0.1) 0%, rgba(20, 20, 20, 0) 100%);
      border: 1px solid rgba(255, 102, 0, 0.2);
      border-radius: 16px;
      padding: 30px;
      margin-top: 30px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .contact-box p {
      color: #fff !important;
      margin-bottom: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .contact-box i {
      color: var(--brand-color);
      font-size: 1.2rem;
    }

    @media (max-width: 991px) {
      .legal-content-wrapper {
        padding-left: 0;
      }
      .toc-wrapper {
        margin-bottom: 40px;
        position: relative;
        top: 0;
        max-height: 300px;
      }
      .legal-hero h1 {
        font-size: 3rem;
      }
      .legal-hero {
        padding: 150px 0 80px;
      }
      .legal-section-card {
        padding: 30px 20px;
      }
    }
