                      btn.innerText = originalText;
                    }
                  });
                }

                // Feedback Form Submission via Axios
                const feedbackForm = document.getElementById('feedbackForm');
                if (feedbackForm) {
                  const submitBtn = document.getElementById('submitFeedbackBtn');
                  feedbackForm.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    // Basic validation
                    const overall = document.querySelector('input[name="overallRating"]:checked');
                    const quiz = document.querySelector('input[name="quizRating"]:checked');
                    const project = document.querySelector('input[name="projectRating"]:checked');
                    const text = document.getElementById('experienceText').value.trim();
                    const linkedin = document.getElementById('linkedinUrl').value.trim();
                    const github = document.getElementById('githubUrl').value.trim();

                    // Highlight unselected rating cards
                    document.querySelectorAll('.fb-rating-card').forEach(c => c.style.borderColor = '');
                    if (!overall || !quiz || !project) {
                      if (!overall) document.querySelectorAll('.fb-rating-card')[0].style.borderColor = '#ff6600';
                      if (!quiz) document.querySelectorAll('.fb-rating-card')[1].style.borderColor = '#ff6600';
                      if (!project) document.querySelectorAll('.fb-rating-card')[2].style.borderColor = '#ff6600';
                      showToast('Please select all star ratings before submitting.', 'warning');
                      return;
                    }

                    if (!text) {
                      showToast('Please describe your experience.', 'warning');
                      document.getElementById('experienceText').style.borderColor = '#ff6600';
                      document.getElementById('experienceText').focus();
                      return;
                    } else {
                      document.getElementById('experienceText').style.borderColor = '';
                    }

                    if (!linkedin) {
                      showToast('Please provide your LinkedIn profile URL.', 'warning');
                      document.getElementById('linkedinUrl').style.borderColor = '#ff6600';
                      document.getElementById('linkedinUrl').focus();
                      return;
                    } else {
                      document.getElementById('linkedinUrl').style.borderColor = '';
                    }



                    const payload = {
                      overallRating: overall.value,
                      quizRating: quiz.value,
                      projectRating: project.value,
                      experienceText: text,
                      suggestions: document.getElementById('suggestions').value.trim(),
                      linkedinUrl: document.getElementById('linkedinUrl').value.trim(),
                      githubUrl: document.getElementById('githubUrl').value.trim(),
                      profilePictureConsent: document.getElementById('profilePictureConsent').checked
                    };

                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Submitting...';

                    try {
                      const response = await axios.post('/intern/feedback', payload);
                      if (response.data.success) {
                        showToast(response.data.message, 'success');
                        // Reload page to show success state after a short delay
                        setTimeout(() => {
                          window.location.reload();
                        }, 1500);
                      } else {
                        showToast(response.data.message || 'Error submitting feedback', 'error');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = 'Submit Feedback <i class="bi bi-send-fill ms-2"></i>';
                      }
                    } catch (error) {
                      console.error("Submission Error:", error);
                      const msg = error.response?.data?.message || 'Server error while submitting feedback';
                      showToast(msg, 'error');
                      submitBtn.disabled = false;
                      submitBtn.innerHTML = 'Submit Feedback <i class="bi bi-send-fill ms-2"></i>';
                    }
                  });
                }

              </script>
</body>

</html>