<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Intern Dashboard | Rixi Lab</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet" />

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon" />

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

  <!-- Main Dashboard CSS -->
  <link href="/css/intern.css" rel="stylesheet" />

  <!-- Cashfree JS SDK -->
  <script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
  <!-- YouTube Iframe API -->
  <script src="https://www.youtube.com/iframe_api"></script>
  <!-- Axios -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <style>
    /* ── Feedback Section – Modern Minimal ── */
    .fb-wrapper {
      background: var(--surface);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }

    .fb-header {
      padding: 24px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: var(--surface-alt);
    }

    .fb-back-btn {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-secondary);
      border-radius: 50px;
      padding: 8px 16px;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition);
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .fb-back-btn:hover {
      background: rgba(255, 102, 0, 0.1);
      border-color: var(--primary);
      color: var(--primary);
    }

    .fb-body {
      padding: 32px;
    }

    @media(min-width:768px) {
      .fb-body {
        padding: 40px 48px;
      }
    }

    .fb-rating-card {
      background: var(--surface-alt);
      border-radius: var(--radius-md);
      padding: 24px 20px;
      text-align: center;
      border: 1px solid var(--border);
      transition: var(--transition);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .fb-rating-card:hover {
      border-color: rgba(255, 102, 0, 0.3);
      background: rgba(255, 102, 0, 0.02);
    }

    .star-rating {
      display: flex;
      flex-direction: row-reverse;
      justify-content: center;
      gap: 6px;
      margin-top: 12px;
    }

    .star-rating input {
      display: none;
    }

    .star-rating label {
      font-size: 1.6rem;
      color: var(--border);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .star-rating label:hover,
    .star-rating label:hover~label,
    .star-rating input:checked~label {
      color: var(--primary);
      transform: scale(1.1);
    }

    .fb-label {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 8px;
      display: inline-block;
    }

    .fb-label .required {
      color: var(--primary);
      margin-left: 2px;
    }

    .fb-label .optional {
      color: var(--text-muted);
      font-size: 0.75rem;
      margin-left: 4px;
    }

    .fb-input {
      width: 100%;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 14px 16px;
      color: var(--text-primary);
      font-size: 0.95rem;
      transition: var(--transition);
      resize: none;
    }

    .fb-input:focus {
      outline: none;
      border-color: var(--primary);
      background: var(--surface);
      box-shadow: 0 0 0 3px rgba(255, 102, 0, 0.1);
    }

    .fb-input::placeholder {
      color: var(--text-muted);
    }

    .fb-input-icon-wrap {
      position: relative;
    }

    .fb-input-icon-wrap i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 1.1rem;
    }

    .fb-input-icon-wrap .fb-input {
      padding-left: 46px;
    }

    .fb-section-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-top: 32px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 12px;
    }

    .fb-section-title i {
      color: var(--primary);
    }

    .fb-section-title:first-child {
      margin-top: 0;
    }

    .fb-consent {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.02);
      border-radius: var(--radius-sm);
      border: 1px dashed var(--border);
      transition: var(--transition);
    }

    .fb-consent:hover {
      border-color: rgba(255, 255, 255, 0.2);
    }

    .fb-consent input {
      margin-top: 4px;
      accent-color: var(--primary);
      width: 18px;
      height: 18px;
      cursor: pointer;
    }

    .fb-consent label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      cursor: pointer;
      line-height: 1.5;
    }

    /* YouTube Style Lecture Card */
    .lecture-yt-card {
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease, border-color 0.3s ease;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .lecture-yt-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
      border-color: rgba(255, 102, 0, 0.4);
    }

    .lecture-yt-card:hover .lecture-yt-play-overlay {
      opacity: 1;
    }

    .lecture-yt-thumbnail {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      background-color: #000;
      overflow: hidden;
    }

    .lecture-yt-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .lecture-yt-card:hover .lecture-yt-thumbnail img {
      transform: scale(1.05);
    }

    .lecture-yt-duration {
      position: absolute;
      bottom: 8px;
      right: 8px;
      background-color: rgba(0, 0, 0, 0.8);
      color: #fff;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.5px;
      z-index: 2;
    }

    .lecture-yt-play-overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0, 0, 0, 0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
      z-index: 2;
    }

    .lecture-yt-play-overlay i {
      color: #fff;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
      background: rgba(255, 102, 0, 0.9);
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-left: 4px;
      box-shadow: 0 4px 15px rgba(255, 102, 0, 0.4);
    }

    .lecture-yt-progress-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: rgba(255, 255, 255, 0.2);
      z-index: 2;
    }

    .lecture-yt-progress-fill {
      height: 100%;
      background: #ff6600;
    }

    .lecture-yt-info {
      padding: 16px;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .lecture-yt-title {
      color: var(--text-primary);
      font-weight: 600;
      font-size: 1rem;
      line-height: 1.4;
      margin-bottom: 6px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .lecture-yt-desc {
      color: var(--text-secondary);
      font-size: 0.85rem;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin-bottom: 8px;
    }

    .lecture-yt-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
    }

    /* Fullscreen Lecture Modal Handling (Class-based) */
    .modal-fullscreen #lectureModalBody {
      flex-grow: 1 !important;
      height: auto !important;
    }
  </style>
</head>

<body>
  <%- include('partials/loader') %>

    <!-- Mobile Sidebar Overlay -->
    <div class="id-sidebar-overlay" id="sidebarOverlay"></div>

    <!-- SIDEBAR -->
    <aside class="id-sidebar" id="sidebar">
      <!-- Brand -->
      <div class="id-sidebar-brand">
        <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo" />
        <div class="id-sidebar-brand-text">
          <h2>Rixi Lab</h2>
          <span class="id-sidebar-badge">INTERN</span>
        </div>
      </div>

      <!-- Profile -->
      <div class="id-sidebar-profile">
        <div class="id-profile-img-wrap" data-bs-toggle="modal" data-bs-target="#updateProfileModal"
          title="Update Profile Picture">
          <img src="<%= intern.img_url %>" alt="Profile" />
        </div>
        <% const formattedName=intern.name.trim().split(" ").slice(0, 2).join(" "); %>
      <h4><%= formattedName %></h4>
      <p><%= intern.intern_id %></p>
      
      <div class=" id-sidebar-profile-stats">
          <div>
            <span>Batch No</span>
            <strong>
              <%= intern.batch_no %>
            </strong>
          </div>
          <div>
            <span>Duration</span>
            <strong>
              <%= intern.duration %> Weeks
            </strong>
          </div>
      </div>
      </div>

      <!-- Navigation -->
      <nav class="id-sidebar-nav">
        <div class="id-sidebar-nav-label">Main Menu</div>
        <a href="#dashboard" class="nav-link active" onclick="switchSection('dashboard', this)">
          <i class="bi bi-grid-1x2-fill"></i>
          <span>Dashboard</span>
        </a>
        <a href="#projects" class="nav-link" onclick="switchSection('projects', this)">
          <i class="bi bi-kanban-fill"></i>
          <span>Projects Timeline</span>
        </a>
        <a href="#quiz" class="nav-link d-none d-md-flex" onclick="switchSection('quiz', this)">
          <i class="bi bi-patch-question-fill"></i>
          <span>Quiz Assessment</span>
        </a>
        <a href="#meetings" class="nav-link" onclick="switchSection('meetings', this)">
          <i class="bi bi-camera-video-fill"></i>
          <span>Meetings</span>
        </a>
        <a href="#lectures" class="nav-link" onclick="switchSection('lectures', this)">
          <i class="bi bi-play-btn-fill"></i>
          <span>Lectures</span>
        </a>
        <a href="#documents" class="nav-link" onclick="switchSection('documents', this)">
          <i class="bi bi-file-earmark-text-fill"></i>
          <span>Documents</span>
        </a>

        <a href="#chat" class="nav-link d-lg-none" onclick="switchSection('chat', this)" id="navChatLink">
          <i class="bi bi-chat-dots-fill"></i>
          <span>Support Chat</span>
          <span id="chatUnreadBadge" class="chat-nav-badge d-none">0</span>
        </a>

        <!-- Logout for Mobile -->
        <a href="#dashboard" class="nav-link d-xl-none text-danger mt-4" data-bs-toggle="modal"
          data-bs-target="#logoutModal" style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px;">
          <i class="bi bi-box-arrow-right"></i>
          <span>Logout</span>
        </a>
      </nav>

      <div class="id-sidebar-footer">
        Technical Support:<br>
        <strong style="color: var(--primary);">support@rixilab.tech</strong><br>
        <small>Copyright © 2026 Rixi Lab. All rights reserved.</small>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="id-main-content">

      <!-- TOPBAR -->
      <header class="id-topbar">
        <div class="id-topbar-left">
          <button class="id-sidebar-toggle" id="sidebarToggle">
            <i class="bi bi-list"></i>
          </button>
          <div>
            <h4 id="topbarTitle">Dashboard</h4>
            <p class="d-none d-sm-block mt-2">Welcome to Rixi Lab, <%= intern.name %>
            </p>
          </div>
        </div>

        <div class="id-topbar-right">

          <!-- Support Chat Topbar Button -->
          <a href="#chat" class="id-topbar-btn d-none d-lg-flex position-relative text-decoration-none" onclick="switchSection('chat', document.getElementById('navChatLink'))" title="Support Chat">
            <i class="bi bi-chat-dots"></i>
            <span id="chatUnreadBadgeDesktop" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.6rem; padding: 0.25rem 0.45rem;">0</span>
          </a>

          <!-- Notifications -->
          <div class="dropdown">
            <button class="id-topbar-btn" data-bs-toggle="dropdown" aria-expanded="false" id="notificationButton">
              <i class="bi bi-bell"></i>
              <% const unreadCount=notifications ? notifications.length : 0; %>
                <% if (unreadCount> 0) { %>
                  <span class="position-absolute top-0 start-100 translate-middle p-1 rounded-circle"
                    style="background-color: var(--primary);">
                    <span class="visually-hidden">New alerts</span>
                  </span>
                  <% } %>
            </button>

            <ul class="dropdown-menu dropdown-menu-end notif-dropdown" id="notificationList">
              <li class="notif-header">
                <span>Notifications (<%= unreadCount %>)</span>
                <% if (notifications && notifications.length> 0) { %>
                  <button type="button" id="markAllBtn" class="btn btn-sm btn-outline-light py-0 px-2"
                    style="font-size: 0.7rem; color: #fff; border-color: rgba(255,255,255,0.3);">Mark All</button>
                  <% } %>
              </li>
              <div style="max-height: 300px; overflow-y: auto;">
                <% if (notifications && notifications.length> 0) { %>
                  <% notifications.forEach(n=> { %>
                    <li class="notif-item" data-id="<%= n._id %>">
                      <div>
                        <strong>
                          <%= n.title %>
                        </strong>
                        <small class="d-block">
                          <%= n.message %>
                        </small>
                      </div>
                      <button type="button" class="btn btn-sm text-success mark-as-read border-0"><i
                          class="bi bi-check2-circle fs-5"></i></button>
                    </li>
                    <% }) %>
                      <% } else { %>
                        <li class="p-3 text-center text-muted small">No new notifications 🎉</li>
                        <% } %>
              </div>
            </ul>
          </div>

          <!-- User Dropdown (Replaces Header logout) -->
          <div class="dropdown ms-2">
            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown"
              style="color: var(--text-primary); font-weight: 500;">
              <img src="<%= intern.img_url %>" alt="Profile" class="rounded-circle border border-2 shadow-sm" width="42"
                height="42" style="object-fit: cover; border-color: white !important;">
              <span class="ms-2 d-none d-md-inline" style="font-size: 0.9rem;">
                <%= intern.name.trim().split(" ")[0] %></span>
          </a>
          <ul class=" dropdown-menu dropdown-menu-end profile-dropdown-menu">
                  <li>
                    <h6 class="dropdown-header">Signed in as <br><strong>
                        <%= intern.email %>
                      </strong></h6>
                  </li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#updateProfileModal"><i
                        class="bi bi-person me-2"></i> Update Photo</a></li>
                  <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#passwordModal"><i
                        class="bi bi-shield-lock me-2"></i> Change Password</a></li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li><a class="dropdown-item text-danger" href="#dashboard" data-bs-toggle="modal"
                      data-bs-target="#logoutModal"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                  </ul>
          </div>

        </div>
      </header>

      <!-- CONTENT BODY -->
      <div class="id-content-body">

        <!-- 1. DASHBOARD SECTION -->
        <section id="dashboard" class="id-section active">

          <!-- Lecture Progress from server (totalWatchedTime / totalAssignedDuration) -->
          <% const serverLectureProgress = typeof lectureProgress !== 'undefined' ? lectureProgress : 0; %>
            <!-- Claymorphism Stat Cards Row -->
            <div class="row g-4 mb-4">
              <div class="col-12 col-sm-6 col-xl-3">
                <div class="id-stat-card h-100">
                  <div class="id-stat-icon"><i class="bi bi-kanban"></i></div>
                  <div class="id-stat-title">Projects Assigned</div>
                  <div class="id-stat-value">
                    <%= totalProjects %>
                  </div>
                </div>
              </div>

              <div class="col-12 col-sm-6 col-xl-3">
                <div class="id-stat-card h-100">
                  <div class="id-stat-icon"><i class="bi bi-play-btn-fill" style="color: #ff6600;"></i></div>
                  <div class="id-stat-title">Lecture Progress</div>
                  <div class="id-stat-value" id="dashboard-lecture-progress">
                    <%= serverLectureProgress %>%
                  </div>
                </div>
              </div>

              <div class="col-12 col-sm-6 col-xl-3">
                <div class="id-stat-card h-100">
                  <div class="id-stat-icon"><i class="bi bi-calendar-check" style="color: #ff6600;"></i></div>
                  <div class="id-stat-title">Meeting Attendance</div>
                  <div class="id-stat-value">
                    <%= attendanceRate %>%
                  </div>
                </div>
              </div>

              <div class="col-12 col-sm-6 col-xl-3">
                <div class="id-stat-card h-100">
                  <div class="id-stat-icon"><i class="bi bi-graph-up-arrow " style="color: #ff6600;"></i></div>
                  <div class="id-stat-title">Project Progress</div>
                  <div class="id-stat-value">
                    <%= progress %>%
                  </div>
                </div>
              </div>
            </div>

            <!-- Glassmorphism Details Panels -->
            <div class="row g-4">
              <div class="col-12 col-lg-6">
                <div class="id-glass-panel h-100">
                  <h3 class="id-panel-title"><i class="bi bi-building"></i> College Details</h3>
                  <ul class="id-info-list">
                    <li><span class="id-info-label">University</span><span class="id-info-value">
                        <%= intern.university %>
                      </span></li>
                    <li><span class="id-info-label">College</span><span class="id-info-value">
                        <%= intern.college %>
                      </span></li>
                    <li><span class="id-info-label">Course</span><span class="id-info-value">
                        <%= intern.course %>
                      </span></li>
                    <li><span class="id-info-label">Branch</span><span class="id-info-value">
                        <%= intern.branch %>
                      </span></li>
                    <li><span class="id-info-label">Year/Sem</span><span class="id-info-value">
                        <%= intern.year_sem %>
                      </span></li>
                  </ul>
                </div>
              </div>
              <div class="col-12 col-lg-6">
                <div class="id-glass-panel h-100">
                  <h3 class="id-panel-title"><i class="bi bi-briefcase"></i> Internship Details</h3>
                  <ul class="id-info-list">
                    <li><span class="id-info-label">Intern ID</span><span class="id-info-value"
                        style="color: var(--primary);">
                        <%= intern.intern_id %>
                      </span></li>
                    <li><span class="id-info-label">Domain</span><span class="id-info-value">
                        <%= intern.domain %>
                      </span></li>
                    <li><span class="id-info-label">Duration</span><span class="id-info-value">
                        <%= intern.duration %> Weeks
                      </span></li>
                    <li><span class="id-info-label">Start Date</span><span class="id-info-value">
                        <%= startingDate %>
                      </span></li>
                    <li><span class="id-info-label">Mentor</span><span class="id-info-value">
                        <%= mentorName %>
                      </span></li>
                  </ul>
                </div>
              </div>
            </div>
        </section>

        <!-- 2. PROJECTS SECTION -->
        <section id="projects" class="id-section">

          <!-- Timeline Progress -->
          <div class="id-progress-wrapper">
            <div class="id-progress-header">
              <h3>Your Project Timeline</h3>
              <span class="id-progress-pct">
                <%= progress %>%
              </span>
            </div>
            <div class="id-progress-bar-container">
              <div class="id-progress-bar-fill" style="width: <%= progress %>%;"></div>
            </div>
          </div>

          <div class="row">
            <% if (intern.projectAssigned && intern.projectAssigned.length> 0) { %>
              <% intern.projectAssigned.forEach(sub=> {
                const proj = projects.find(p => p._id.toString() === sub.projectId.toString());
                %>
                <div class="col-12">
                  <div class="id-project-card">
                    <!-- Project Info -->
                    <div class="id-project-info">
                      <h5>
                        <%= proj ? proj.title : 'N/A' %>
                      </h5>
                      <p>
                        <%= proj ? proj.description : '' %>
                      </p>
                    </div>

                    <!-- Actions -->
                    <div class="id-project-actions mt-3 mt-md-0">
                      <% if (sub.status==='accepted' ) { %>
                        <span class="id-status-badge id-status-accepted"><i class="bi bi-check-circle-fill me-1"></i>
                          Accepted</span>
                        <% } else if (sub.status==='rejected' ) { %>
                          <span class="id-status-badge id-status-rejected"><i class="bi bi-x-circle-fill me-1"></i>
                            Rejected</span>
                          <% } else{ %>
                            <span class="id-status-badge id-status-pending"><i class="bi bi-clock-fill me-1"></i>
                              Pending</span>
                            <% } %>

                              <a href="<%= proj ? proj.downloadLink : '#' %>" target="_blank"
                                class="btn btn-outline-primary-custom">
                                <i class="bi bi-download me-1"></i> Download
                              </a>

                              <% if (sub.status !=='accepted' && proj && !proj.isHidden) { %>
                                <a href="<%= proj.uploadLink %>" target="_blank" class="btn btn-primary-custom">
                                  <i class="bi bi-upload me-1"></i> Upload
                                </a>
                                <% } else if (sub.status !=='accepted' && proj && proj.isHidden) { %>
                                  <button class="btn btn-secondary px-4 disabled">Closed</button>
                                  <% } else { %>
                                    <button class="btn btn-outline-success  disabled">Uploaded</button>
                                    <% } %>
                    </div>
                  </div>
                </div>
                <% }) %>
                  <% } else { %>
                    <div class="col-12 text-center py-5">
                      <i class="bi bi-folder-x fs-1 text-light opacity-50 mb-3 d-block"></i>
                      <p class="text-light">No projects assigned yet.</p>
                    </div>
                    <% } %>
          </div>
        </section>

        <!-- 2.5 QUIZ SECTION -->
        <section id="quiz" class="id-section">
          <h4 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i
              class="bi bi-patch-question-fill me-2" style="color: #ff6600;"></i> Assigned Quizzes</h4>

          <div class="row g-3">
            <% if (progress===100 && assignedQuizzes && assignedQuizzes.length> 0) { %>
              <% assignedQuizzes.forEach(q=> { %>
                <div class="col-12 mt-4">
                  <div class="id-project-card id-quiz-card" style="flex-direction: column; align-items: stretch;">
                    <div class="d-flex align-items-center gap-4 w-100">
                      <div class="id-quiz-icon">
                        <i class="bi bi-patch-question-fill"></i>
                      </div>

                      <div class="id-project-info flex-grow-1">
                        <h5>
                          <%= q.quiz.title %>
                        </h5>
                        <p class="mb-1">
                          Score: <strong>
                            <%= intern.quiz_score %>
                          </strong> &nbsp;•&nbsp; Attempts: <%= q.attemptCount %> / 3
                            <% if (q.attemptCount>= 1) { %>
                              <% if (intern.isPassed) { %>
                                <span class="badge bg-success ms-2">Pass</span>
                                <% } else { %>
                                  <span class="badge bg-danger ms-2">Fail</span>
                                  <% } %>
                                    <% } %>
                        </p>
                      </div>

                      <div class="id-project-actions flex-shrink-0">
                        <% if (q.isClosed) { %>
                          <button class="btn btn-danger px-4" disabled>Closed</button>
                          <% } else if (q.attemptCount>= 3) { %>
                            <button class="btn btn-secondary px-4" disabled>No Attempts Left</button>
                            <% } else { %>
                              <a href="/intern/quiz/<%= q.quiz._id %>" class="btn btn-success px-4"
                                style="font-weight: 600;" id="startQuizBtn">
                                <i class="bi bi-play-circle-fill me-1"></i> Start Quiz
                              </a>
                              <% } %>
                      </div>
                    </div>
                  </div> <!-- End of id-project-card id-quiz-card -->

                  <% if (q.attemptCount>= 3 && !intern.isPassed && !intern.certificatePurchased) { %>
                    <div
                      class="mt-3 p-4 d-flex flex-column flex-md-row align-items-center justify-content-between rounded shadow-sm"
                      style="background: rgba(255, 102, 0, 0.05); border: 1px solid rgba(255, 102, 0, 0.3); border-radius: 16px !important;">
                      <div class="mb-3 mb-md-0">
                        <h6 class="mb-1" style="color: #ff6600; font-size: 1.1rem;"><i
                            class="bi bi-info-circle-fill me-1"></i> Need your certificate?</h6>
                        <p class="text-secondary small mb-0">You have no attempts left for this quiz. However, you can
                          still get your certificate via paid option.</p>
                      </div>
                      <button class="btn px-4 fw-bold"
                        style="background: linear-gradient(135deg, #ff6600, #ff8533); color: #fff; white-space: nowrap; border: none; box-shadow: 0 4px 15px rgba(255,102,0,0.3);"
                        onclick="initiateCertPayment(this)">
                        <i class="bi bi-credit-card me-1"></i> Pay ₹99 for Certificate
                      </button>
                    </div>
                    <% } else if (intern.certificatePurchased) { %>
                      <div class="mt-3 p-4 rounded shadow-sm"
                        style="background: rgba(40, 167, 69, 0.1); border: 1px solid rgba(40, 167, 69, 0.5); border-radius: 16px !important;">
                        <div class="d-flex align-items-center">
                          <i class="bi bi-check-circle-fill text-success fs-3 me-3"></i>
                          <div>
                            <h6 class="mb-0 text-success fw-bold" style="font-size: 1.1rem;">Payment Successful</h6>
                            <p class="text-light small mb-0 mt-1">You will get your certificate in the document section
                              within 6 Hrs.</p>
                          </div>
                        </div>
                      </div>
                      <% } %>
                </div> <!-- End of col-12 mt-4 -->
                <% }) %>
                  <% } else { %>
                    <div class="col-12 text-center py-5">
                      <i class="bi bi-patch-question-fill fs-1 text-light opacity-50 mb-3 d-block"></i>
                      <p class="text-light">Your quiz will be assigned once your project submission is accepted.
                      </p>
                    </div>
                    <% } %>
          </div>
        </section>

        <!-- 3. MEETINGS SECTION -->
        <section id="meetings" class="id-section">
          <h4 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-camera-video me-2"
              style="color: #ff6600;"></i> Scheduled Meetings</h4>

          <div class="row g-3">
            <% if (assignedMeetings && assignedMeetings.length> 0) { %>
              <% assignedMeetings.forEach(meeting=> { %>
                <div class="col-12 col-md-6 col-lg-12">
                  <div class="id-meeting-card">
                    <div class="d-flex">
                      <div class="me-3 mt-1">
                        <i class="bi bi-calendar-event fs-3" style="color: var(--text-primary);"></i>
                      </div>
                      <div>
                        <h5 class="fw-bold mb-1" style="color: var(--text-primary);">
                          <%= meeting.title || 'Untitled Meeting' %>
                        </h5>
                        <p class="mb-0 text-secondary" style="font-size: 0.85rem;">
                          <span class="badge bg-light text-dark border me-2">Week <%= meeting.week || 'N/A' %></span>
                          <i class="bi bi-clock me-1"></i>
                          <span class="meeting-time" data-time="<%= meeting.scheduledTime %>">
                            <%= meeting.scheduledTime ? new Date(meeting.scheduledTime).toLocaleString('en-IN', {
                              timeZone: 'Asia/Kolkata' , weekday: 'short' , year: 'numeric' , month: 'short' ,
                              day: '2-digit' , hour: '2-digit' , minute: '2-digit' , hour12: true }) : 'Time not set' %>
                          </span>
                        </p>
                      </div>
                    </div>

                    <div class="id-project-actions mt-3 mt-lg-0">
                      <a href="<%= meeting.link || '#' %>" target="_blank" class="btn btn-outline-primary-custom">
                        <i class="bi bi-box-arrow-up-right me-1"></i> Join Meeting
                      </a>

                      <span
                        class="id-status-badge <% if (meeting.attendance === 'present') { %> id-status-accepted <% } else if (meeting.attendance === 'absent') { %> id-status-rejected <% } else { %> bg-secondary text-white <% } %>">
                        <%= meeting.attendance ? meeting.attendance.toUpperCase() : 'N/A' %>
                      </span>
                    </div>
                  </div>
                </div>
                <% }) %>
                  <% } else { %>
                    <div class="col-12 text-center py-5">
                      <i class="bi bi-camera-video-off fs-1 text-light opacity-50 mb-3 d-block"></i>
                      <p class="text-light">No upcoming meetings scheduled.</p>
                    </div>
                    <% } %>
          </div>
        </section>

        <!-- 3.5 LECTURES SECTION -->
        <section id="lectures" class="id-section">
          <!-- <h4 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-play-btn-fill me-2"
              style="color: #ff6600;"></i> Assigned Lectures</h4> -->

          <!-- Timeline Progress (uses server-computed lectureProgress) -->
          <% const _lectures=typeof allLectures !=='undefined' ? allLectures : [];
            const lecProgPct = typeof lectureProgress !== 'undefined' ? lectureProgress : 0;
            %>
            <div class="id-progress-wrapper mb-4">
              <div class="id-progress-header">
                <h3>Your Lecture Timeline</h3>
                <span class="id-progress-pct" id="lecture-progress-pct">
                  <%= lecProgPct %>%
                </span>
              </div>
              <div class="id-progress-bar-container">
                <div class="id-progress-bar-fill" id="lecture-progress-bar" style="width: <%= lecProgPct %>%;">
                </div>
              </div>
              <div class="mt-3 text-secondary opacity-75" style="font-size: 0.85rem;">
                <span>Note : Watch the lecture without skipping to ensure your progress is counted.</span>  
              </div>
            </div>

            <div class="row g-4">
              <% if (_lectures.length> 0) { %>
                <% _lectures.forEach(lecture=> { %>
                  <div class="col-12 col-md-6 col-xl-4">
                    <div class="lecture-yt-card" onclick="openLectureVideo('<%= lecture._id %>', '<%= (lecture.title || '').replace(/'/g, '&#39;') %>', <%= lecture.watchedTime || 0 %>, <%= lecture.completed || false %>)">
                      <div class="lecture-yt-thumbnail">
                        <img src="https://img.youtube.com/vi/<%= lecture.videoId %>/mqdefault.jpg" alt="Lecture Thumbnail">
                        <div class="lecture-yt-duration"><%= lecture.duration || '0:00' %></div>
                        <div class="lecture-yt-play-overlay"><i class="bi bi-play-fill fs-1"></i></div>
                        
                        <!-- Track progress visually on thumbnail -->
                        <% 
                          let pct = 0;
                          let _durSecs = 0;
                          if (lecture.duration) {
                            const p = String(lecture.duration).split(':').map(Number);
                            if (p.length === 3) _durSecs = p[0]*3600 + p[1]*60 + p[2];
                            else if (p.length === 2) _durSecs = p[0]*60 + p[1];
                          }
                          if (lecture.completed) { pct = 100; }
                          else if (_durSecs > 0 && lecture.watchedTime) { pct = Math.min(100, (lecture.watchedTime / _durSecs)*100); }
                        %>
                        <div class="lecture-yt-progress-bar">
                          <div class="lecture-yt-progress-fill" style="width: <%= pct %>%;"></div>
                        </div>
                      </div>
                      <div class="lecture-yt-info">
                        <div class="lecture-yt-title d-flex justify-content-between align-items-center"><%= lecture.title %> 
                           <% if (lecture.completed) { %>
                            <span id="lecture-badge-<%= lecture._id %>" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 lecture-status-badge"><i class="bi bi-check-circle-fill me-1"></i> Watched</span>
                          <% } else { %>
                            <span id="lecture-badge-<%= lecture._id %>" class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 lecture-status-badge"><i class="bi bi-clock-fill me-1"></i> Pending</span>
                          <% } %>
                        </div>
                        <div class="lecture-yt-desc"><%= lecture.description ? lecture.description : 'Recorded Video Lecture' %></div>
                      </div>
                    </div>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="col-12 text-center py-5">
                        <i class="bi bi-camera-reels fs-1 text-light opacity-50 mb-3 d-block"></i>
                        <p class="text-light">No lectures assigned yet.</p>
                      </div>
                      <% } %>
            </div>
        </section>

        <!-- 4. DOCUMENTS SECTION -->
        <section id="documents" class="id-section">
          <h3 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-folder2-open me-2"
              style="color: #ff6600;"></i> Internship Documents</h3>

          <div class="row g-4">
            <!-- Offer Letter -->
            <div class="col-12 col-xl-6">
              <div class="id-doc-card">
                <div class="d-flex align-items-center gap-3">
                  <div class="id-doc-icon"><i class="bi bi-envelope-paper"></i></div>
                  <div>
                    <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Offer Letter</h5>
                    <p class="mb-0 text-secondary" style="font-size: 0.85rem;">Official internship offer document.</p>
                  </div>
                </div>
                <a href="<%= intern.offer_letter || `/download-offer-letter/${intern._id}` %>" target="_blank"
                  class="btn btn-outline-primary-custom rounded-circle ">
                  <i class="bi bi-download"></i>
                </a>
              </div>
            </div>

            <!-- Feedback Form -->
            <% if (progress===100) { %>
              <div class="col-12 col-xl-6">
                <div class="id-doc-card"
                  style="border-color: <%= intern.feedbackSubmitted ? '#10b981' : 'var(--border)' %>;">
                  <div class="d-flex align-items-center gap-3">
                    <div class="id-doc-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i
                        class="bi bi-chat-square-text"></i></div>
                    <div>
                      <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Internship Feedback</h5>
                      <p class="mb-0 text-secondary" style="font-size: 0.85rem;">
                        <%= intern.feedbackSubmitted ? 'Feedback submitted, thank you.'
                          : 'Submit your program feedback.' %>
                      </p>
                    </div>
                  </div>
                  <% if (intern.feedbackSubmitted) { %>
                    <span
                      class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 p-2 px-3 rounded-pill"
                      style="font-size: 0.9rem;">Submitted <i class="bi bi-check-circle-fill ms-1"></i></span>
                    <% } else { %>
                      <button type="button" onclick="openFeedbackSection()" title="Submit Feedback"
                        class="btn btn-outline-success rounded-circle "><i class="bi bi-arrow-right"></i></button>
                      <% } %>
                </div>
              </div>
              <% } %>

                <!-- Certificate -->
                <div class="col-12 col-xl-6">
                  <div class="id-doc-card">
                    <div class="d-flex align-items-center gap-3">
                      <div class="id-doc-icon"><i class="bi bi-award"></i></div>
                      <div>
                        <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Completion Certificate</h5>
                        <p class="mb-0 text-secondary" style="font-size: 0.85rem;">Unlocked upon program completion.</p>
                      </div>
                    </div>
                    <% if (intern.certificate_link) { %>
                      <% if (intern.certificate_id && String(intern.certificate_id).startsWith('TEMP')) { %>
                        <button type="button" class="btn btn-outline-primary-custom rounded-circle p-2 px-3"
                          onclick="showToast('Your certificate is not valid yet (TEMP ID).', 'warning')"><i
                            class="bi bi-download"></i></button>
                        <% } else { %>
                          <a href="<%= intern.certificate_link %>" download
                            class="btn btn-outline-primary-custom rounded-circle p-2 px-3"><i
                              class="bi bi-download"></i></a>
                          <% } %>
                            <% } else if (intern.completion_date) { %>
                              <% if (!intern.feedbackSubmitted) { %>
                                <button class="btn btn-secondary rounded-circle p-2 px-3 opacity-50"
                                  title="Submit feedback first" disabled><i class="bi bi-lock-fill"></i></button>
                                <% } else { %>
                                  <% if (intern.certificate_id && String(intern.certificate_id).startsWith('TEMP')) { %>
                                    <button type="button" class="btn btn-outline-primary-custom rounded-circle"
                                      onclick="showToast('Your certificate is not valid yet. Please wait for final approval.', 'warning')"><i
                                        class="bi bi-download"></i></button>
                                    <% } else { %>
                                      <a href="/download-certificate/<%= intern._id %>" target="_blank"
                                        class="btn btn-outline-primary-custom rounded-circle "><i
                                          class="bi bi-download"></i></a>
                                      <% } %>
                                        <% } %>
                                          <% } else { %>
                                            <button class="btn btn-secondary rounded-circle p-2 px-3 opacity-50"
                                              disabled><i class="bi bi-lock-fill"></i></button>
                                            <% } %>
                  </div>
                </div>

          </div>
        </section>

        <!-- 4.5. FEEDBACK SECTION -->
        <section id="feedback_section" class="id-section">
          <div class="row justify-content-center">
            <div class="col-12 col-xl-10">

              <% if (intern.feedbackSubmitted) { %>
                <!-- ── Submitted State ── -->
                <div class="fb-wrapper">
                  <div class="fb-header">
                    <button type="button" class="fb-back-btn"
                      onclick="switchSection('documents', document.querySelector('a[href=\'#documents\']'))">
                      <i class="bi bi-arrow-left"></i> Back to Documents
                    </button>
                    <span
                      class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill"><i
                        class="bi bi-check-circle-fill me-1"></i> Completed</span>
                  </div>
                  <div class="fb-body text-center py-5">
                    <div class="d-inline-flex justify-content-center align-items-center rounded-circle mb-4"
                      style="width:100px;height:100px;background:rgba(16,185,129,0.1);color:#10b981;">
                      <i class="bi bi-check2-circle" style="font-size:4rem;"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-2">Feedback Submitted Successfully</h3>
                    <p class="text-secondary mb-4 mx-auto" style="max-width: 400px;">Thank you for sharing your
                      experience. We appreciate your valuable feedback. You can now download your completion
                      certificate.</p>
                    <button onclick="switchSection('documents', document.querySelector('a[href=\'#documents\']'))"
                      class="btn btn-primary-custom px-4 py-2"><i class="bi bi-file-earmark-text me-2"></i> View
                      Certificate</button>
                  </div>
                </div>

                <% } else { %>
                  <!-- ── Feedback Form ── -->
                  <div class="fb-wrapper">
                    <!-- Card Header with Back Button -->
                    <div class="fb-header">
                      <button type="button" class="fb-back-btn"
                        onclick="switchSection('documents', document.querySelector('a[href=\'#documents\']'))">
                        <i class="bi bi-arrow-left"></i> Documents
                      </button>
                      <span style="font-size:0.75rem;color:var(--text-muted);"><i class="bi bi-asterisk me-1"
                          style="color:#ff6600;font-size:0.6rem;"></i> Required fields</span>
                    </div>

                    <div class="fb-body">
                      <div class="mb-5 border-bottom border-secondary border-opacity-25 pb-4">
                        <h3 class="text-white fw-bold mb-2">Internship Feedback</h3>
                        <p class="text-secondary mb-0">Please share your honest experience to help us improve.</p>
                      </div>

                      <form id="feedbackForm" novalidate>

                        <div class="fb-section-title"><i class="bi bi-star-fill"></i> Ratings</div>

                        <div class="row g-4 mb-5">
                          <div class="col-12 col-md-4">
                            <div class="fb-rating-card h-100">
                              <div class="text-secondary mb-2" style="font-size: 1.25rem;"><i
                                  class="bi bi-building-check"></i></div>
                              <div class="fb-label text-center mb-0">Overall Experience <span class="required">*</span>
                              </div>
                              <div class="star-rating">
                                <input type="radio" id="star5_overall" name="overallRating" value="5" required />
                                <label for="star5_overall" title="5 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star4_overall" name="overallRating" value="4" />
                                <label for="star4_overall" title="4 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star3_overall" name="overallRating" value="3" />
                                <label for="star3_overall" title="3 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star2_overall" name="overallRating" value="2" />
                                <label for="star2_overall" title="2 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star1_overall" name="overallRating" value="1" />
                                <label for="star1_overall" title="1 star"><i class="bi bi-star-fill"></i></label>
                              </div>
                            </div>
                          </div>
                          <div class="col-12 col-md-4">
                            <div class="fb-rating-card h-100">
                              <div class="text-secondary mb-2" style="font-size: 1.25rem;"><i
                                  class="bi bi-patch-question-fill"></i></div>
                              <div class="fb-label text-center mb-0">Quiz Assessment <span class="required">*</span>
                              </div>
                              <div class="star-rating">
                                <input type="radio" id="star5_quiz" name="quizRating" value="5" required />
                                <label for="star5_quiz" title="5 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star4_quiz" name="quizRating" value="4" />
                                <label for="star4_quiz" title="4 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star3_quiz" name="quizRating" value="3" />
                                <label for="star3_quiz" title="3 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star2_quiz" name="quizRating" value="2" />
                                <label for="star2_quiz" title="2 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star1_quiz" name="quizRating" value="1" />
                                <label for="star1_quiz" title="1 star"><i class="bi bi-star-fill"></i></label>
                              </div>
                            </div>
                          </div>
                          <div class="col-12 col-md-4">
                            <div class="fb-rating-card h-100">
                              <div class="text-secondary mb-2" style="font-size: 1.25rem;"><i class="bi bi-laptop"></i>
                              </div>
                              <div class="fb-label text-center mb-0">Project & Tasks <span class="required">*</span>
                              </div>
                              <div class="star-rating">
                                <input type="radio" id="star5_project" name="projectRating" value="5" required />
                                <label for="star5_project" title="5 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star4_project" name="projectRating" value="4" />
                                <label for="star4_project" title="4 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star3_project" name="projectRating" value="3" />
                                <label for="star3_project" title="3 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star2_project" name="projectRating" value="2" />
                                <label for="star2_project" title="2 stars"><i class="bi bi-star-fill"></i></label>
                                <input type="radio" id="star1_project" name="projectRating" value="1" />
                                <label for="star1_project" title="1 star"><i class="bi bi-star-fill"></i></label>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="fb-section-title"><i class="bi bi-chat-text-fill"></i> Detailed Feedback</div>

                        <div class="mb-4">
                          <label for="experienceText" class="fb-label">What did you like most about the internship?
                            <span class="required">*</span></label>
                          <textarea class="fb-input" id="experienceText" name="experienceText" rows="4"
                            placeholder="Tell us about the positive aspects of your experience..." required></textarea>
                        </div>

                        <div class="mb-5">
                          <label for="suggestions" class="fb-label">Suggestions for improvement <span
                              class="required">*</span></label>
                          <textarea class="fb-input" id="suggestions" name="suggestions" rows="3"
                            placeholder="How can we make this program better for future interns?" required></textarea>
                        </div>

                        <div class="fb-section-title"><i class="bi bi-link-45deg"></i> Professional Links</div>

                        <div class="row g-4 mb-5">
                          <div class="col-12 col-md-6">
                            <label for="linkedinUrl" class="fb-label">LinkedIn URL <span
                                class="required">*</span></label>
                            <div class="fb-input-icon-wrap">
                              <i class="bi bi-linkedin"></i>
                              <input type="url" class="fb-input" id="linkedinUrl" name="linkedinUrl"
                                placeholder="https://linkedin.com/in/username" required>
                            </div>
                          </div>
                          <div class="col-12 col-md-6">
                            <label for="githubUrl" class="fb-label">GitHub URL <span
                                class="optional">(Optional)</span></label>
                            <div class="fb-input-icon-wrap">
                              <i class="bi bi-github"></i>
                              <input type="url" class="fb-input" id="githubUrl" name="githubUrl"
                                placeholder="https://github.com/username">
                            </div>
                          </div>
