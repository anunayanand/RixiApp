                      }
                    }).catch(console.error);
                }

                const EMOJIS = ["👍", "👎", "😊", "😂", "🤣", "😍", "🙏", "🔥", "🎉", "💡", "✅", "❌", "❓", "👀", "🙌", "👏", "🚀", "💻", "😅", "😎", "🥺", "😢", "😡", "🤔"];
