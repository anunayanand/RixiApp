            <img id="previewImage" src="<%= intern.img_url %>" style="width: 140px; height: 140px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary-glow); padding: 4px;" alt="Preview" />
          </div>
          <form action="/update-image" method="POST" enctype="multipart/form-data" id="updateImageForm">
            <input type="file" name="image" id="imageInput" class="form-control mb-3 p-2 text-white" style="background: var(--surface-alt); border-color: var(--border);" accept="image/*" required />
            <button type="submit" class="btn btn-primary-custom w-100 py-2 fs-6">Upload New Picture</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Change Password Modal -->
  <% if (showPasswordPopup) { %>
  <div class="modal fade" id="passwordModal" tabindex="-1" aria-labelledby="passwordModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content shadow-lg" style="background-color: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);">
        <div class="modal-header border-bottom-0 rounded-top" style="background: var(--surface-alt); border-radius: var(--radius-lg) var(--radius-lg) 0 0;">
          <h5 class="modal-title fw-bold text-white" id="passwordModalLabel"><i class="bi bi-shield-lock-fill text-primary me-2"></i>Change Your Password</h5>
        </div>
        <div class="modal-body p-4">
          <p class="text-secondary small mb-4">For security reasons, please update your initial password before accessing your dashboard.</p>
          <form action="/intern/change-password" method="POST" id="passwordForm" novalidate>
            <div class="mb-3">
              <label class="form-label fw-semibold text-white small">New Password</label>
              <div class="input-group">
                <input type="password" id="newPassFirst" name="newPassword" class="form-control p-2 text-white shadow-sm" style="background: var(--surface-alt); border: 1px solid var(--border); border-right: none;" placeholder="Enter new password (min. 6 chars)" minlength="6" required />
                <button type="button" class="btn" style="background: var(--surface-alt); border: 1px solid var(--border); border-left: none; color: var(--text-secondary);" onclick="togglePwd('newPassFirst', this)"><i class="bi bi-eye-slash"></i></button>
              </div>
            </div>
            <div class="mb-4">
              <label class="form-label fw-semibold text-white small">Confirm Password</label>
              <div class="input-group">
                <input type="password" id="confPassFirst" name="confirmPassword" class="form-control p-2 text-white shadow-sm" style="background: var(--surface-alt); border: 1px solid var(--border); border-right: none;" placeholder="Confirm password" required minlength="6" />
                <button type="button" class="btn" style="background: var(--surface-alt); border: 1px solid var(--border); border-left: none; color: var(--text-secondary);" onclick="togglePwd('confPassFirst', this)"><i class="bi bi-eye-slash"></i></button>
              </div>
