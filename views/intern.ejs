    </div>
  </div>
  <% } %>
  <!-- General UI Password Modal (used from dropdown) -->
  <% if (!showPasswordPopup) { %>
    <div class="modal fade" id="passwordModal" tabindex="-1" aria-labelledby="optionalPasswordModalLabel" aria-hidden="true">
