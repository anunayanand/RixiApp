  </div>

  <%- include("partials/toaster") %>

  <!-- Vendor JS Files -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
  <!-- Main JS Logics from existing view -->
  <script src="/js/intern.js"></script>

  <!-- UI Interactions Script -->
  <script>
    // Tab Switching Logic
    function switchSection(sectionId, element) {
      // Prevent default anchor behavior if handled by script (we use hashes so it's fine)
      
      // Remove active class from all nav links and hide all sections
      document.querySelectorAll('.id-sidebar-nav .nav-link').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.id-section').forEach(sec => sec.classList.remove('active'));
      
      // Add active to clicked link and show target section
      element.classList.add('active');
      const target = document.getElementById(sectionId);
      if (target) {
        target.classList.add('active');
      }

      // Update Topbar Title
      const titleSpan = element.querySelector('span');
      if (titleSpan) {
        document.getElementById('topbarTitle').innerText = titleSpan.innerText;
      }

      // Hide sidebar on mobile after click
      if (window.innerWidth < 1200) {
        document.getElementById('sidebar').classList.remove('show');
        document.getElementById('sidebarOverlay').classList.remove('show');
      }
    }

    // Sidebar Toggle Logic
    const toggleBtn = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');

    if(toggleBtn && sidebar && overlay) {
      toggleBtn.addEventListener('click', () => {
        sidebar.classList.add('show');
        overlay.classList.add('show');
      });

      overlay.addEventListener('click', () => {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
      });
    }

    // Handle Required Password Modal
    <% if (showPasswordPopup) { %>
      document.addEventListener("DOMContentLoaded", function() {
        const passwordModalEl = document.getElementById("passwordModal");
        if (passwordModalEl) {
          const passwordModal = new bootstrap.Modal(passwordModalEl, {
            backdrop: "static",
            keyboard: false,
          });
          passwordModal.show();
        }
      });
    <% } %>

    // Password visibility toggle
    function togglePwd(inputId, btn) {
      const input = document.getElementById(inputId);
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('bi-eye-slash', 'bi-eye');
        btn.style.color = 'var(--primary)';
      } else {
        input.type = 'password';
        icon.classList.replace('bi-eye', 'bi-eye-slash');
        btn.style.color = 'var(--text-secondary)';
      }
    }

    // Mobile Quiz blocking logic
    window.addEventListener("resize", function () {
      if (window.innerWidth < 1024) {
        const startBtn = document.getElementById('startQuizBtn');
        if (startBtn) {
          // Replace link behavior for mobile
          startBtn.addEventListener("click", (e) => {
            e.preventDefault();
            window.location.href = "/mobile-blocked";
          });
        }
      }
    });
    // Trigger resize check on load
    window.dispatchEvent(new Event('resize'));

    // ==========================================
    // CHAT SYSTEM LOGIC
    // ==========================================
    let currentTicketId = null;
    let lastMessageId = null;
    let chatPollInterval = null;
    let isChatOpen = false;

    const chatStateNoTicket = document.getElementById('chatStateNoTicket');
    const chatStatePending = document.getElementById('chatStatePending');
    const chatStateActive = document.getElementById('chatStateActive');
    const chatMessagesBox = document.getElementById('chatMessagesBox');
    
    // Check initial chat status on load
    window.addEventListener("DOMContentLoaded", () => {
       fetchTicketStatus();
       fetchUnreadCount();
       pingAdminOnlineStatus();
       setInterval(fetchUnreadCount, 5000); // Check unread count every 5s
       setInterval(pingAdminOnlineStatus, 10000); // Ping-pong mentor status every 10s
    });

    function pingAdminOnlineStatus() {
       fetch('/chat/ping-admin', { cache: 'no-store' })
         .then(res => res.json())
         .then(data => {
            const dot = document.getElementById('pingStatusDot');
            const txt = document.getElementById('pingStatusText');
            if(dot && txt) {
               dot.classList.remove('spinner-grow', 'spinner-grow-sm', 'bg-success', 'bg-secondary');
               dot.classList.add('rounded-circle');
               dot.style.width = '10px';
               dot.style.height = '10px';
               if(data.success && data.isOnline) {
                  dot.classList.add('bg-success');
                  txt.innerText = 'Mentor Online';
                  txt.classList.remove('text-secondary');
                  txt.classList.add('text-success');
               } else {
                  dot.classList.add('bg-secondary');
                  txt.innerText = 'Mentor Offline';
                  txt.classList.remove('text-success');
                  txt.classList.add('text-secondary');
               }
            }
         }).catch(console.error);
    }

    // Handle section switch to handle chat read receipts
    const originalSwitchSection = switchSection;
    switchSection = function(sectionId, element) {
       originalSwitchSection(sectionId, element);
       isChatOpen = (sectionId === 'chat');
       
       if (isChatOpen && currentTicketId) {
           markMessagesAsRead(currentTicketId);
       }
    };

    function fetchTicketStatus() {
       fetch('/chat/ticket/status')
         .then(res => res.json())
         .then(data => {
            if (!data.success || !data.ticket) {
               showChatState('noticket');
               return;
            }
            const ticket = data.ticket;
            currentTicketId = ticket._id;
            
            if (ticket.status === 'pending') {
               document.getElementById('pendingSubject').innerText = ticket.subject;
               showChatState('pending');
               // Start polling to check if it gets accepted
               startChatPolling();
            } else if (ticket.status === 'accepted') {
               setupActiveChat(ticket);
               showChatState('active');
               startChatPolling();
               if(isChatOpen) markMessagesAsRead(currentTicketId);
            }
         }).catch(console.error);
    }

    function showChatState(state) {
       chatStateNoTicket.classList.add('d-none');
       chatStatePending.classList.add('d-none');
       chatStateActive.classList.add('d-none');

       if (state === 'noticket') chatStateNoTicket.classList.remove('d-none');
       else if (state === 'pending') chatStatePending.classList.remove('d-none');
       else if (state === 'active') chatStateActive.classList.remove('d-none');
    }

    function setupActiveChat(ticket) {
       document.getElementById('activeSubject').innerText = ticket.subject;
       if (ticket.adminId) {
          document.getElementById('chatAdminName').innerText = ticket.adminId.name || 'Mentor';

       }
    }

    // Raise Ticket
    document.getElementById('raiseTicketForm')?.addEventListener('submit', (e) => {
       e.preventDefault();
       const subject = document.getElementById('ticketSubject').value;
       const btn = e.target.querySelector('button');
       btn.disabled = true;
       btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Raising...';

       fetch('/chat/ticket', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ subject })
       })
       .then(res => res.json())
       .then(data => {
          if (data.success) {
             currentTicketId = data.ticket._id;
             document.getElementById('pendingSubject').innerText = data.ticket.subject;
             showChatState('pending');
             startChatPolling();
          } else {
             alert(data.message || 'Error raising ticket');
             btn.disabled = false;
             btn.innerHTML = '<i class="bi bi-send-plus me-2"></i> Raise Ticket';
          }
       }).catch(console.error);
    });

    // Polling logic
    function startChatPolling() {
       if (chatPollInterval) clearInterval(chatPollInterval);
       pollMessages(); // initial fetch
       chatPollInterval = setInterval(pollMessages, 3000);
    }

    function pollMessages() {
       if (!currentTicketId) return;

       let url = `/chat/messages/${currentTicketId}`;
       if (lastMessageId) url += `?lastMessageId=${lastMessageId}`;

       fetch(url, { cache: 'no-store' })
         .then(res => res.json())
         .then(data => {
            if (!data.success) return;
            
            // Check if ticket closed or accepted while pending
            if (data.status === 'closed') {
               clearInterval(chatPollInterval);
               showToast('Chat session ended by mentor.', 'info');
               setTimeout(() => location.reload(), 2000);
               return;
            }
            if (!chatStateActive.classList.contains('d-none') === false && data.status === 'accepted') {
                // Transitioned from pending to accepted
                fetchTicketStatus(); 
                return;
            }

            // Update mentor online status
            const statusDot = document.getElementById('chatAdminStatus');
            const statusText = document.getElementById('chatAdminStatusText');
            const pingDot = document.getElementById('pingStatusDot');
            const pingTxt = document.getElementById('pingStatusText');

            if (data.opponentIsOnline) {
               if(statusDot) { statusDot.classList.remove('bg-secondary'); statusDot.classList.add('bg-success'); }
               if(statusText) { statusText.innerText = 'Online'; statusText.classList.remove('text-secondary'); statusText.classList.add('text-success'); }
               if(pingDot) { pingDot.classList.remove('bg-secondary', 'spinner-grow', 'spinner-grow-sm'); pingDot.classList.add('rounded-circle', 'bg-success'); }
               if(pingTxt) { pingTxt.innerText = 'Mentor Online'; pingTxt.classList.remove('text-secondary'); pingTxt.classList.add('text-success'); }
            } else {
               if(statusDot) { statusDot.classList.remove('bg-success'); statusDot.classList.add('bg-secondary'); }
               if(statusText) { statusText.innerText = 'Offline'; statusText.classList.remove('text-success'); statusText.classList.add('text-secondary'); }
               if(pingDot) { pingDot.classList.remove('bg-success', 'spinner-grow', 'spinner-grow-sm'); pingDot.classList.add('rounded-circle', 'bg-secondary'); }
               if(pingTxt) { pingTxt.innerText = 'Mentor Offline'; pingTxt.classList.remove('text-success'); pingTxt.classList.add('text-secondary'); }
            }

            // Render new messages
            if (data.messages && data.messages.length > 0 && data.status === 'accepted') {
               data.messages.forEach(msg => {
                  renderMessage(msg);
                  lastMessageId = msg._id;
               });
               chatMessagesBox.scrollTop = chatMessagesBox.scrollHeight;
               
               if (isChatOpen) markMessagesAsRead(currentTicketId);
            }
         }).catch(console.error);
    }

    function renderMessage(msg) {
        const isIntern = msg.senderRole === 'intern';
        const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        
        const bubbleWrap = document.createElement('div');
        bubbleWrap.className = `chat-bubble ${isIntern ? 'chat-bubble-intern' : 'chat-bubble-admin'}`;
        
        bubbleWrap.innerHTML = `
           <div>${escapeHtml(msg.text)}</div>
           <span class="chat-time">${time}</span>
        `;
        chatMessagesBox.appendChild(bubbleWrap);
    }

    // Send Message
    document.getElementById('chatSendBtn')?.addEventListener('click', sendMessage);
    document.getElementById('chatInputMessage')?.addEventListener('keypress', (e) => {
       if (e.key === 'Enter' && !e.shiftKey) {
           e.preventDefault();
           sendMessage();
       }
    });

    function sendMessage() {
       const input = document.getElementById('chatInputMessage');
       const text = input.value.trim();
       if (!text || !currentTicketId) return;

       input.value = '';
       document.getElementById('emojiPanel').classList.remove('show');

       fetch('/chat/message', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ticketId: currentTicketId, text })
       })
       .then(res => res.json())
       .then(data => {
          if (data.success) {
             renderMessage(data.message);
             lastMessageId = data.message._id;
             chatMessagesBox.scrollTop = chatMessagesBox.scrollHeight;
          }
       }).catch(console.error);
    }

    function markMessagesAsRead(ticketId) {
        fetch(`/chat/mark-read/${ticketId}`, { method: 'POST' });
        const badge = document.getElementById('chatUnreadBadge');
        if (badge) badge.classList.add('d-none');
    }

    function fetchUnreadCount() {
        if (isChatOpen) return; // don't show badge if we are already reading
        fetch('/chat/unread-badge')
           .then(res => res.json())
           .then(data => {
               const badge = document.getElementById('chatUnreadBadge');
               if (data.success && data.count > 0) {
                   badge.innerText = data.count > 99 ? '99+' : data.count;
                   badge.classList.remove('d-none');
               } else {
                   badge.classList.add('d-none');
               }
           }).catch(console.error);
    }

    const EMOJIS = ["👍","👎","😊","😂","🤣","😍","🙏","🔥","🎉","💡","✅","❌","❓","👀","🙌","👏","🚀","💻","😅","😎","🥺","😢","😡","🤔"];
    const emojiPanel = document.getElementById('emojiPanel');
    const toggleEmojiBtn = document.getElementById('toggleEmojiBtn');
    
    if (emojiPanel && toggleEmojiBtn) {
        EMOJIS.forEach(emoji => {
           const btn = document.createElement('button');
           btn.type = 'button';
           btn.className = 'emoji-btn';
           btn.innerText = emoji;
           btn.onclick = () => {
              const input = document.getElementById('chatInputMessage');
              input.value += emoji;
              input.focus();
           };
           emojiPanel.appendChild(btn);
        });

        toggleEmojiBtn.addEventListener('click', (e) => {
           e.stopPropagation();
           emojiPanel.classList.toggle('show');
        });

        document.addEventListener('click', (e) => {
           if (!emojiPanel.contains(e.target) && e.target !== toggleEmojiBtn) {
              emojiPanel.classList.remove('show');
           }
        });
    }

    function escapeHtml(unsafe) {
        return unsafe
             .replace(/&/g, "&amp;")
             .replace(/</g, "&lt;")
             .replace(/>/g, "&gt;")
             .replace(/"/g, "&quot;")
             .replace(/'/g, "&#039;");
    }

  </script>
</body>
</html>