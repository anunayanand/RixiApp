<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Intern Dashboard | Rixi Lab</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />

  <!-- Favicons -->
  <link href="/img/Rixi Lab New Logo PNG.png" rel="icon" />
  <link href="/img/apple-touch-icon.png" rel="apple-touch-icon" />

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

  <!-- Main Dashboard CSS -->
  <link href="/css/intern.css" rel="stylesheet" />
</head>

<body>
  <%- include('partials/loader') %>

  <!-- Mobile Sidebar Overlay -->
  <div class="id-sidebar-overlay" id="sidebarOverlay"></div>

  <!-- SIDEBAR -->
  <aside class="id-sidebar" id="sidebar">
    <!-- Brand -->
    <div class="id-sidebar-brand">
      <img src="/img/Rixi Lab New Logo PNG.png" alt="Rixi Lab Logo" />
      <div class="id-sidebar-brand-text">
        <h2>Rixi Lab</h2>
        <span class="id-sidebar-badge">INTERN</span>
      </div>
    </div>

    <!-- Profile -->
    <div class="id-sidebar-profile">
      <div class="id-profile-img-wrap" data-bs-toggle="modal" data-bs-target="#updateProfileModal" title="Update Profile Picture">
        <img src="<%= intern.img_url %>" alt="Profile" />
      </div>
      <% const formattedName = intern.name.trim().split(" ").slice(0, 2).join(" "); %>
      <h4><%= formattedName %></h4>
      <p><%= intern.intern_id %></p>
      
      <div class="id-sidebar-profile-stats" >
        <div>
          <span>Batch No</span>
          <strong><%= intern.batch_no %></strong>
        </div>
        <div>
          <span>Duration</span>
          <strong><%= intern.duration %> Weeks</strong>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="id-sidebar-nav">
      <div class="id-sidebar-nav-label">Main Menu</div>
      <a href="#dashboard" class="nav-link active" onclick="switchSection('dashboard', this)">
        <i class="bi bi-grid-1x2-fill"></i>
        <span>Dashboard</span>
      </a>
      <a href="#projects" class="nav-link" onclick="switchSection('projects', this)">
        <i class="bi bi-kanban-fill"></i>
        <span>Projects Timeline</span>
      </a>
      <a href="#quiz" class="nav-link d-none d-md-flex" onclick="switchSection('quiz', this)">
        <i class="bi bi-patch-question-fill"></i>
        <span>Quiz Assessment</span>
      </a>
      <a href="#meetings" class="nav-link" onclick="switchSection('meetings', this)">
        <i class="bi bi-camera-video-fill"></i>
        <span>Meetings</span>
      </a>
      <a href="#documents" class="nav-link" onclick="switchSection('documents', this)">
        <i class="bi bi-file-earmark-text-fill"></i>
        <span>Documents</span>
      </a>
      
      <a href="#chat" class="nav-link" onclick="switchSection('chat', this)" id="navChatLink">
        <i class="bi bi-chat-dots-fill"></i>
        <span>Support Chat</span>
        <span id="chatUnreadBadge" class="chat-nav-badge d-none">0</span>
      </a>
      
      <!-- Logout for Mobile -->
      <a href="#dashboard" class="nav-link d-xl-none text-danger mt-4" data-bs-toggle="modal" data-bs-target="#logoutModal" style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px;">
        <i class="bi bi-box-arrow-right"></i>
        <span>Logout</span>
      </a>
    </nav>

    <div class="id-sidebar-footer">
      Technical Support:<br>
      <strong style="color: var(--primary);">support@rixilab.tech</strong><br>
      <small>Copyright © 2026 Rixi Lab. All rights reserved.</small>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="id-main-content">
    
    <!-- TOPBAR -->
    <header class="id-topbar">
      <div class="id-topbar-left">
        <button class="id-sidebar-toggle" id="sidebarToggle">
          <i class="bi bi-list"></i>
        </button>
        <div>
          <h4 id="topbarTitle">Dashboard</h4>
          <p class="d-none d-sm-block mt-2">Welcome to Rixi Lab, <%= intern.name %></p>
        </div>
      </div>

      <div class="id-topbar-right">
        
        <!-- Notifications -->
        <div class="dropdown">
          <button class="id-topbar-btn" data-bs-toggle="dropdown" aria-expanded="false" id="notificationButton">
            <i class="bi bi-bell"></i>
            <% const unreadCount = notifications ? notifications.length : 0; %>
            <% if (unreadCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle p-1 rounded-circle" style="background-color: var(--primary);">
                <span class="visually-hidden">New alerts</span>
              </span>
            <% } %>
          </button>
          
          <ul class="dropdown-menu dropdown-menu-end notif-dropdown" id="notificationList">
            <li class="notif-header">
              <span>Notifications (<%= unreadCount %>)</span>
              <% if (notifications && notifications.length > 0) { %>
                <button type="button" id="markAllBtn" class="btn btn-sm btn-outline-light py-0 px-2" style="font-size: 0.7rem; color: #fff; border-color: rgba(255,255,255,0.3);">Mark All</button>
              <% } %>
            </li>
            <div style="max-height: 300px; overflow-y: auto;">
              <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach(n => { %>
                  <li class="notif-item" data-id="<%= n._id %>">
                    <div>
                      <strong><%= n.title %></strong>
                      <small class="d-block"><%= n.message %></small>
                    </div>
                    <button type="button" class="btn btn-sm text-success mark-as-read border-0"><i class="bi bi-check2-circle fs-5"></i></button>
                  </li>
                <% }) %>
              <% } else { %>
                <li class="p-3 text-center text-muted small">No new notifications 🎉</li>
              <% } %>
            </div>
          </ul>
        </div>

        <!-- User Dropdown (Replaces Header logout) -->
        <div class="dropdown ms-2">
          <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" style="color: var(--text-primary); font-weight: 500;">
            <img src="<%= intern.img_url %>" alt="Profile" class="rounded-circle border border-2 shadow-sm" width="42" height="42" style="object-fit: cover; border-color: white !important;">
            <span class="ms-2 d-none d-md-inline" style="font-size: 0.9rem;"><%= intern.name.trim().split(" ")[0] %></span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end profile-dropdown-menu">
            <li><h6 class="dropdown-header">Signed in as <br><strong><%= intern.email %></strong></h6></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#updateProfileModal"><i class="bi bi-person me-2"></i> Update Photo</a></li>
            <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#passwordModal"><i class="bi bi-shield-lock me-2"></i> Change Password</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="#dashboard" data-bs-toggle="modal" data-bs-target="#logoutModal"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
          </ul>
        </div>

      </div>
    </header>

    <!-- CONTENT BODY -->
    <div class="id-content-body">
      
      <!-- 1. DASHBOARD SECTION -->
      <section id="dashboard" class="id-section active">
        
        <!-- Claymorphism Stat Cards Row -->
        <div class="row g-4 mb-4">
          <div class="col-12 col-md-4">
            <div class="id-stat-card h-100">
              <div class="id-stat-icon"><i class="bi bi-kanban"></i></div>
              <div class="id-stat-title">Projects Assigned</div>
              <div class="id-stat-value"><%= totalProjects %></div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="id-stat-card h-100">
              <div class="id-stat-icon"><i class="bi bi-calendar-check" style="color: #ff6600;"></i></div>
              <div class="id-stat-title">Attendance</div>
              <div class="id-stat-value"><%= attendanceRate %>%</div>
            </div>
          </div>
          <div class="col-12 col-md-4">
            <div class="id-stat-card h-100">
              <div class="id-stat-icon"><i class="bi bi-graph-up-arrow " style="color: #ff6600;"></i></div>
              <div class="id-stat-title">Overall Progress</div>
              <div class="id-stat-value"><%= progress %>%</div>
            </div>
          </div>
        </div>

        <!-- Glassmorphism Details Panels -->
        <div class="row g-4">
          <div class="col-12 col-lg-6">
            <div class="id-glass-panel h-100">
              <h3 class="id-panel-title"><i class="bi bi-building"></i> College Details</h3>
              <ul class="id-info-list">
                <li><span class="id-info-label">University</span><span class="id-info-value"><%= intern.university %></span></li>
                <li><span class="id-info-label">College</span><span class="id-info-value"><%= intern.college %></span></li>
                <li><span class="id-info-label">Course</span><span class="id-info-value"><%= intern.course %></span></li>
                <li><span class="id-info-label">Branch</span><span class="id-info-value"><%= intern.branch %></span></li>
                <li><span class="id-info-label">Year/Sem</span><span class="id-info-value"><%= intern.year_sem %></span></li>
              </ul>
            </div>
          </div>
          <div class="col-12 col-lg-6">
            <div class="id-glass-panel h-100">
              <h3 class="id-panel-title"><i class="bi bi-briefcase"></i> Internship Details</h3>
              <ul class="id-info-list">
                <li><span class="id-info-label">Intern ID</span><span class="id-info-value" style="color: var(--primary);"><%= intern.intern_id %></span></li>
                <li><span class="id-info-label">Domain</span><span class="id-info-value"><%= intern.domain %></span></li>
                <li><span class="id-info-label">Duration</span><span class="id-info-value"><%= intern.duration %> Weeks</span></li>
                <li><span class="id-info-label">Start Date</span><span class="id-info-value"><%= startingDate %></span></li>
                <li><span class="id-info-label">Mentor</span><span class="id-info-value"><%= mentorName %></span></li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. PROJECTS SECTION -->
      <section id="projects" class="id-section">
        
        <!-- Timeline Progress -->
        <div class="id-progress-wrapper">
          <div class="id-progress-header">
            <h3>Your Project Timeline</h3>
            <span class="id-progress-pct"><%= progress %>%</span>
          </div>
          <div class="id-progress-bar-container">
            <div class="id-progress-bar-fill" style="width: <%= progress %>%;"></div>
          </div>
        </div>

        <div class="row">
          <% if (intern.projectAssigned && intern.projectAssigned.length > 0) { %> 
            <% intern.projectAssigned.forEach(sub => { 
                const proj = projects.find(p => p._id.toString() === sub.projectId.toString()); 
            %>
              <div class="col-12">
                <div class="id-project-card">
                  <!-- Project Info -->
                  <div class="id-project-info">
                    <h5><%= proj ? proj.title : 'N/A' %></h5>
                    <p><%= proj ? proj.description : '' %></p>
                  </div>
                  
                  <!-- Actions -->
                  <div class="id-project-actions mt-3 mt-md-0">
                    <% if (sub.status === 'accepted') { %>
                      <span class="id-status-badge id-status-accepted"><i class="bi bi-check-circle-fill me-1"></i> Accepted</span>
                    <% } else if (sub.status === 'rejected') { %>
                      <span class="id-status-badge id-status-rejected"><i class="bi bi-x-circle-fill me-1"></i> Rejected</span>
                    <% } else{ %>
                      <span class="id-status-badge id-status-pending"><i class="bi bi-clock-fill me-1"></i> Pending</span>
                    <% }  %>

                    <a href="<%= proj ? proj.downloadLink : '#' %>" target="_blank" class="btn btn-outline-primary-custom">
                      <i class="bi bi-download me-1"></i> Download
                    </a>

                    <% if (sub.status !== 'accepted' && proj && !proj.isHidden) { %>
                      <a href="<%= proj.uploadLink %>" target="_blank" class="btn btn-primary-custom">
                        <i class="bi bi-upload me-1"></i> Upload
                      </a>
                    <% } else if (sub.status !== 'accepted' && proj && proj.isHidden) { %>
                      <button class="btn btn-secondary px-4 disabled">Closed</button>
                    <% } else { %>
                      <button class="btn btn-outline-success  disabled">Uploaded</button>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %> 
          <% } else { %>
            <div class="col-12 text-center py-5">
              <i class="bi bi-folder-x fs-1 text-light opacity-50 mb-3 d-block"></i>
              <p class="text-light">No projects assigned yet.</p>
            </div>
          <% } %>
        </div>
      </section>

      <!-- 2.5 QUIZ SECTION -->
      <section id="quiz" class="id-section">
        <h3 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-patch-question-fill me-2" style="color: #ff6600;"></i> Assigned Quizzes</h3>
        
        <div class="row g-3">
          <% if (assignedQuizzes && assignedQuizzes.length > 0) { %> 
            <% assignedQuizzes.forEach(q => { %>
              <div class="col-12 mt-4">
                <div class="id-project-card id-quiz-card">
                  <div class="d-flex align-items-center gap-4 w-100">
                    <div class="id-quiz-icon">
                      <i class="bi bi-patch-question-fill"></i>
                    </div>
                    
                    <div class="id-project-info flex-grow-1">
                      <h5><%= q.quiz.title %></h5>
                      <p class="mb-1">
                        Score: <strong><%= intern.quiz_score %></strong> &nbsp;•&nbsp; Attempts: <%= q.attemptCount %> / 2
                        <% if (q.attemptCount >= 1) { %>
                          <% if (intern.isPassed) { %>
                            <span class="badge bg-success ms-2">Pass</span>
                          <% } else { %>
                            <span class="badge bg-danger ms-2">Fail</span>
                          <% } %>
                        <% } %>
                      </p>
                    </div>

                    <div class="id-project-actions flex-shrink-0">
                      <% if (q.isClosed) { %>
                        <button class="btn btn-danger px-4" disabled>Closed</button>
                      <% } else if (q.attemptCount >= 2) { %>
                        <button class="btn btn-secondary px-4" disabled>No Attempts Left</button>
                      <% } else { %>
                        <a href="/intern/quiz/<%= q.quiz._id %>" class="btn btn-success px-4" style="font-weight: 600;" id="startQuizBtn">
                          <i class="bi bi-play-circle-fill me-1"></i> Start Quiz
                        </a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %> 
          <% } else { %>
            <div class="col-12 text-center py-5">
              <i class="bi bi-patch-question-fill fs-1 text-light opacity-50 mb-3 d-block"></i>
              <p class="text-light">Your quiz will be assigned once your project submission is accepted.</p>
            </div>
          <% } %>
        </div>
      </section>

      <!-- 3. MEETINGS SECTION -->
      <section id="meetings" class="id-section">
        <h3 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-camera-video me-2" style="color: #ff6600;"></i> Scheduled Meetings</h3>
        
        <div class="row g-3">
          <% if (assignedMeetings && assignedMeetings.length > 0) { %> 
            <% assignedMeetings.forEach(meeting => { %>
              <div class="col-12 col-md-6 col-lg-12">
                <div class="id-meeting-card">
                  <div class="d-flex">
                    <div class="me-3 mt-1">
                      <i class="bi bi-calendar-event fs-3" style="color: var(--text-primary);"></i>
                    </div>
                    <div>
                      <h5 class="fw-bold mb-1" style="color: var(--text-primary);"><%= meeting.title || 'Untitled Meeting' %></h5>
                      <p class="mb-0 text-secondary" style="font-size: 0.85rem;">
                        <span class="badge bg-light text-dark border me-2">Week <%= meeting.week || 'N/A' %></span>
                        <i class="bi bi-clock me-1"></i> 
                        <span class="meeting-time" data-time="<%= meeting.scheduledTime %>">
                          <%= meeting.scheduledTime ? new Date(meeting.scheduledTime).toLocaleString() : 'Time not set' %>
                        </span>
                      </p>
                    </div>
                  </div>

                  <div class="id-project-actions mt-3 mt-lg-0">
                    <a href="<%= meeting.link || '#' %>" target="_blank" class="btn btn-outline-primary-custom">
                      <i class="bi bi-box-arrow-up-right me-1"></i> Join Meeting
                    </a>

                    <span class="id-status-badge <% if (meeting.attendance === 'present') { %> id-status-accepted <% } else if (meeting.attendance === 'absent') { %> id-status-rejected <% } else { %> bg-secondary text-white <% } %>">
                      <%= meeting.attendance ? meeting.attendance.toUpperCase() : 'N/A' %>
                    </span>
                  </div>
                </div>
              </div>
            <% }) %> 
          <% } else { %>
            <div class="col-12 text-center py-5">
              <i class="bi bi-camera-video-off fs-1 text-light opacity-50 mb-3 d-block"></i>
              <p class="text-light">No upcoming meetings scheduled.</p>
            </div>
          <% } %>
        </div>
      </section>

      <!-- 4. DOCUMENTS SECTION -->
     <section id="documents" class="id-section">
        <h3 class="mb-4" style="font-weight: 700; color: var(--text-primary);"><i class="bi bi-folder2-open me-2" style="color: #ff6600;"></i> Internship Documents</h3>
        
        <div class="row g-4">
          <!-- Offer Letter -->
          <div class="col-12 col-xl-6">
            <div class="id-doc-card">
              <div class="d-flex align-items-center gap-3">
                <div class="id-doc-icon"><i class="bi bi-envelope-paper"></i></div>
                <div>
                  <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Offer Letter</h5>
                  <p class="mb-0 text-secondary" style="font-size: 0.85rem;">Official internship offer document.</p>
                </div>
              </div>
              <a href="<%= intern.offer_letter || `/download-offer-letter/${intern._id}` %>" target="_blank" class="btn btn-outline-primary-custom rounded-circle ">
                <i class="bi bi-download"></i>
              </a>
            </div>
          </div>

          <!-- Feedback Form -->
          <% if (progress === 100) { %>
            <div class="col-12 col-xl-6">
              <div class="id-doc-card" style="border-color: #10b981;">
                <div class="d-flex align-items-center gap-3">
                  <div class="id-doc-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i class="bi bi-chat-square-text"></i></div>
                  <div>
                    <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Internship Feedback</h5>
                    <p class="mb-0 text-secondary" style="font-size: 0.85rem;">Submit your program feedback.</p>
                  </div>
                </div>
                <a href="https://forms.gle/EVts4YfhRZCnp6aj8" target="_blank" class="btn btn-outline-success rounded-circle ">
                  <i class="bi bi-arrow-right"></i>
                </a>
              </div>
            </div>
          <% } %>

          <!-- Certificate -->
          <div class="col-12 col-xl-6">
            <div class="id-doc-card">
              <div class="d-flex align-items-center gap-3">
                <div class="id-doc-icon"><i class="bi bi-award"></i></div>
                <div>
                  <h5 class="fw-bold mb-1" style="color: var(--text-primary);">Completion Certificate</h5>
                  <p class="mb-0 text-secondary" style="font-size: 0.85rem;">Unlocked upon program completion.</p>
                </div>
              </div>
              <% if (intern.certificate_link) { %>
                <a href="<%= intern.certificate_link %>" download class="btn btn-outline-primary-custom rounded-circle p-2 px-3"><i class="bi bi-download"></i></a>
              <% } else if (intern.completion_date) { %>
                <a href="/download-certificate/<%= intern._id %>" target="_blank" class="btn btn-outline-primary-custom rounded-circle "><i class="bi bi-download"></i></a>
              <% } else { %>
                <button class="btn btn-secondary rounded-circle p-2 px-3 opacity-50" disabled><i class="bi bi-lock-fill"></i></button>
              <% } %>
            </div>
          </div>

        </div>
      </section>

      <!-- 5. CHAT SECTION -->
      <section id="chat" class="id-section">
        <h3 class="mb-4 d-flex align-items-center" style="font-weight: 700; color: var(--text-primary);">
          <span><i class="bi bi-chat-dots me-2" style="color: #ff6600;"></i> Chat with Mentor</span>
          <div class="ms-auto d-flex align-items-center" style="font-size: 0.85rem; font-weight: 500;">
            <div class="spinner-grow spinner-grow-sm text-secondary me-2" role="status" id="pingStatusDot"></div>
            <span id="pingStatusText" class="text-secondary">Checking Status...</span>
          </div>
        </h3>
        
        <!-- State 1: Raise Ticket Form -->
        <div id="chatStateNoTicket" class="chat-ticket-card d-none">
          <div class="mb-4">
            <i class="bi bi-chat-square-text " style="font-size: 3rem; color: #ff6600;"></i>
          </div>
          <h4 class="text-white fw-bold mb-2">Need Help?</h4>
          <p class="text-secondary small mb-4">Raise a support ticket to start a one-to-one chat with your assigned mentor.</p>
          <form id="raiseTicketForm">
            <div class="mb-3 text-start">
              <label class="form-label text-white small fw-semibold">Subject</label>
              <select class="form-select form-control" id="ticketSubject" style="background: var(--surface-alt); border-color: var(--border); color: var(--text-primary);" required>
                <option value="" disabled selected>Select a topic...</option>
                <option value="Project Guidance">Project Guidance</option>
                <option value="Meeting Request">Meeting Request</option>
                <option value="General Query">General Query</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-send-plus me-2"></i> Raise Ticket</button>
          </form>
        </div>

        <!-- State 2: Ticket Pending -->
        <div id="chatStatePending" class="chat-ticket-card d-none">
          <div class="spinner-grow mb-4" role="status" style="width: 3rem; height: 3rem; color:#ff6600"></div>
          <h4 class="text-white fw-bold mb-2">Ticket Raised</h4>
          <p class="text-secondary small mb-2">Subject: <strong id="pendingSubject" class="text-white">...</strong></p>
          <p class="text-secondary small mb-0">Waiting for your mentor to accept the request. Please check back soon.</p>
        </div>

        <!-- State 3: Active Chat -->
        <div id="chatStateActive" class="chat-window d-none">
          <div class="chat-header">
            <div class="d-flex align-items-center gap-3">
              <div class="position-relative">
                <img id="chatAdminImg" src="/img/chat-admin-profile.jpg" alt="Mentor" width="40" height="40" class="rounded-circle" style="object-fit: cover; border: 2px solid var(--border);">
                <span id="chatAdminStatus" class="position-absolute bottom-0 end-0 border border-2 border-dark rounded-circle bg-secondary" style="width: 10px; height: 10px;"></span>
              </div>
              <div>
                <h6 class="mb-0 fw-bold text-white mb-1" id="chatAdminName">Mentor Name</h6>
                <div class="text-secondary" style="font-size: 0.75rem;"><span id="chatAdminStatusText" class="text-secondary">Offline</span> • <span id="activeSubject" class="opacity-75"></span></div>
              </div>
            </div>
            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill"><i class="bi bi-shield-check me-1"></i> Active</span>
          </div>
          
          <div class="chat-messages" id="chatMessagesBox">
            <!-- Messages inserted here via JS -->
          </div>

          <div class="chat-input-bar">
            <!-- Emoji Panel -->
            <div id="emojiPanel" class="emoji-panel"></div>

            <button type="button" class="chat-emoji-btn" id="toggleEmojiBtn" title="Emojis"><i class="bi bi-emoji-smile"></i></button>
            <textarea class="chat-input" id="chatInputMessage" placeholder="Type your message..." rows="1"></textarea>
            <button type="button" class="chat-send-btn" id="chatSendBtn" title="Send"><i class="bi bi-send-fill"></i></button>
          </div>
        </div>

      </section>

    </div>
  </main>

