              <!-- Main JS Logics from existing view -->
              <script src="/js/intern.js"></script>

              <!-- UI Interactions Script -->
              <script>
                // Tab Switching Logic
                function switchSection(sectionId, element) {
                  // Prevent default anchor behavior if handled by script (we use hashes so it's fine)

                  // Remove active class from all nav links and hide all sections
                  document.querySelectorAll('.id-sidebar-nav .nav-link').forEach(el => el.classList.remove('active'));
                  document.querySelectorAll('.id-section').forEach(sec => sec.classList.remove('active'));

                  // Add active to clicked link and show target section
                  element.classList.add('active');
                  const target = document.getElementById(sectionId);
                  if (target) {
                    target.classList.add('active');
                  }

                  // Update Topbar Title
                  const titleSpan = element.querySelector('span');
                  if (titleSpan) {
                    document.getElementById('topbarTitle').innerText = titleSpan.innerText;
                  }

                  // Hide sidebar on mobile after click
                  if (window.innerWidth < 1200) {
                    document.getElementById('sidebar').classList.remove('show');
                    document.getElementById('sidebarOverlay').classList.remove('show');
                  }
                }

                function openFeedbackSection() {
                  document.querySelectorAll('.id-sidebar-nav .nav-link').forEach(el => el.classList.remove('active'));
                  document.querySelectorAll('.id-section').forEach(sec => sec.classList.remove('active'));
                  const target = document.getElementById('feedback_section');
                  if (target) target.classList.add('active');
                  document.getElementById('topbarTitle').innerText = 'Internship Feedback';
                }

                // Custom Lecture Video Logic
                let ytPlayer;
                let currentLectureId = null;
                let currentWatchedTime = 0;
                let maxWatchedTimeAllowed = 0;
                let isLectureCompleted = false;
                let animationFrameId = null;
                let syncInterval = null;
                let currentVideoDuration = 0;

                function onYouTubeIframeAPIReady() {
                  console.log("YouTube API Ready");
                }

                function markLectureCompletedInUI(id) {
                  const badge = document.getElementById('lecture-badge-' + id);
                  if (badge && badge.classList.contains('text-warning')) {
                    badge.className = 'badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 lecture-status-badge';
                    badge.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Watched';

                    // Update card onclick to reflect completed status so it can be replayed freely without skipping restriction
                    const card = badge.closest('.lecture-yt-card');
                    if (card) {
                      const oldOnclick = card.getAttribute('onclick');
                      if (oldOnclick) {
                        card.setAttribute('onclick', oldOnclick.replace(/,\s*false\s*\)$/, ', true)'));
                      }
                      
                      // Also update the progress bar visually
                      const progressFill = card.querySelector('.lecture-yt-progress-fill');
                      if (progressFill) progressFill.style.width = '100%';
                    }

                    // Update progress by counting DOM elements
                    const lectureBadges = document.querySelectorAll('.lecture-status-badge');
                    if (lectureBadges.length > 0) {
                      const total = lectureBadges.length;
                      const completed = document.querySelectorAll('.lecture-status-badge.text-success').length;
                      const pct = Math.round((completed / total) * 100);

                      const pctSpan = document.getElementById('lecture-progress-pct');
                      const barFill = document.getElementById('lecture-progress-bar');
                      const dashPct = document.getElementById('dashboard-lecture-progress');
                      if (pctSpan) pctSpan.innerText = pct + '%';
                      if (barFill) barFill.style.width = pct + '%';
                      if (dashPct) dashPct.innerText = pct + '%';
                    }
                  }
                }

                async function openLectureVideo(lectureId, title, watchedTime, completed) {
                  currentLectureId = lectureId;
                  isLectureCompleted = completed === true || completed === 'true';

                  if (isLectureCompleted) {
                    currentWatchedTime = 0;
                  } else {
                    currentWatchedTime = parseFloat(watchedTime) || 0;
                  }
                  maxWatchedTimeAllowed = parseFloat(watchedTime) || 0;

                  document.getElementById('lectureVideoTitle').innerText = title || "Lecture Video";
                  let cStatusEl1 = document.getElementById('customStatusText');
                  if (cStatusEl1) cStatusEl1.innerText = isLectureCompleted ? "Completed" : "0% Watched";
                  document.getElementById('customProgressBar').style.width = '0%';

                  // Fetch signed token from server (never expose videoId in HTML)
                  let videoId = '';
                  try {
                    const tokenRes = await fetch(`/intern/lecture/${lectureId}/token`);
                    if (!tokenRes.ok) throw new Error('Token fetch failed');
                    const tokenData = await tokenRes.json();
                    if (!tokenData.token) throw new Error('No token received');
                    // Decode videoId from token payload (server embeds it securely)
                    videoId = tokenData.videoId;
                  } catch (err) {
                    console.error('Failed to get lecture token:', err);
                    showToast('Could not load lecture. Please try again.', 'danger');
                    return;
                  }

                  const modal = new bootstrap.Modal(document.getElementById('lectureVideoModal'));

                  if (ytPlayer && ytPlayer.loadVideoById) {
                    ytPlayer.loadVideoById({ videoId: videoId, startSeconds: currentWatchedTime });
                  } else {
                    ytPlayer = new YT.Player('ytplayer', {
                      height: '100%',
                      width: '100%',
                      videoId: videoId,
                      playerVars: {
                        'playsinline': 1,
                        'controls': 0,
                        'disablekb': 1,
                        'rel': 0,
                        'modestbranding': 1,
                        'showinfo': 0,
                        'fs': 0
                      },
                      events: {
                        'onReady': onPlayerReady,
                        'onStateChange': onPlayerStateChange
                      }
                    });
                  }

                  modal.show();
                }

                function onPlayerReady(event) {
                  event.target.seekTo(currentWatchedTime);
                  event.target.playVideo();
                }

                function onPlayerStateChange(event) {
                  if (event.data == YT.PlayerState.PLAYING) {
                    document.getElementById('customPlayIcon').classList.remove('bi-play-fill');
                    document.getElementById('customPlayIcon').classList.add('bi-pause-fill');
                    document.getElementById('customPlayIcon').style.marginLeft = "0"; // Adjust icon positioning
                    currentVideoDuration = ytPlayer.getDuration();
                    startProgressTracking();
                  } else {
                    document.getElementById('customPlayIcon').classList.remove('bi-pause-fill');
                    document.getElementById('customPlayIcon').classList.add('bi-play-fill');
                    document.getElementById('customPlayIcon').style.marginLeft = "3px"; // Adjust icon positioning
                    stopProgressTracking();
                    syncProgressToServer(); // Save when paused
                  }
                }

                function toggleCustomPlay() {
                  if (!ytPlayer || !ytPlayer.getPlayerState) return;
                  const state = ytPlayer.getPlayerState();
                  if (state == YT.PlayerState.PLAYING) {
                    ytPlayer.pauseVideo();
                  } else {
                    ytPlayer.playVideo();
                  }
                }

                function toggleCustomMute() {
                  if (!ytPlayer) return;
                  const icon = document.getElementById('customMuteIcon');
                  if (ytPlayer.isMuted()) {
                    ytPlayer.unMute();
                    icon.classList.replace('bi-volume-mute-fill', 'bi-volume-up-fill');
                  } else {
                    ytPlayer.mute();
                    icon.classList.replace('bi-volume-up-fill', 'bi-volume-mute-fill');
                  }
                }

                function toggleCustomFullscreen() {
                  const dialog = document.querySelector('#lectureVideoModal .modal-dialog');
                  const icon = document.getElementById('customFullscreenIcon');

                  if (dialog) {
                    dialog.classList.toggle('modal-fullscreen');
                    const isFullscreen = dialog.classList.contains('modal-fullscreen');

                    if (icon) {
                      if (isFullscreen) {
                        icon.classList.replace('bi-fullscreen', 'bi-fullscreen-exit');
                      } else {
                        icon.classList.replace('bi-fullscreen-exit', 'bi-fullscreen');
                      }
                    }
                  }
                }

                let isScrubbing = false;

                function getScrubTime(event) {
                  const bar = document.getElementById('customProgressBarBg');
                  const rect = bar.getBoundingClientRect();
                  let clickX = event.clientX - rect.left;
                  let percent = clickX / rect.width;
                  if (percent < 0) percent = 0;
                  if (percent > 1) percent = 1;

                  let targetTime = percent * currentVideoDuration;

                  // ONLY IF NOT COMPLETED: Prevent skipping into unwatched territory!
                  if (!isLectureCompleted && targetTime > maxWatchedTimeAllowed + 1) {
                    targetTime = maxWatchedTimeAllowed;
                  }
                  return targetTime;
                }

                function startScrubbing(event) {
                  if (!ytPlayer || !currentVideoDuration) return;
                  isScrubbing = true;
                  handleScrubMove(event);
                  document.addEventListener('mousemove', handleScrubMove);
                  document.addEventListener('mouseup', stopScrubbing);
                  event.preventDefault(); // Prevent text selection while dragging
                }

                function handleScrubMove(event) {
                  if (!isScrubbing || !currentVideoDuration) return;
                  let targetTime = getScrubTime(event);
                  
                  let pcent = (targetTime / currentVideoDuration) * 100;
                  document.getElementById('customProgressBar').style.width = pcent + '%';
                  
                  const durationStr = formatTime(currentVideoDuration);
                  const currentStr = formatTime(targetTime);
                  const timeTextEl = document.getElementById('customTimeText');
                  if (timeTextEl && timeTextEl.innerText !== `${currentStr} / ${durationStr}`) {
                    timeTextEl.innerText = `${currentStr} / ${durationStr}`;
                  }

                  ytPlayer.seekTo(targetTime, true);
                }

                function stopScrubbing(event) {
                  if (!isScrubbing) return;
                  isScrubbing = false;
                  document.removeEventListener('mousemove', handleScrubMove);
                  document.removeEventListener('mouseup', stopScrubbing);
                }

                function progressLoop() {
                  if (!ytPlayer || !ytPlayer.getCurrentTime) return;

                  const ctime = ytPlayer.getCurrentTime();

                  // Anti-skip enforcement on the fly
                  if (!isLectureCompleted && ctime > maxWatchedTimeAllowed + 2) {
                    ytPlayer.seekTo(maxWatchedTimeAllowed);
                    animationFrameId = requestAnimationFrame(progressLoop);
                    return;
                  }

                  // Update max strictly
                  if (ctime > maxWatchedTimeAllowed) {
                    maxWatchedTimeAllowed = ctime;
                  }

                  // Format Time visually (checking equality avoids unnecessary reflows)
                  if (!isScrubbing) {
                    const durationStr = formatTime(currentVideoDuration);
                    const currentStr = formatTime(ctime);
                    const timeTextEl = document.getElementById('customTimeText');
                    if (timeTextEl && timeTextEl.innerText !== `${currentStr} / ${durationStr}`) {
                      timeTextEl.innerText = `${currentStr} / ${durationStr}`;
                    }

                    // Update Progress bar visually to show current playback position
                    let pcent = (ctime / currentVideoDuration) * 100;
                    if (pcent > 100) pcent = 100;
                    document.getElementById('customProgressBar').style.width = pcent + '%';
                  }

                  if (!isLectureCompleted) {
                    // Status shows highest achieved progress
                    let maxPcent = (maxWatchedTimeAllowed / currentVideoDuration) * 100;
                    let cStatusEl2 = document.getElementById('customStatusText');
                    if (cStatusEl2) {
                      const newStatus = Math.round(maxPcent) + '% Watched';
                      if (cStatusEl2.innerText !== newStatus) {
                        cStatusEl2.innerText = newStatus;
                      }
                    }

                    // Condition meets 99%
                    if (maxPcent >= 99) {
                      isLectureCompleted = true;
                      if (cStatusEl2) cStatusEl2.innerText = "Completed";
                      syncProgressToServer();
                      showToast("Lecture successfully completed!", "success");
                      markLectureCompletedInUI(currentLectureId);
                    }
                  }

                  animationFrameId = requestAnimationFrame(progressLoop);
                }

                function startProgressTracking() {
                  if (animationFrameId) cancelAnimationFrame(animationFrameId);
                  if (syncInterval) clearInterval(syncInterval);

                  progressLoop(); // Start visual update loop using requestAnimationFrame

                  // Server sync every 5 seconds securely
                  syncInterval = setInterval(syncProgressToServer, 5000);
                }

                function stopProgressTracking() {
                  if (animationFrameId) cancelAnimationFrame(animationFrameId);
                  if (syncInterval) clearInterval(syncInterval);
                }

                function syncProgressToServer() {
                  if (!currentLectureId || currentVideoDuration <= 0) return;

                  axios.post(`/intern/lecture/${currentLectureId}/progress`, {
                    watchedTime: maxWatchedTimeAllowed,
                    duration: currentVideoDuration
                  })
                    .then(({ data }) => {
                      if (data.success) {
                        // Update completion badge in UI
                        if (data.completed && !isLectureCompleted) {
                          isLectureCompleted = true;
                          let cStatusEl3 = document.getElementById('customStatusText');
                          if (cStatusEl3) cStatusEl3.innerText = "Completed";
                          markLectureCompletedInUI(currentLectureId);
                        }

                        // Update overall progress from server calculation (totalWatchedTime / totalAssignedDuration)
                        if (typeof data.overallProgress === 'number') {
                          const pct = data.overallProgress;
                          const pctSpan = document.getElementById('lecture-progress-pct');
                          const barFill = document.getElementById('lecture-progress-bar');
                          const dashPct = document.getElementById('dashboard-lecture-progress');
                          if (pctSpan) pctSpan.innerText = pct + '%';
                          if (barFill) barFill.style.width = pct + '%';
                          if (dashPct) dashPct.innerText = pct + '%';
                        }
                      }
                    })
                    .catch(err => console.error('Sync error:', err));
                }

                function formatTime(seconds) {
                  if (!seconds || isNaN(seconds)) return "0:00";
                  const s = Math.floor(seconds % 60);
                  const m = Math.floor(seconds / 60);
                  return m + ':' + (s < 10 ? '0' : '') + s;
                }

                function closeLectureVideo() {
                  if (ytPlayer && ytPlayer.pauseVideo) {
                    ytPlayer.pauseVideo();
                  }
                  stopProgressTracking();
                  syncProgressToServer();
                }

                // Keyboard listener for Spacebar play/pause
                document.addEventListener('keydown', function (event) {
                  if (currentLectureId && event.code === 'Space') {
                    event.preventDefault();
                    toggleCustomPlay();
                  }
                });

                // Clean up modal on hide as well (fallbacks)
                const lectureModalEl = document.getElementById('lectureVideoModal');
                if (lectureModalEl) {
                  lectureModalEl.addEventListener('hidden.bs.modal', function () {
                    closeLectureVideo();
                  });
                }

                // Sidebar Toggle Logic
                const toggleBtn = document.getElementById('sidebarToggle');
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('sidebarOverlay');

                if (toggleBtn && sidebar && overlay) {
                  toggleBtn.addEventListener('click', () => {
                    sidebar.classList.add('show');
                    overlay.classList.add('show');
                  });

                  overlay.addEventListener('click', () => {
                    sidebar.classList.remove('show');
                    overlay.classList.remove('show');
                  });
                }

    // Handle Required Password Modal
