  <% } %>

  <!-- Logout Confirmation Modal -->
  <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content shadow-lg" style="background-color: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);">
        <div class="modal-body text-center p-4">
          <div class="mb-3">
            <i class="bi bi-box-arrow-right text-danger" style="font-size: 3rem;"></i>
          </div>
          <h5 class="fw-bold text-white mb-2">Ready to Leave?</h5>
          <p class="text-secondary small mb-4">Are you sure you want to log out of your dashboard?</p>
          <div class="d-flex gap-2 justify-content-center">
            <button type="button" class="btn btn-outline-secondary w-50" data-bs-dismiss="modal" style="border-color: var(--border); color: var(--text-secondary);">Cancel</button>
