                  <input type="password" id="newPassGen" name="newPassword" class="form-control p-2 text-white shadow-sm" style="background: var(--surface-alt); border: 1px solid var(--border); border-right: none;" placeholder="Enter new password" minlength="6" required />
                  <button type="button" class="btn" style="background: var(--surface-alt); border: 1px solid var(--border); border-left: none; color: var(--text-secondary);" onclick="togglePwd('newPassGen', this)"><i class="bi bi-eye-slash"></i></button>
                </div>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold text-white small">Confirm Password</label>
                <div class="input-group">
                  <input type="password" id="confPassGen" name="confirmPassword" class="form-control p-2 text-white shadow-sm" style="background: var(--surface-alt); border: 1px solid var(--border); border-right: none;" placeholder="Confirm password" required minlength="6" />
                  <button type="button" class="btn" style="background: var(--surface-alt); border: 1px solid var(--border); border-left: none; color: var(--text-secondary);" onclick="togglePwd('confPassGen', this)"><i class="bi bi-eye-slash"></i></button>
