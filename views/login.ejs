  <!-- Vendor CSS Files -->
  <link href="/js/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/js/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <!-- <link href="/js/vendor/aos/aos.css" rel="stylesheet"> -->
  <link href="/js/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
  <link href="/js/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="/css/main.css" rel="stylesheet">
  <link href="/css/validation.css" rel="stylesheet">
</head>

<body class="index-page">
  <%- include('partials/loader') %>
    <header id="header" class="header d-flex align-items-center fixed-top">
      <div class="container position-relative d-flex align-items-center justify-content-between">

        <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
          <img src="/img/Rixi Lab New Logo PNG.png" alt="">
          <h1 class="sitename">Rixi Lab</h1>
        </a>

        <nav id="navmenu" class="navmenu">
          <ul>
            <li><a href="/" class="active">Home</a></li>
            <li><a href="internship">Internship</a></li>
            <li><a href="cap">CAP</a></li>
            <li><a href="/#about">About</a></li>
            <li><a href="/#services">Services</a></li>
            <li><a href="/bootcamp">Bootcamps</a></li>
            <li><a href="/certificate">Certificate</a></li>
            <li><a href="/#contact" style="color: white !important;">Contact</a></li>
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>

        <a class="btn-getstarted" href="internship">Internship</a>

      </div>
    </header>

    <main class="main "><br><br>
      <!-- Contact Section -->
      <section id="contact" class="contact section ">
        <!-- Section Title -->
        <div class="container  section-title" data-aos="fade-up" style="padding-bottom: 30px;">
          <h2 id="login-title">Intern Login</h2>
          <!-- <p>Necessitatibus eius consequatur ex aliquid fuga eum quidem sint consectetur velit</p> -->
        </div><!-- End Section Title -->

        <!-- Login Type Toggle -->
        <div class="container mb-4" data-aos="fade-up" data-aos-delay="50">
          <div class="login-tab-switcher">
            <button class="login-tab active" id="tab-intern" onclick="switchTab('intern')">
              <i class="bi bi-person-badge"></i> Intern
            </button>
            <button class="login-tab" id="tab-ambassador" onclick="switchTab('ambassador')">
              <i class="bi bi-star"></i> Ambassador
            </button>
            <!-- <button class="login-tab" id="tab-bootcamp" onclick="switchTab('bootcamp')"> -->
            <a class="login-tab" id="tab-bootcamp" href="/bootcamp-portal/login">
              <i class="bi bi-laptop"></i> Bootcamp
            </a>
          </div>
        </div>

        <div class="container" data-aos="fade-up" data-aos-delay="100">
          <div class="row d-flex justify-content-center">

            <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
              <div class="contact-form-wrapper">
                <div class="form-header">
                  <h3 id="formTitle">Login With Your Email & Password</h3>
                  <!-- <p id="formSubtitle" class="form-subtitle">Intern Portal</p> -->
                </div>

                <!-- Intern / Ambassador Form -->
                <form id="loginForm" class="php-email-form needs-validation" action="/login" method="POST" novalidate>
                  <input type="hidden" name="loginType" id="loginTypeInput" value="intern">

                  <div class="mb-3">
                    <label for="contactEmail" class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="email" id="contactEmail"
                      placeholder="Enter your email address" required>
                  </div>
                  <div class="mb-3">
                    <label for="InternID" class="form-label">Password</label>
                    <div class="position-relative">
                      <input type="password" name="password" class="form-control pe-5" id="InternID"
                        placeholder="Password" required>
                      <i class="bi bi-eye-slash position-absolute top-50 end-0 translate-middle-y me-3" id="toggleIcon"
                        style="cursor: pointer;" onclick="togglePassword()"></i>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label for="captchaInput" class="form-label">Enter the captcha below:</label>
                    <div id="captcha-container" class="mb-2"
                      style="display:flex; align-items:center; justify-content:center;">
                      <div id="captcha-text" class="form-control text-center fw-bold"
                        style="letter-spacing: 6px; font-size: 1.75rem; background: #000; color: #ff6600; font-family: 'Special Elite',system-ui;">
                        <%= captchaText %>
                      </div>
                      <button type="button" id="refresh-captcha"
                        style="background:none; border:none; margin-left:5px;margin-right: 5px; font-size:22px; color:#ff6600; cursor:pointer;">↻</button>
                      <input type="text" id="captchaInput" name="captchaInput" class="form-control"
                        placeholder="Enter captcha here" required>
                    </div>
                  </div>

                  <div class="mb-2 text-center" id="errorMsg"></div>

                  <button type="submit" class="submit-btn">
                    <span>Login</span>
                    <i class="bi bi-arrow-right"></i>
                  </button>
                  <div class="text-center mt-3">
                    <a href="/reset-password" style="text-decoration: none; color: #ff6600;">
                      Forgot Password? Click to Reset
                    </a>
                  </div>
                </form>

                <!-- Bootcamp Panel -->
                <div id="bootcampPanel" style="display:none;" class="text-center py-3">
                  <div class="bootcamp-login-icon mb-3">
                    <i class="bi bi-laptop" style="font-size:3rem; color:#ff6600;"></i>
                  </div>
                  <p class="mb-1" style="color:#ccc; font-size:0.95rem;">Access your bootcamp portal with OTP verification.</p>
                  <p class="mb-4" style="color:#888; font-size:0.82rem;">You'll receive a one-time password on your registered email.</p>
                  <a href="/bootcamp-portal/login" class="submit-btn d-inline-block text-decoration-none" style="min-width:220px;">
                    <span>Go to Bootcamp Portal</span>
                    <i class="bi bi-arrow-right"></i>
                  </a>
                </div>

              </div>
            </div>
          </div>
        </div>

        <style>
          .login-tab-switcher {
            display: flex;
            justify-content: center;
            gap: 0;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,102,0,0.25);
            border-radius: 50px;
            padding: 5px;
            max-width: 380px;
            margin: 0 auto;
          }
          .login-tab {
            flex: 1;
            padding: 9px 18px;
            border: none;
            border-radius: 50px;
            background: transparent;
            color: #aaa;
            font-size: 0.82rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
            letter-spacing: 0.03em;
          }
          .login-tab i {
            margin-right: 5px;
          }
          .login-tab.active {
            background: linear-gradient(135deg, #ff6600, #ff8c00);
            color: #fff;
            box-shadow: 0 4px 14px rgba(255,102,0,0.4);
          }
          .login-tab:hover:not(.active) {
            color: #ff6600;
            background: rgba(255,102,0,0.08);
          }
          .form-subtitle {
            color: #ff6600;
            font-size: 0.78rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin: 4px 0 0;
            font-weight: 600;
          }
          .bootcamp-login-icon {
            animation: pulse-icon 2s ease-in-out infinite;
          }
          @keyframes pulse-icon {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.08); opacity: 0.85; }
          }
          #loginForm, #bootcampPanel {
            transition: opacity 0.3s ease;
          }
        </style>
      </section><!-- /Contact Section -->

    </main>
    <%- include("partials/toaster") %>
      <footer id="footer" class="footer light-background">
        <div class="copyright text-center">
          <div
            class="container d-flex flex-column flex-lg-row justify-content-center justify-content-lg-between align-items-center">
            <div class="d-flex flex-column align-items-center align-items-lg-start">
              <div>
                © Copyright 2025-26 <strong><span>Rixi Lab</span></strong>. All Rights Reserved
              </div>
              <div class="credits">
                Designed by
                <a style="text-decoration: none; color: #ff6600" href="https://www.rixilab.tech"><b>Rixi Lab</b></a>
              </div>
            </div>

            <div class="social-links order-first order-lg-last mb-3 mb-lg-0">
              <a class="btn-getstarted btn-outline" style=" width: 5rem;" href="admin-login">Login</a>
              <a href="https://www.linkedin.com/company/rixilab"><i class="bi bi-linkedin"></i></a>
              <a href="https://www.facebook.com/rixilab"><i class="bi bi-facebook"></i></a>
              <a href="https://www.instagram.com/rixilab.in"><i class="bi bi-instagram"></i></a>
              <a href=""><i class="bi bi-twitter-x"></i></a>
            </div>
          </div>
        </div>
      </footer>


      <!-- Scroll Top -->
      <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i
          class="bi bi-arrow-up-short"></i></a>

      <!-- Vendor JS Files -->
      <script src="/js/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
      <script src="/js/vendor/aos/aos.js"></script>
      <script src="/js/vendor/glightbox/js/glightbox.min.js"></script>
      <script src="/js/vendor/purecounter/purecounter_vanilla.js"></script>
      <script src="/js/vendor/typed.js/typed.umd.js"></script>
      <script src="/js/vendor/swiper/swiper-bundle.min.js"></script>

      <!-- Main JS File -->
      <script src="/js/main.js"></script>
      <script>
        document.getElementById("refresh-captcha").addEventListener("click", async () => {
          try {
            const res = await fetch("/generate-captcha");
            const data = await res.json();
            document.getElementById("captcha-text").textContent = data.captcha;
          } catch (err) {
            console.error("Failed to refresh captcha:", err);
          }
        });
        const captchaText = document.getElementById("captcha-text");
        captchaText.addEventListener("contextmenu", e => e.preventDefault());
        captchaText.addEventListener("copy", e => e.preventDefault());
        captchaText.style.userSelect = "none";
      </script>
      <script>
        function switchTab(type) {
          // Update tab buttons
          document.querySelectorAll('.login-tab').forEach(t => t.classList.remove('active'));
          document.getElementById('tab-' + type).classList.add('active');

          const loginForm    = document.getElementById('loginForm');
          const bootcampPanel = document.getElementById('bootcampPanel');
          const formTitle    = document.getElementById('formTitle');
          const loginTitle = document.getElementById('login-title');
          const loginTypeInput = document.getElementById('loginTypeInput');

          if (type === 'bootcamp') {
            loginForm.style.display    = 'none';
            bootcampPanel.style.display = 'block';
            formTitle.textContent    = 'Bootcamp Portal Login';
            loginTitle.innerText = 'Bootcamp  Login';
          } else {
            loginForm.style.display    = 'block';
            bootcampPanel.style.display = 'none';
            loginTypeInput.value = type;
            if (type === 'intern') {
              formTitle.textContent    = 'Login With Your Email & Password';
              loginTitle.innerText = 'Intern Login';
            } else {
              formTitle.textContent    = 'Login With Your Email & Password';
              loginTitle.innerText = 'Ambassador Login';
            }
          }
        }
      </script>
      <script>
        function togglePassword() {
          const passwordInput = document.getElementById("InternID");
          const toggleIcon = document.getElementById("toggleIcon");
          if (passwordInput.type === "password") {
            passwordInput.type = "text";
            toggleIcon.classList.remove("bi-eye-slash");
            toggleIcon.classList.add("bi-eye");
          } else {
            passwordInput.type = "password";
            toggleIcon.classList.remove("bi-eye");
            toggleIcon.classList.add("bi-eye-slash");
          }
        }
      </script>

      <nav class="mobile-bottom-nav d-xl-none">
        <a href="/" class="bottom-nav-item">
          <i class="bi bi-house"></i><span>Home</span>
        </a>
        <a href="/internship" class="bottom-nav-item">
          <i class="bi bi-laptop"></i><span>Internship</span>
        </a>
        <a href="/cap" class="bottom-nav-item">
          <i class="bi bi-mortarboard"></i><span>CAP</span>
        </a>
        <a href="/bootcamp" class="bottom-nav-item">
          <i class="bi bi-laptop"></i><span>Bootcamps</span>
        </a>
        <a href="/certificate" class="bottom-nav-item">
          <i class="bi bi-award"></i><span>Certificate</span>
        </a>
      </nav>
</body>

</html>